{"build_type":"library","description":"Host-port module primitive - performs the mmap syscall mapping the given length of the descriptor as a shared readable writable region at a kernel-chosen address, returning the mapped address. Protection is read-write, the mapping is shared, and the offset is zero.","module_name":"attach-shared-descriptor-region-within-address-space","package_name":"attach-shared-descriptor-region-within-address-space","function_definitions":{"attach-shared-descriptor-region-within-address-space":{"return_type":"i64","parameter_definitions":[{"parameter_name":"length","parameter_type":"i64"},{"parameter_name":"fd","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"prot","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"shared","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"9","arg1":"zero","arg2":"length","arg3":"prot","arg4":"shared","arg5":"fd","arg6":"zero","result_variable":"r"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}