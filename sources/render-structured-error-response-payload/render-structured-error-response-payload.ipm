{"build_type":"library","description":"Build one structured error response object with the two canonical keys code (a machine error code) and error (a human-readable detail) and route it through the single sanctioned emitter, so no tool hand-rolls its own error JSON shape. Tools call this instead of constructing an error object inline, giving one uniform error envelope everywhere. Both arguments are string handles.","module_name":"render-structured-error-response-payload","package_name":"render-structured-error-response-payload","function_definitions":{"render-structured-error-response-payload":{"return_type":"i64","parameter_definitions":[{"parameter_name":"code","parameter_type":"i64"},{"parameter_name":"detail","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"s_code","variable_type":"str","assignment_operation":"string","source_target":"code"},{"instruction_type":"variable_declaration","variable_name":"s_error","variable_type":"str","assignment_operation":"string","source_target":"error"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"err","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"err"},{"kind":"var","value":"s_code"},{"kind":"var","value":"code"}]},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"err"},{"kind":"var","value":"s_error"},{"kind":"var","value":"detail"}]},{"instruction_type":"function_invocation","invocation_name":"write-result-object-toward-standard-output","invocation_arguments":[{"kind":"var","value":"err"}],"result_assignment_variable":"w","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"w"}}]}}}