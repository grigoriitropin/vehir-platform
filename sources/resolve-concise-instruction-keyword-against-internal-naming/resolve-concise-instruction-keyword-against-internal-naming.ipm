{"build_type":"library","description":"Translate a concise instruction keyword (the surface form an agent writes: call, let, return, sys, if_num, if_str, alu) into the internal instruction_type string the stored IR carries (function_invocation, variable_declaration, return_statement, invoke_kernel_syscall, conditional_branch, alu_operation). Keywords that are already identical between the concise and internal forms (field_read, field_write, array_read, array_write, global_read, global_write) and any unrecognized value pass through unchanged, so grep accepts both the concise names an agent naturally uses and the raw internal type names.","module_name":"resolve-concise-instruction-keyword-against-internal-naming","package_name":"resolve-concise-instruction-keyword-against-internal-naming","function_definitions":{"resolve-concise-instruction-keyword-against-internal-naming":{"return_type":"i64","parameter_definitions":[{"parameter_name":"kind","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"conditional_branch","condition_operation":"string_equals","condition_target":"kind","condition_value":"call","branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r1","variable_type":"str","assignment_operation":"string","source_target":"function_invocation"},{"instruction_type":"return_statement","return_payload":{"value":"r1"}}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_operation":"string_equals","condition_target":"kind","condition_value":"let","branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r2","variable_type":"str","assignment_operation":"string","source_target":"variable_declaration"},{"instruction_type":"return_statement","return_payload":{"value":"r2"}}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_operation":"string_equals","condition_target":"kind","condition_value":"return","branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r3","variable_type":"str","assignment_operation":"string","source_target":"return_statement"},{"instruction_type":"return_statement","return_payload":{"value":"r3"}}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_operation":"string_equals","condition_target":"kind","condition_value":"sys","branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r4","variable_type":"str","assignment_operation":"string","source_target":"invoke_kernel_syscall"},{"instruction_type":"return_statement","return_payload":{"value":"r4"}}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_operation":"string_equals","condition_target":"kind","condition_value":"if_num","branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r5","variable_type":"str","assignment_operation":"string","source_target":"conditional_branch"},{"instruction_type":"return_statement","return_payload":{"value":"r5"}}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_operation":"string_equals","condition_target":"kind","condition_value":"if_str","branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r6","variable_type":"str","assignment_operation":"string","source_target":"conditional_branch"},{"instruction_type":"return_statement","return_payload":{"value":"r6"}}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_operation":"string_equals","condition_target":"kind","condition_value":"alu","branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r7","variable_type":"str","assignment_operation":"string","source_target":"alu_operation"},{"instruction_type":"return_statement","return_payload":{"value":"r7"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"kind"}}]}}}