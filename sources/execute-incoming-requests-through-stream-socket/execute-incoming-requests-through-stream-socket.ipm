{"build_type":"daemon","description":"Sovereign bus daemon. Reads its shell_path configuration from the request via the sanctioned argument entry (no raw argv access), binds an abstract AF_UNIX SOCK_STREAM socket, then serves connections in a perpetual accept loop until terminated by its supervisor. Each connection is read to end of stream then forked: the child redirects standard output onto the connection and execve the configured shell so the tool result flows straight to the client socket with no pipe; the parent reaps and closes. A single scratch buffer is allocated once and reused for every connection.","module_name":"execute-incoming-requests-through-stream-socket","package_name":"execute-incoming-requests-through-stream-socket","function_definitions":{"execute-incoming-requests-through-stream-socket":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"addrsize","variable_type":"i64","assignment_operation":"literal","source_target":116},{"instruction_type":"variable_declaration","variable_name":"capbig","variable_type":"i64","assignment_operation":"literal","source_target":1048576},{"instruction_type":"variable_declaration","variable_name":"sockname","variable_type":"str","assignment_operation":"string","source_target":"vehir-bus-