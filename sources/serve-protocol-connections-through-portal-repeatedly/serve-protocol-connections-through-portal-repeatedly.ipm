{"build_type":"library","description":"Channel-B accept loop of the Model Context Protocol edge daemon: accept one connection, hand it to the Channel-B per-connection message router (route-protocol-messages-through-portal-across-connection, which submits tools/call through the kernel portal), then tail-recurse to accept the next connection after the client disconnects. Runs until the process is terminated. The scratch buffer is allocated once by the caller and reused for every connection. Carries no shell path because no shell is forked; the portal region base is a process global mapped by the answer-mcp Channel-B entry.","module_name":"serve-protocol-connections-through-portal-repeatedly","package_name":"serve-protocol-connections-through-portal-repeatedly","function_definitions":{"serve-protocol-connections-through-portal-repeatedly":{"return_type":"i64","parameter_definitions":[{"parameter_name":"listen_fd","parameter_type":"i64"},{"parameter_name":"scratch","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"43","arg1":"listen_fd","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"conn"},{"instruction_type":"function_invocation","invocation_name":"route-protocol-messages-through-portal-across-connection","invocation_arguments":[{"kind":"var","value":"conn"},{"kind":"var","value":"scratch"}],"result_assignment_variable":"d","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"serve-protocol-connections-through-portal-repeatedly","invocation_arguments":[{"kind":"var","value":"listen_fd"},{"kind":"var","value":"scratch"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}