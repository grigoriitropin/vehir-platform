{"build_type":"library","description":"Join a library directory path and an object symbol name into a NUL-terminated filesystem path `<libdir>/<name>`, returning the string_buffer data pointer. Used by the native object loader to locate the file backing a symbol (one package = one function = one file named by its symbol).","module_name":"concatenate-library-directory-joining-package-identifier","package_name":"concatenate-library-directory-joining-package-identifier","function_definitions":{"concatenate-library-directory-joining-package-identifier":{"return_type":"i64","parameter_definitions":[{"parameter_name":"libdir","parameter_type":"i64"},{"parameter_name":"name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"libdir"}]},{"instruction_type":"function_invocation","invocation_name":"append-single-octet-inside-expandable-buffer","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"int","value":47}]},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"name"}]},{"instruction_type":"field_read","struct":"string_buffer","field":"data","base":"buf","dest":"data"},{"instruction_type":"return_statement","return_payload":{"value":"data"}}]}}}