{"build_type":"library","description":"Drains the contiguous filled prefix of an ordered reorder buffer in launch order. Buffer layout (i64 slots over base buf): [0] = next cursor (launch index awaiting delivery), [1] = order accumulator, [3..] = filled flags indexed by launch position, [6..] = results indexed by launch position. Starting at the cursor it folds each contiguously-filled result into the accumulator (acc = acc*10 + result) in launch order, advancing the cursor, and stops at the first gap or at kbound. Recurses tail-style; mutates the buffer in place so partial prefixes delivered across separate completions accumulate correctly. This is the streaming ordered delivery (deliver launch-order prefix as it becomes ready), not wait-for-all.","module_name":"drain-contiguous-ordered-completion-prefix","package_name":"drain-contiguous-ordered-completion-prefix","function_definitions":{"drain-contiguous-ordered-completion-prefix":{"return_type":"i64","parameter_definitions":[{"parameter_name":"buf","parameter_type":"i64"},{"parameter_name":"kbound","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"six","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"variable_declaration","variable_name":"ten","variable_type":"i64","assignment_operation":"literal","source_target":10},{"instruction_type":"array_read","dest":"next","base":"buf","index":"zero","scale":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"next"},"rhs":{"value":"kbound"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"fi","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"fi","lhs":{"value":"three"},"rhs":{"value":"next"}},{"instruction_type":"array_read","dest":"filled","base":"buf","index":"fi","scale":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"filled"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"ri","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"ri","lhs":{"value":"six"},"rhs":{"value":"next"}},{"instruction_type":"array_read","dest":"res","base":"buf","index":"ri","scale":8},{"instruction_type":"array_read","dest":"acc0","base":"buf","index":"one","scale":8},{"instruction_type":"variable_declaration","variable_name":"acc1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"*","target":"acc1","lhs":{"value":"acc0"},"rhs":{"value":"ten"}},{"instruction_type":"variable_declaration","variable_name":"acc2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"acc2","lhs":{"value":"acc1"},"rhs":{"value":"res"}},{"instruction_type":"array_write","base":"buf","index":"one","value":"acc2","scale":8},{"instruction_type":"variable_declaration","variable_name":"nn","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"nn","lhs":{"value":"next"},"rhs":{"value":"one"}},{"instruction_type":"array_write","base":"buf","index":"zero","value":"nn","scale":8},{"instruction_type":"function_invocation","invocation_name":"drain-contiguous-ordered-completion-prefix","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"kbound"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}