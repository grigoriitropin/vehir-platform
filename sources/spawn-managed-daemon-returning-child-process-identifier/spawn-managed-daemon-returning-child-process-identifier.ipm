{"build_type":"library","description":"Fork the managed service. Reads service_path (ctx slot 0) and service_request (ctx slot 1) from the supervisor context struct, forks, and in the child calls the execve helper (which replaces the process with the service); the parent returns the child process identifier. The branch bodies are kept to a single call each so per-branch temporaries do not collide.","module_name":"spawn-managed-daemon-returning-child-process-identifier","package_name":"spawn-managed-daemon-returning-child-process-identifier","function_definitions":{"spawn-managed-daemon-returning-child-process-identifier":{"return_type":"i64","parameter_definitions":[{"parameter_name":"ctx","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"array_read","dest":"sp","base":"ctx","index":"zero","scale":8},{"instruction_type":"array_read","dest":"sr","base":"ctx","index":"one","scale":8},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"57","arg1":"zero","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"pid"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"pid"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"execute-daemon-binary-inside-forked-child","invocation_arguments":[{"kind":"var","value":"sp"},{"kind":"var","value":"sr"}],"result_assignment_variable":"cr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"cr"}}],"branch_on_failure":