{"build_type":"library","description":"Emit the generation's tool-policy.json as a BUILD OUTPUT: from the declared-build-state artifacts (each carries the name of a dispatchable tool), write {\"tools\":[{name, entry, calls, reads_stdin}]} into gen_bin_dir/tool-policy.json — a BUILD CACHE of the contracts for the shell's no-fork help path (the shell cannot run tools to collect their self-descriptions). The single source of truth is the derivation (derive_tool_contract_from_package_doc over the parsed AST); this file and the contract embedded in each binary are two build-generated copies of that one derivation and cannot drift. Derives each tool's contract from its parsed package AST (looked up in universe by package_name). Called by reconcile after it builds all artifacts, so the discovery list (read by emit_posix_unavailable_error_with_tools, a sibling of the shell binary) is always exactly what was built, with facts derived from code — add an artifact to declared-build-state, reconcile builds it, it appears in the tool list with its contract. No hand maintenance, no hand-written descriptions, no runtime directory scan. Reuses collect_tool_contracts_into_array, build_store_path, render_document_value_producing_cstring, open_file_for_writing, write_bytes_to_file, close_open_file.","module_name":"serialize-policy-definition-using-built-artifacts","package_name":"serialize-policy-definition-using-built-artifacts","function_definitions":{"serialize-policy-definition-using-built-artifacts":{"return_type":"i64","parameter_definitions":[{"parameter_name":"artifacts","parameter_type":"i64"},{"parameter_name":"gen_bin_dir","parameter_type":"i64"},{"parameter_name":"universe","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_tools","variable_type":"str","assignment_operation":"string","source_target":"tools"},{"instruction_type":"variable_declaration","variable_name":"s_policy","variable_type":"str","assignment_operation":"string","source_target":"tool-policy.json"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"res","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"tools","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"child","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"artifacts"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"artifacts","dest":"child"}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"gather-executable-contracts-inside-array","invocation_arguments":[{"kind":"var","value":"child"},{"kind":"var","value":"tools"},{"kind":"var","value":"universe"}],"result_assignment_variable":"cr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"res"},{"kind":"var","value":"s_tools"},{"kind":"var","value":"tools"}]},{"instruction_type":"function_invocation","invocation_name":"render-document-value-producing-cstring","invocation_arguments":[{"kind":"var","value":"res"}],"result_assignment_variable":"printed","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"printed"},"rhs":{"value":"zero"},"branch_on_success":[],"branch_on_failure":[{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"printed"}],"result_assignment_variable":"plen","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"construct-content-addressed-storage-location","invocation_arguments":[{"kind":"var","value":"gen_bin_dir"},{"kind":"var","value":"s_policy"}],"result_assignment_variable":"path","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"acquire-filepath-towards-writing-operations","invocation_arguments":[{"kind":"var","value":"path"}],"result_assignment_variable":"fd","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"transfer-character-sequence-towards-document","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"printed"},{"kind":"var","value":"plen"}]},{"instruction_type":"function_invocation","invocation_name":"release-allocated-system-descriptor-resource","invocation_arguments":[{"kind":"var","value":"fd"}]}]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}