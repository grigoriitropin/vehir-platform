":"function_invocation","invocation_name":"append-fiber-toward-scheduler-ready-stack","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"root"}],"result_assignment_variable":"_p","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"drive-fiber-scheduler-until-quiescent","invocation_arguments":[{"kind":"var","value":"buf"}],"result_assignment_variable":"_d","result_type":"i64"},{"instruction_type":"array_read","dest":"result","base":"buf","index":"fortyone","scale":8},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"186","arg1":"zero","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"tid"},{"instruction_type":"variable_declaration","variable_name":"ridx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"ridx","lhs":{"value":"five"},"rhs":{"value":"claim"}},{"instruction_type":"array_write","base":"shared","index":"ridx","value":"result","scale":8},{"instruction_type":"variable_declaration","variable_name":"tidx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"tidx","lhs":{"value":"seven"},"rhs":{"value":"claim"}},{"instruction_type":"array_write","base":"shared","index":"tidx","value":"tid","scale":8},{"instruction_type":"variable_declaration","variable_name":"didx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"didx","lhs":{"value":"nine"},"rhs":{"value":"claim"}},{"instruction_type":"array_write","base":"shared","index":"didx","value":"one","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}