{"build_type":"library","description":"Launcher-side helper (worker-runtime-FINAL A8): allocate a child worker's native stack of the given size from the arena and return its TOP (base + size), the value clone+CLONE_VM needs as the child's initial stack pointer. Single responsibility: stack allocation + top computation, so lower-launch emits only a call.","module_name":"allocate-worker-launch-stack-top","package_name":"allocate-worker-launch-stack-top","function_definitions":{"allocate-worker-launch-stack-top":{"return_type":"i64","parameter_definitions":[{"parameter_name":"size","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"allocate-system-memory-chunk-region","invocation_arguments":[{"kind":"var","value":"size"}],"result_assignment_variable":"base","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"top","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"top","lhs":{"value":"base"},"rhs":{"value":"size"}},{"instruction_type":"return_statement","return_payload":{"value":"top"}}]}}}