ing-restart-backoff-timer","invocation_arguments":[{"kind":"var","value":"ctx"}],"result_assignment_variable":"dh","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"tmrev"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"restart-managed-daemon-after-backoff-timer-fires","invocation_arguments":[{"kind":"var","value":"ctx"}],"result_assignment_variable":"rh","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"dispatch-supervisor-events-until-process-terminated","invocation_arguments":[{"kind":"var","value":"ctx"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}