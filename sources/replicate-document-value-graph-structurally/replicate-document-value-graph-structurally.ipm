{"build_type":"library","description":"Structural (not byte-deep) copy of a document value graph: allocates a fresh node, copies the type and number, ALIASES the string pointers (key in field key, value in text -- both arena-resident and never freed, so aliasing is safe for copy-then-discard-source), then recursively replicates the child chain via duplicate_sibling_chain_under_parent. Returns 0 for a null input. Use to re-parent a subtree into a fresh tree without corrupting the source links.","module_name":"replicate-document-value-graph-structurally","package_name":"replicate-document-value-graph-structurally","function_definitions":{"replicate-document-value-graph-structurally":{"return_type":"i64","parameter_definitions":[{"parameter_name":"node","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"node_size","variable_type":"i64","assignment_operation":"literal","source_target":64},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"node"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"allocate-json-document-element-record","invocation_arguments":[{"kind":"var","value":"node_size"}],"result_assignment_variable":"new","result_type":"i64"},{"instruction_type":"field_read","struct":"json-tree-node","field":"kind","base":"node","dest":"t"},{"instruction_type":"field_write","struct":"json-tree-node","field":"kind","base":"new","value":"t"},{"instruction_type":"field_read","struct":"json-tree-node","field":"key","base":"node","dest":"s"},{"instruction_type":"field_write","struct":"json-tree-node","field":"key","base":"new","value":"s"},{"instruction_type":"field_read","struct":"json-tree-node","field":"text","base":"node","dest":"vs"},{"instruction_type":"field_write","struct":"json-tree-node","field":"text","base":"new","value":"vs"},{"instruction_type":"field_read","struct":"json-tree-node","field":"number","base":"node","dest":"vi"},{"instruction_type":"field_write","struct":"json-tree-node","field":"number","base":"new","value":"vi"},{"instruction_type":"field_write","struct":"json-tree-node","field":"child","base":"new","value":"zero"},{"instruction_type":"field_write","struct":"json-tree-node","field":"next","base":"new","value":"zero"},{"instruction_type":"field_write","struct":"json-tree-node","field":"prev","base":"new","value":"zero"},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"node","dest":"c"},{"instruction_type":"function_invocation","invocation_name":"duplicate-sibling-chain-under-parent","invocation_arguments":[{"kind":"var","value":"c"},{"kind":"var","value":"new"}]},{"instruction_type":"return_statement","return_payload":{"value":"new"}}]}}}