{"build_type":"library","description":"Flat capability-checked verb dispatcher. The caller has already confirmed the verb is inside the channel capability mask and placed the deny sentinel in result slot 260. This routes the verb identifier to its per-verb relocation handler through a flat sequence of independent equality guards, each body a single call, so the dispatch stays shallow and avoids the deeply nested form that stalls the compiler. Verb ids - one readlink, two openat, three read, four write, five close, six getdents, seven newfstatat, eight rename, nine unlink, ten mkdir, eleven lseek, twelve symlink.","module_name":"dispatch-permitted-offset-request-toward-handler","package_name":"dispatch-permitted-offset-request-toward-handler","function_definitions":{"dispatch-permitted-offset-request-toward-handler":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"},{"parameter_name":"verb","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"v1","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"v2","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"v3","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"v4","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"v5","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"v6","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"variable_decl