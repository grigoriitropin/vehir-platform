{"build_type":"library","description":"Append one newline-terminated line to a journal source file (the Vehir journald primitive). The path is the journal directory joined with the source name via construct-content-addressed-storage-location (no path literal). Opens write-append-create (flags 1089) so entries accumulate per source across processes, writes the line then a newline, and closes. Used by the journal record tool and, later, by the single sanctioned tool-exit so every tool result is journaled per source.","module_name":"append-line-toward-journal-source-file","package_name":"append-line-toward-journal-source-file","function_definitions":{"append-line-toward-journal-source-file":{"return_type":"i64","parameter_definitions":[{"parameter_name":"dir","parameter_type":"i64"},{"parameter_name":"source","parameter_type":"i64"},{"parameter_name":"line","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"flags","variable_type":"i64","assignment_operation":"literal","source_target":1089},{"instruction_type":"variable_declaration","variable_name":"mode","variable_type":"i64","assignment_operation":"literal","source_target":493},{"instruction_type":"variable_declaration","variable_name":"nl","variable_type":"str","assignment_operation":"string","source_target":"\n"},{"instruction_type":"function_invocation","invocation_name":"construct-content-addressed-storage-location","invocation_arguments":[{"kind":"var","value":"dir"},{"kind":"var","value":"source"}],"result_assignment_variable":"path","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"line"}],"result_assignment_variable":"llen","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"acquire-legacy-descriptor-opening-pathname-flags","invocation_arguments":[{"kind":"var","value":"path"},{"kind":"var","value":"flags"},{"kind":"var","value":"mode"}],"result_assignment_variable":"fd","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"transfer-character-sequence-towards-document","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"line"},{"kind":"var","value":"llen"}],"result_assignment_variable":"w","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"transfer-character-sequence-towards-document","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"nl"},{"kind":"var","value":"one"}],"result_assignment_variable":"nw","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"release-allocated-system-descriptor-resource","invocation_arguments":[{"kind":"var","value":"fd"}],"result_assignment_variable":"c","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}