{"build_type":"library","description":"Serialize one native object (a symbol, its rendered code byte buffer, and its kept external relocations) into the JSON object text {\"symbol\":name,\"code\":[bytes],\"relocs\":[{site,target}]} the native loader consumes. Shared by function-object and data-object emission. The text is built directly from fixed JSON fragment literals (none start with '/', so they do not trip the hardcoded-path check) plus the code-byte and relocation array serializers.","module_name":"serialize-symbol-object-inside-json-document","package_name":"serialize-symbol-object-inside-json-document","function_definitions":{"serialize-symbol-object-inside-json-document":{"return_type":"i64","parameter_definitions":[{"parameter_name":"symbol","parameter_type":"i64"},{"parameter_name":"code","parameter_type":"i64"},{"parameter_name":"out_relocs","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"frag_head","variable_type":"str","assignment_operation":"string","source_target":"{\"symbol\":\""},{"instruction_type":"variable_declaration","variable_name":"frag_code","variable_type":"str","assignment_operation":"string","source_target":"\",\"code\":["},{"instruction_type":"variable_declaration","variable_name":"frag_relocs","variable_type":"str","assignment_operation":"string","source_target":"],\"relocs\":["},{"instruction_type":"variable_declaration","variable_name":"frag_tail","variable_type":"str","assignment_operation":"string","source_target":"]}"},{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"tbuf","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","