{"build_type":"library","description":"Append a function object's machine-code bytes into a text buffer as the body of a JSON integer array (comma-separated decimals, no surrounding brackets). Reads each byte from the raw code region pointer with a byte-wide array_read, masks to 0..255, and formats it as decimal text. Tail-recurses over the byte index. Used by render_one_function_into_object to serialize the code field of a native object file.","module_name":"serialize-instruction-octets-inside-json-array","package_name":"serialize-instruction-octets-inside-json-array","function_definitions":{"serialize-instruction-octets-inside-json-array":{"return_type":"i64","parameter_definitions":[{"parameter_name":"buf","parameter_type":"i64"},{"parameter_name":"data","parameter_type":"i64"},{"parameter_name":"bi","parameter_type":"i64"},{"parameter_name":"blen","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"mask255","variable_type":"i64","assignment_operation":"literal","source_target":255},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"bi"},"rhs":{"value":"blen"},"branch_on_success":[{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"bi"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"append-single-octet-inside-expandable-buffer","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"int","value":44}]}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"data"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"report-si-fault","invocation_arguments":[{"kind":"var","value":"bi"},{"kind":"var","value":"blen"},{"kind":"var","value":"data"},{"kind":"var","value":"zero"}],"result_assignment_variable":"_sidiag","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"array_read","dest":"rawb","base":"data","index":"bi","scale":1},{"instruction_type":"variable_declaration","variable_name":"byteval","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"&","target":"byteval","lhs":{"value":"rawb"},"rhs":{"value":"mask255"}},{"instruction_type":"function_invocation","invocation_name":"format-signed-integer-towards-decimal-string","invocation_arguments":[{"kind":"var","value":"byteval"}],"result_assignment_variable":"txt","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"txt"}]},{"instruction_type":"variable_declaration","variable_name":"bi2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"bi2","lhs":{"value":"bi"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"serialize-instruction-octets-inside-json-array","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"data"},{"kind":"var","value":"bi2"},{"kind":"var","value":"blen"}],"result_assignment_variable":"rr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"rr"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}