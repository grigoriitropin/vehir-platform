{"build_type":"library","description":"Overflow-safe relocation primitive for a region-relative buffer argument. Takes the channel base pointer, a region-relative offset and a tool-supplied length. Fails closed returning zero when the length is negative, when the length exceeds the region size, when the offset is negative, or when the offset plus length would exceed the region size, using a subtraction form that cannot overflow because the length is already proven non-negative and bounded. Otherwise returns the absolute pointer base plus offset. Zero is an unambiguous deny sentinel because base plus offset is never zero for a mapped region.","module_name":"bounds-check-buffer-offset-returning-relocated-pointer","package_name":"bounds-check-buffer-offset-returning-relocated-pointer","function_definitions":{"bounds-check-buffer-offset-returning-relocated-pointer":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"},{"parameter_name":"off","parameter_type":"i64"},{"parameter_name":"len","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"c16384","variable_type":"i64","assignment_operation":"literal","source_target":16384},{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"ptr","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"limit","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"len"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":1}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"c16384"},"rhs":{"value":"len"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":1}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"off"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":1}],"branch_on_failure":[]},{"instruction_type":"alu_operation","operator":"-","target":"limit","lhs":{"value":"c16384"},"rhs":{"value":"len"}},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"limit"},"rhs":{"value":"off"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":1}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"deny"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"ptr","lhs":{"value":"base"},"rhs":{"value":"off"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"ptr"}}]}}}