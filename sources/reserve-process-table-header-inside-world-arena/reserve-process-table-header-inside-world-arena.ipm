{"build_type":"library","description":"Cold-boot only: reserve the process-table header at the world-arena base. Writes the table magic into slot 0 and advances the arena bump cursor past a fixed header region so later allocations never clobber the table. The table base equals the arena base (envelope slot 0), so a post-swap kernel finds it without any global. Records the table base in g_process_table_base.","module_name":"reserve-process-table-header-inside-world-arena","package_name":"reserve-process-table-header-inside-world-arena","function_definitions":{"reserve-process-table-header-inside-world-arena":{"return_type":"i64","parameter_definitions":[{"parameter_name":"table_base","parameter_type":"i64"},{"parameter_name":"header_bytes","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"s0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"magic","variable_type":"i64","assignment_operation":"literal","source_target":1448888908},{"instruction_type":"array_write","base":"table_base","index":"s0","value":"magic","scale":8},{"instruction_type":"variable_declaration","variable_name":"newcur","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"newcur","lhs":{"value":"table_base"},"rhs":{"value":"header_bytes"}},{"instruction_type":"global_write","name":"arena_cursor_address","value":"newcur"},{"instruction_type":"global_write","name":"g_process_table_base","value":"table_base"},{"instruction_type":"return_statement","return_payload":{"value":"table_base"}}]}}}