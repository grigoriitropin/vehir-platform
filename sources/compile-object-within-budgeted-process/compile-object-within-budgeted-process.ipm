{"build_type":"library","description":"Compile one job object either directly or inside a kernel-budgeted child process. When the budget pool base global is zero the call goes straight to the compiler, identical to an in-process compile. When the base is non-zero the compile is meant to run inside a forked child drawing its transient memory from the kernel-owned pool, so the per-compile footprint is bounded and reclaimed on child exit. This wrapper is the single seam through which reconcile sends compilation work, so toggling the pool changes nothing for callers.","module_name":"compile-object-within-budgeted-process","package_name":"compile-object-within-budgeted-process","function_definitions":{"compile-object-within-budgeted-process":{"return_type":"i64","parameter_definitions":[{"parameter_name":"job","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"function_invocation","invocation_name":"compile_job_object_to_elf","invocation_arguments":[{"kind":"var","value":"job"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}},"module_globals":[{"global_name":"g_kernel_budget_pool_base","global_type":"i64","global_init":"0"},{"global_name":"g_kernel_budget_pool_size","global_type":"i64","global_init":"0"}]}