{"build_type":"library","description":"Block SIGTERM and create a signalfd for it, returning the descriptor. This is the soft external power button: SIGTERM is converted from an async kill into a pollable event so the kernel can shut down on its own terms. Mirrors the proven SIGCHLD signalfd idiom.","module_name":"block-shutdown-signal-creating-descriptor","package_name":"block-shutdown-signal-creating-descriptor","function_definitions":{"block-shutdown-signal-creating-descriptor":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"negone","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"sigtermmask","variable_type":"i64","assignment_operation":"literal","source_target":16384},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"eight"}],"result_assignment_variable":"mask","result_type":"i64"},{"instruction_type":"array_write","base":"mask","index":"zero","value":"sigtermmask","scale":8},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"adjust-blocked-signal-delivery-process-membership","invocation_arguments":[{"kind":"var","value":"zero"},{"kind":"var","value":"mask"},{"kind":"var","value":"zero"},{"kind":"var","value":"eight"}],"result_assignment_variable":"sp","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"create-signal-delivery-notification-