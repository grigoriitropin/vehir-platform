{"build_type":"library","description":"Render one lowered function (from the low-IR module) into a self-contained native object as JSON text: {\"symbol\":name,\"code\":[bytes],\"relocs\":[{site,target}]}. Gives the function a FRESH code buffer, label map (g_render_labelmap) and fixup list (g_render_fixups) so emitted offsets are function-local (0-based); after rendering, resolve_local_fixups_keep_external patches intra-function references in place and collects cross-object references into g_obj_out_relocs to be emitted as relocations the loader resolves by name. The code bytes and kept relocations are then serialized into a text buffer whose data pointer is returned.","module_name":"render-single-function-inside-object","package_name":"render-single-function-inside-object","module_globals":[{"global_name":"g_obj_out_relocs","global_type":"i64","global_init":"0"}],"function_definitions":{"render-single-function-inside-object":{"return_type":"i64","parameter_definitions":[{"parameter_name":"func","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"k_name","variable_type":"str","assignment_operation":"string","source_target":"name"},{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"code","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"labelmap","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"fixups","result_type":"i64"},{"instruction_type":"global_write","name":"g_render_labelmap","value":"labelmap"},{"instruction_type":"global_write","name":"g_render_fixups","value":"fixups"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"out_relocs","result_type":"i64"},{"instruction_type":"global_write","name":"g_obj_out_relocs","value":"out_relocs"},{"instruction_type":"function_invocation","invocation_name":"render-function-definition-inside-native-instructions","invocation_arguments":[{"kind":"var","value":"func"},{"kind":"var","value":"code"}]},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"fixups"}],"result_assignment_variable":"nfix","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"resolve-local-fixups-retaining-external-targets","invocation_arguments":[{"kind":"var","value":"fixups"},{"kind":"var","value":"zero"},{"kind":"var","value":"nfix"},{"kind":"var","value":"code"}],"result_assignment_variable":"_rs","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"extract-instruction-field-string-value","invocation_arguments":[{"kind":"var","value":"func"},{"kind":"var","value":"k_name"}],"result_assignment_variable":"symbol","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"serialize-symbol-object-inside-json-document","invocation_arguments":[{"kind":"var","value":"symbol"},{"kind":"var","value":"code"},{"kind":"var","value":"out_relocs"}],"result_assignment_variable":"outdata","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"outdata"}}]}}}