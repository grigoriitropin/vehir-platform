{"build_type":"library","description":"Set the disposition of the broken-pipe signal to ignore for the calling process, so writing to a socket whose peer has already closed returns an error instead of terminating the process. Builds a signal-action record with the ignore handler and no flags and installs it for signal 13 via rt_sigaction with the 8-byte signal-set size. Used by network servers as belt-and-suspenders alongside the connection-manager fork isolation.","module_name":"ignore-broken-channel-signal-disposition","package_name":"ignore-broken-channel-signal-disposition","function_definitions":{"ignore-broken-channel-signal-disposition":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"igndisp","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"sigpipe","variable_type":"i64","assignment_operation":"literal","source_target":13},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"thirtytwo","variable_type":"i64","assignment_operation":"literal","source_target":32},{"instruction_type":"variable_declaration","variable_name":"s0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s1","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"s2","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"s3","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instru