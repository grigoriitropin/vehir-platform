{"build_type":"library","description":"List one directory's entries as a json-tree-node sequence of {name,type} mapping values (type = getdents64 d_type: 4=dir 8=file 10=symlink 2=char 6=block 1=fifo 12=sock 0=unknown). Opens the dir read-only, then drains it COMPLETELY via read_directory_into_array_via_getdents (getdents looped until 0 — no truncation on large dirs). The 1 MiB scratch buffer is allocated ONCE into the module global g_dirent_buffer and REUSED for every directory in a recursive walk, so total memory is one buffer regardless of how many directories are visited (the bump arena never frees, so a per-call allocation would grow without bound — ~1 MiB per directory). Entry names are copied out (encode_textual_payload_document_value) during parsing, so reusing the buffer for the next directory never corrupts an already-built list. A non-directory / missing / permission-denied path yields an empty array, never a crash. Reuses open_file_for_reading, allocate_bytes_from_mmap_arena, begin_empty_sequence_document_value, read_directory_into_array_via_getdents, close_open_file.","module_name":"retrieve-directory-entries-including-structural-classification","package_name":"retrieve-directory-entries-including-structural-classification","module_globals":[{"global_name":"g_dirent_buffer","global_type":"i64","global_init":"0"}],"function_definitions":{"retrieve-directory-entries-including-structural-classification":{"return_type":"i64","parameter_definitions":[{"parameter_name":"dir_path","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"bufsize","variable_type":"i64","assignment_operation":"literal","source_target":1048576},{"instruction_type":"function_invocation","invocation_name":"acquire-filepath-towards-reading-operations","invocation_arguments":[{"kind":"var","value":"dir_path"}],"result_assignment_variable":"fd","result_type":"i64"},{"instruction_type":"global_read","dest":"buf","name":"g_dirent_buffer"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"buf"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"bufsize"}],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"global_write","name":"g_dirent_buffer","value":"buf"}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"arr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"retrieve-directory-inside-array-through-getdents","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"buf"},{"kind":"var","value":"bufsize"},{"kind":"var","value":"arr"}],"result_assignment_variable":"rd","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"release-allocated-system-descriptor-resource","invocation_arguments":[{"kind":"var","value":"fd"}],"result_assignment_variable":"cl","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"s_empty","variable_type":"str","assignment_operation":"string","source_target":""},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"arr","dest":"head"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"sorted","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"build-sorted-entry-copies-sequence","invocation_arguments":[{"kind":"var","value":"head"},{"kind":"var","value":"sorted"},{"kind":"var","value":"s_empty"}],"result_assignment_variable":"bs","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"sorted"}}]}}}