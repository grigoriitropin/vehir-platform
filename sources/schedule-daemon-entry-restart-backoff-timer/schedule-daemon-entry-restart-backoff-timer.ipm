{"build_type":"library","description":"After a managed service died, increment its failure counter (entry slot 3) and arm its restart backoff timer (entry slot 2, a timerfd). Linear backoff: delay seconds equals the new failure count; if failures exceed nine the service is parked 240 seconds and the failure counter resets (crash-limit). No sleep: the delay is a timerfd event.","module_name":"schedule-daemon-entry-restart-backoff-timer","package_name":"schedule-daemon-entry-restart-backoff-timer","function_definitions":{"schedule-daemon-entry-restart-backoff-timer":{"return_type":"i64","parameter_definitions":[{"parameter_name":"entry","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"nine","variable_type":"i64","assignment_operation":"literal","source_target":9},{"instruction_type":"variable_declaration","variable_name":"c32","variable_type":"i64","assignment_operation":"literal","source_target":32},{"instruction_type":"variable_declaration","variable_name":"parksec","variable_type":"i64","assignment_operation":"literal","source_target":240},{"instruction_type":"array_read","dest":"failures","base":"entry","index":"three","scale":8},{"instruction_type":"array_read","dest":"tfd","base":"entry","index":"two","scale":8},{"instruction_type":"variable_declaration","variable_name":"nf","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"nf","lhs":{"value":"failures"},"rhs":{"value":"one"}},{"instruction_type":"variable_declaration","variable_name":"delay","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"delay","lhs":{"value":"nf"},"rhs":{"value":"zero"}},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"nf"},"rhs":{"value":"nine"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"delay","lhs":{"value":"parksec"},"rhs":{"value":"zero"}},{"instruction_type":"alu_operation","operator":"+","target":"nf","lhs":{"value":"zero"},"rhs":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"array_write","base":"entry","index":"three","value":"nf","scale":8},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c32"}],"result_assignment_variable":"its","result_type":"i64"},{"instruction_type":"array_write","base":"its","index":"two","value":"delay","scale":8},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"286","arg1":"tfd","arg2":"zero","arg3":"its","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"st"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}