{"build_type":"library","description":"Recursively commit the etc config tree into a generation, mirroring the source-as-symlink-tree into the SAME shared source-objects pool. Makes dst_dir, lists src_dir with type classification, packs {src_dir,dst_dir,objdir} into a ctx and walks the entries: subdirectories recurse here, files are content-addressed + symlinked. Mutually recursive with commit-etc-entries-iteration-toward-generation. Called by the reconcile analysis child right after the source commit. INTERIM mechanism (operator 2026-06-25): not the final etc model.","module_name":"commit-etc-branch-within-generation-mirror","package_name":"commit-etc-branch-within-generation-mirror","function_definitions":{"commit-etc-branch-within-generation-mirror":{"return_type":"i64","parameter_definitions":[{"parameter_name":"src_dir","parameter_type":"i64"},{"parameter_name":"dst_dir","parameter_type":"i64"},{"parameter_name":"objdir","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"mode","variable_type":"i64","assignment_operation":"literal","source_target":493},{"instruction_type":"variable_declaration","variable_name":"c24","variable_type":"i64","assignment_operation":"literal","source_target":24},{"instruction_type":"function_invocation","invocation_name":"create-directory-bearing-pathname-permission","invocation_arguments":[{"kind":"var","value":"dst_dir"},{"kind":"var","value":"mode"}],"result_assignment_variable":"mk","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name"