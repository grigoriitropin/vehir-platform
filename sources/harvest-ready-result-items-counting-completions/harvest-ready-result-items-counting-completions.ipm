{"build_type":"library","description":"As-completed harvest: advances consumed and completed for every newly-published result, stopping when consumed reaches the doorbell permit count (state[0][0], the count of writes already committed). Counting by permit rather than a zero slot sentinel makes it wrap-safe for a ringed result array and independent of completion order. Recurses until consumed==published.","module_name":"harvest-ready-result-items-counting-completions","package_name":"harvest-ready-result-items-counting-completions","function_definitions":{"harvest-ready-result-items-counting-completions":{"return_type":"i64","parameter_definitions":[{"parameter_name":"state","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"ten","variable_type":"i64","assignment_operation":"literal","source_target":10},{"instruction_type":"array_read","dest":"consumed","base":"state","index":"eight","scale":8},{"instruction_type":"array_read","dest":"db","base":"state","index":"zero","scale":8},{"instruction_type":"array_read","dest":"published","base":"db","index":"zero","scale":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"consumed"},"rhs":{"value":"published"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"c1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operat