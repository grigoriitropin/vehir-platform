{"build_type":"library","description":"Smart bootloader: reads a boot config naming the oneshot, counter, current, fallback, store and entry paths plus arena bytes cores threads, resolves which generation to boot by the failure counter (counter below one rolls to the fallback generation, otherwise decrements and persists the counter), honours a pending oneshot override, falls back if the chosen generation entry object is missing, builds the chosen generation objlib directory, reserves the arena, and invokes the kernel entry from that generation handing it the env and the config path. The counter is reset to healthy by the mark-good step only after the boot passes its self check, so a generation that keeps failing self check is rolled back to the previous generation.","module_name":"resolve-rollback-generation-launching-kernel-entry","package_name":"resolve-rollback-generation-launching-kernel-entry","function_definitions":{"resolve-rollback-generation-launching-kernel-entry":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"sixtyfour","variable_type":"i64","assignment_operation":"literal","source_target":64},{"instruction_type":"variable_declaration","variable_name":"envsize","variable_type":"i64","assignment_operation":"literal","source_target":32},{"instruction_type":"variable_declaration","variable_name":"i0","variable_type":"i64","assignment_operation":"literal","sourc