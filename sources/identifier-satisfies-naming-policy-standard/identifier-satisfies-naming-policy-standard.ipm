{"build_type":"library","description":"Top-level naming policy check for one entity name (a hyphen-joined identifier; callers pass function names already converted to hyphen form). Returns 1 if the name has at least 5 word tokens AND every token passes the per-word rule (>=5 lowercase Latin letters, or a registered allowlisted abbreviation), else 0. allowlist is the parsed document value sequence from naming_abbreviation_allowlist_json. Reuses split_hyphenated_name_into_token_array, count_members_inside_container_value, check_all_tokens_pass_naming_policy.","module_name":"identifier-satisfies-naming-policy-standard","package_name":"identifier-satisfies-naming-policy-standard","function_definitions":{"identifier-satisfies-naming-policy-standard":{"return_type":"i64","parameter_definitions":[{"parameter_name":"name","parameter_type":"i64"},{"parameter_name":"allowlist","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"function_invocation","invocation_name":"split-hyphenated-identifier-inside-token-array","invocation_arguments":[{"kind":"var","value":"name"}],"result_assignment_variable":"tokens","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"tokens"}],"result_assignment_variable":"n","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"n"},"rhs":{"value":"five"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"verify-every-token-satisfies-naming-standards","invocation_arguments":[{"kind":"var","value":"tokens"},{"kind":"var","value":"allowlist"},{"kind":"var","value":"zero"},{"kind":"var","value":"n"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}