{"build_type":"library","description":"The generic cooperative scheduler loop, our own wait/wake with NO futex and NO eventfd. Pops a ready fiber id off the ready stack (slot 0 = top), dispatches one cooperative step by category, and tail-recurses until the ready stack is empty (quiescent). Parking is a fiber not requeuing itself; waking is completion routing pushing an awaiter back onto the ready stack.","module_name":"drive-fiber-scheduler-until-quiescent","package_name":"drive-fiber-scheduler-until-quiescent","function_definitions":{"drive-fiber-scheduler-until-quiescent":{"return_type":"i64","parameter_definitions":[{"parameter_name":"s","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"array_read","dest":"top","base":"s","index":"zero","scale":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"top"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"array_read","dest":"t","base":"s","index":"top","scale":8},{"instruction_type":"variable_declaration","variable_name":"ntop","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"-","target":"ntop","lhs":{"value":"top"},"rhs":{"value":"one"}},{"instruction_type":"array_write","base":"s","index":"zero","value":"ntop","scale":8},{"instruction_type":"function_invocation","invocation_name":"dispatch-ready-fiber-matching-declared-category","invocation_arguments":[{"kind":"var","value":"s"},{"kind":"var","value":"t"}],"result_assignment_variable":"_d","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"drive-fiber-scheduler-until-quiescent","invocation_arguments":[{"kind":"var","value":"s"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}