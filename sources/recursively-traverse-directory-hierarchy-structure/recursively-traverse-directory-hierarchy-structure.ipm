{"build_type":"library","description":"Recursive directory-tree walker (DFS). For a directory path at a given depth, list its entries (with type) and hand the child list to emit_tree_rows_for_entries, which emits one flat row per entry into the g_tree_out global and recurses back into this function for sub-directories. Mutual recursion with emit_tree_rows_for_entries; descent is O(tree-depth) on the call stack (siblings are tail-iterated, not stacked). Reuses list_directory_entries_with_type, emit_tree_rows_for_entries.","module_name":"recursively-traverse-directory-hierarchy-structure","package_name":"recursively-traverse-directory-hierarchy-structure","function_definitions":{"recursively-traverse-directory-hierarchy-structure":{"return_type":"i64","parameter_definitions":[{"parameter_name":"dir_path","parameter_type":"i64"},{"parameter_name":"depth","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"global_read","dest":"tr","name":"g_tree_truncated"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"tr"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"retrieve-directory-entries-including-structural-classification","invocation_arguments":[{"kind":"var","value":"dir_path"}],"result_assignment_variable":"entries","result_type":"i64"},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"entries","dest":"first"},{"instruction_type":"function_invocation","invocation_name":"generate-flattened-directory-records-representing-entries","invocation_arguments":[{"kind":"var","value":"first"},{"kind":"var","value":"dir_path"},{"kind":"var","value":"depth"}],"result_assignment_variable":"er","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}