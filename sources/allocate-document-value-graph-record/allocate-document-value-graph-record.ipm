{"build_type":"library","module_name":"allocate-document-value-graph-record","package_name":"allocate-document-value-graph-record","description":"CC0 / agent-authored, original from RFC 8259 (original work, not derived from another implementation). Defines the json-tree-node DOM struct and allocates a zeroed node carrying a kind tag. kind tags: 1=mapping 2=sequence 3=text 4=number 5=boolean 6=absent. Fields: kind=type tag; key=member key pointer for a mapping child (else 0, the honest name for what other implementations misleadingly called the string field); text=string payload pointer; number=integer or boolean(0 or 1) payload; child=first child; next=next sibling; prev=previous sibling. 56 bytes = 7 i64. Arena memory is mmap-zeroed so all unset fields are 0.","struct_definitions":[{"struct_name":"json-tree-node","field_definitions":[{"field_name":"kind","field_type":"i64"},{"field_name":"key","field_type":"i64"},{"field_name":"text","field_type":"i64"},{"field_name":"number","field_type":"i64"},{"field_name":"parent","field_type":"i64"},{"field_name":"child","field_type":"i64"},{"field_name":"next","field_type":"i64"},{"field_name":"prev","field_type":"i64"}]}],"function_definitions":{"allocate-document-value-graph-record":{"return_type":"i64","parameter_definitions":[{"parameter_name":"kind","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"node_size","variable_type":"i64","assignment_operation":"literal","source_target":64},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"node_size"}],"result_assignment_variable":"node","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"clear-allocated-buffer-memory-region","invocation_arguments":[{"kind":"var","value":"node"},{"kind":"var","value":"zero"},{"kind":"var","value":"node_size"}],"result_assignment_variable":"_zfill","result_type":"i64"},{"instruction_type":"field_write","struct":"json-tree-node","field":"kind","base":"node","value":"kind"},{"instruction_type":"return_statement","return_payload":{"value":"node"}}]}}}