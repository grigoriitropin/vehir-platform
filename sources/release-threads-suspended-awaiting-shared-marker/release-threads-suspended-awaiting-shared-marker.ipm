{"build_type":"library","description":"Layer-1 wait/wake primitive (wake-object-eventfd-replacement-DESIGN). Wakes up to `count` threads blocked on the 4-byte shared marker word at address `word` via FUTEX_WAKE (op 1) through the single host-port futex primitive. Pairs with suspend-calling-thread-awaiting-shared-marker. The marker word's value is owned by the CALLER (the layer-2 doorbell): the caller MUST change the marker before calling this, so a waiter that has not yet parked sees the change and never sleeps (lost-wakeup discipline). This primitive only issues the wake; it does not touch the marker value.","module_name":"release-threads-suspended-awaiting-shared-marker","package_name":"release-threads-suspended-awaiting-shared-marker","function_definitions":{"release-threads-suspended-awaiting-shared-marker":{"return_type":"i64","parameter_definitions":[{"parameter_name":"word","parameter_type":"i64"},{"parameter_name":"count","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"op_wake","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"function_invocation","invocation_name":"operate-futex-value-across-userspace-address","invocation_arguments":[{"kind":"var","value":"word"},{"kind":"var","value":"op_wake"},{"kind":"var","value":"count"}],"result_assignment_variable":"fw","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}