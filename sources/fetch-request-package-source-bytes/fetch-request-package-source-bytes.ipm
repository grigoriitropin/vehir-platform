{"build_type":"library","description":"Runtime-layer reader helper: given a tool's request argument object, return the package SOURCE BYTES the request points at by PATH. Reads the arg's \"path\" field and reads that file via the fail-hard read_entire_file_into_string. Returns 0 when there is NO path field OR the file is empty/missing/unreadable (the caller emits a clean error on a 0 return — this is what lets even non-parsing callers like diff reject a directory). Otherwise returns the raw file bytes (not a parsed object) so the caller can both decode_entire_source_building_document them AND keep them for the content hash. The one place reader tools funnel package-by-path reads through, so a bad path is safe and the logic lives once. Reuses locate_named_member_inside_mapping, read_entire_file_into_string.","module_name":"fetch-request-package-source-bytes","package_name":"fetch-request-package-source-bytes","function_definitions":{"fetch-request-package-source-bytes":{"return_type":"i64","parameter_definitions":[{"parameter_name":"arg","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_path","variable_type":"str","assignment_operation":"string","source_target":"path"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"arg"},{"kind":"var","value":"s_path"}],"result_assignment_variable":"pathn","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"pathn"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"field_read","struct":"json-tree-node","field":"text","base":"pathn","dest":"path"},{"instruction_type":"function_invocation","invocation_name":"retrieve-entire-document-inside-string","invocation_arguments":[{"kind":"var","value":"path"}],"result_assignment_variable":"raw","result_type":"i64"},{"instruction_type":"array_read","dest":"firstbyte","base":"raw","index":"zero","scale":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"firstbyte"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"raw"}}]}}}