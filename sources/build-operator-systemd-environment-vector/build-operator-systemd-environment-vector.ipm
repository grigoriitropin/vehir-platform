{"build_type":"library","description":"Build a minimal environment vector for invoking the stock systemd user CLIs. Given the user runtime directory (passed in by the caller, never a hardcoded path), it produces a NULL-terminated environ array containing a single XDG_RUNTIME_DIR assignment, written into the caller-provided two-slot array. Modern systemctl --user and journalctl --user derive the user bus address from XDG_RUNTIME_DIR, so no separate bus address is needed.","module_name":"build-operator-systemd-environment-vector","package_name":"build-operator-systemd-environment-vector","function_definitions":{"build-operator-systemd-environment-vector":{"return_type":"i64","parameter_definitions":[{"parameter_name":"xdg_runtime_dir","parameter_type":"i64"},{"parameter_name":"out_argv2","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"p_xdg","variable_type":"str","assignment_operation":"string","source_target":"XDG_RUNTIME_DIR="},{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"xb","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"xb"},{"kind":"var","value":"p_xdg"}]},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"xb"},{"kind":"var","value":"xdg_runtime_dir"}]},{"instruction_type":"field_read","struct":"string_buffer","field":"data","base":"xb","dest":"xdg"},{"instruction_type":"array_write","base":"out_argv2","index":"zero","value":"xdg","scale":8},{"instruction_type":"array_write","base":"out_argv2","index":"one","value":"zero","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}