{"build_type":"library","description":"At supervisor boot, restore previously enabled services from the persistence file so they survive a vsm restart. Reads the services file whose path is given, parses it as a JSON array of service elements each holding path and request, and constructs and launches every one onto the supervision table starting at the base index that follows the seed services. Returns the new total service count. A missing, empty, or unparseable file leaves the count unchanged.","module_name":"restore-persisted-services-extending-supervision-table","package_name":"restore-persisted-services-extending-supervision-table","function_definitions":{"restore-persisted-services-extending-supervision-table":{"return_type":"i64","parameter_definitions":[{"parameter_name":"services_file","parameter_type":"i64"},{"parameter_name":"table","parameter_type":"i64"},{"parameter_name":"base_count","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"retrieve-entire-document-inside-string","invocation_arguments":[{"kind":"var","value":"services_file"}],"result_assignment_variable":"content","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"decode-entire-source-building-document","invocation_arguments":[{"kind":"var","value":"content"}],"result_assignment_variable":"arr","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"arr"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"base_count"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"arr"}],"result_assignment_variable":"fsize","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"fsize"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"base_count"}}],"branch_on_failure":[]},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"arr","dest":"firstelem"},{"instruction_type":"variable_declaration","variable_name":"total","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"total","lhs":{"value":"base_count"},"rhs":{"value":"fsize"}},{"instruction_type":"function_invocation","invocation_name":"construct-daemon-table-launching-every-declared-daemon","invocation_arguments":[{"kind":"var","value":"firstelem"},{"kind":"var","value":"table"},{"kind":"var","value":"base_count"},{"kind":"var","value":"total"}],"result_assignment_variable":"ct","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"total"}}]}}}