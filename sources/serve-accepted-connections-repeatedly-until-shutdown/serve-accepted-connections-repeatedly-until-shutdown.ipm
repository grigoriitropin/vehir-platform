{"build_type":"library","description":"Accept loop of the bus daemon: accept one connection, read its request to end of stream, fork to serve it (child redirects output onto the connection and execve the shell, parent reaps and closes), then tail-recurse to accept the next connection. Runs until the process is terminated by its supervisor. The scratch buffer is allocated once by the caller and reused every iteration.","module_name":"serve-accepted-connections-repeatedly-until-shutdown","package_name":"serve-accepted-connections-repeatedly-until-shutdown","function_definitions":{"serve-accepted-connections-repeatedly-until-shutdown":{"return_type":"i64","parameter_definitions":[{"parameter_name":"listen_fd","parameter_type":"i64"},{"parameter_name":"shell_path","parameter_type":"i64"},{"parameter_name":"scratch","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"capbig","variable_type":"i64","assignment_operation":"literal","source_target":1048576},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"43","arg1":"listen_fd","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"conn"},{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"reqbuf","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"accumulate-socket-bytes-until-stream-closes","invocation_arguments":[{"kind":"var","value":"conn"},{"kind":"var","value":"reqbuf"},{"kind":"var","value":"scratch"},{"kind":"var","value":"capbig"}],"result_assignment_variable":"acc","result_type":"i64"},{"instruction_type":"f