{"build_type":"library","description":"Single declarative source of truth for the whole-program build enforcers and the severity mode of each. Returns a parsed array of objects, each with an enforcer key naming a universe-level check and a mode of active or warning. Active means fail-closed: any violation blocks the build and refuses to flip the current generation. Warning means the build is permitted to proceed but the orchestrator emits a severe criticality message listing every tolerated violator. Adding an enforcer is one row here plus its detector and one router call; switching an enforcer between active and warning is editing a single word in this literal.","module_name":"declare-enforcement-policy-modes-registry","package_name":"declare-enforcement-policy-modes-registry","function_definitions":{"declare-enforcement-policy-modes-registry":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"s_json","variable_type":"str","assignment_operation":"string","source_target":"[{\"enforcer\": \"unguarded_dereferences\", \"mode\": \"active\"}, {\"enforcer\": \"arity_mismatches\", \"mode\": \"active\"}, {\"enforcer\": \"duplicate_function_groups\", \"mode\": \"active\"}, {\"enforcer\": \"dangling_call_references\", \"mode\": \"active\"}, {\"enforcer\": \"tool_output_contract\", \"mode\": \"warning\"}, {\"enforcer\": \"tool_parameter_guard\", \"mode\": \"warning\"}, {\"enforcer\": \"naming_policy\", \"mode\": \"warning\"}, {\"enforcer\": \"syscall_monopoly\", \"mode\": \"warning\"}, {\"enforcer\": \"memory_footprint_budget\", \"mode\": \"warning\"}, {\"enforcer\": \"linux_process_forking\", \"mode\": \"warning\"}, {\"enforcer\": \"reconcile_input_global_isolation\", \"mode\": \"active\"}, {\"enforcer\": \"dead_package_reachability\", \"mode\": \"warning\"}, {\"enforcer\": \"reachability_deglob_diff\", \"mode\": \"warning\"}]"},{"instruction_type":"function_invocation","invocation_name":"decode-entire-source-building-document","invocation_arguments":[{"kind":"var","value":"s_json"}],"result_assignment_variable":"doc","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"doc"}}]}}}