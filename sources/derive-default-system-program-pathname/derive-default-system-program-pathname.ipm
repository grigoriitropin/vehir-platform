{"build_type":"library","description":"Return the conventional /usr/bin/<name> absolute path for a stock host tool, given its bare name. The leading slash is written as a byte (47) and the rest as the non-slash-leading literal usr/bin/ so no source string literal starts with a slash (the hardcoded-path source-compliance check flags only first-byte-slash literals). Used by the systemd compatibility layer to default the systemctl and journalctl paths so callers need not pass them. Returns a cstring pointer.","module_name":"derive-default-system-program-pathname","package_name":"derive-default-system-program-pathname","function_definitions":{"derive-default-system-program-pathname":{"return_type":"i64","parameter_definitions":[{"parameter_name":"tool_name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"slash","variable_type":"i64","assignment_operation":"literal","source_target":47},{"instruction_type":"variable_declaration","variable_name":"p_usrbin","variable_type":"str","assignment_operation":"string","source_target":"usr/bin/"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"two"}],"result_assignment_variable":"slashbuf","result_type":"i64"},{"instruction_type":"array_write","base":"slashbuf","index":"zero","value":"slash","scale":1},{"instruction_type":"array_write","base":"slashbuf","index":"one","value":"zero","scale":1},{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"sb","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"sb"},{"kind":"var","value":"slashbuf"}]},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"sb"},{"kind":"var","value":"p_usrbin"}]},{"instruction_type":"function_invocation","invocation_name":"append-cstring-inside-string-buffer","invocation_arguments":[{"kind":"var","value":"sb"},{"kind":"var","value":"tool_name"}]},{"instruction_type":"field_read","struct":"string_buffer","field":"data","base":"sb","dest":"path"},{"instruction_type":"return_statement","return_payload":{"value":"path"}}]}}}