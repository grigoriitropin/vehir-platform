{"build_type":"library","description":"Per-verb relocation handler for the close verb. Reads the file descriptor from request slot 257 once into a local and performs the close module realization which writes the return value into result slot 260. The close verb carries no region-relative pointer so no bounds check is required beyond the channel capability mask already enforced by the caller.","module_name":"relocate-offset-arguments-performing-closing-handler","package_name":"relocate-offset-arguments-performing-closing-handler","function_definitions":{"relocate-offset-arguments-performing-closing-handler":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"i257","variable_type":"i64","assignment_operation":"literal","source_target":257},{"instruction_type":"array_read","dest":"fd","base":"base","index":"i257","scale":8},{"instruction_type":"function_invocation","invocation_name":"perform-close-syscall-writing-shared-region-result","invocation_arguments":[{"kind":"var","value":"base"},{"kind":"var","value":"fd"}],"result_assignment_variable":"pr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}