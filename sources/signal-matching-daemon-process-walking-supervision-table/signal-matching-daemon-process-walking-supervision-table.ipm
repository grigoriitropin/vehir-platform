{"build_type":"library","description":"Walk the supervision table looking for the service whose request names the given identifier (the request object has that name as its only key). On a match, send SIGTERM to that service process; when the disable flag is set, also null the entry path slot so the supervisor will not respawn it (a stop rather than a restart). Returns one if a service was found and signalled, zero otherwise. Tail-recursive over the table index.","module_name":"signal-matching-daemon-process-walking-supervision-table","package_name":"signal-matching-daemon-process-walking-supervision-table","function_definitions":{"signal-matching-daemon-process-walking-supervision-table":{"return_type":"i64","parameter_definitions":[{"parameter_name":"table","parameter_type":"i64"},{"parameter_name":"index","parameter_type":"i64"},{"parameter_name":"count","parameter_type":"i64"},{"parameter_name":"name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"sigterm","variable_type":"i64","assignment_operation":"literal","source_target":15},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"index"},"rhs":{"value":"count"},"branch_on_success":[{"instruction_type":"array_read","dest":"entry","base":"table","index":"index","scale":8},{"instruction_type":"array_read","dest":"reqstr","base":"entry","index":"one","scale":8},{"instruction_type":"function_invocation","invocation_name":"decode-entire-source-building-document","invocation_arguments":[{"ki