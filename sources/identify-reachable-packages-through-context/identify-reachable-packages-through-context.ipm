e","invocation_arguments":[],"result_assignment_variable":"worklist","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c32"}],"result_assignment_variable":"rctx","result_type":"i64"},{"instruction_type":"array_write","base":"rctx","index":"z","value":"closure","scale":8},{"instruction_type":"array_write","base":"rctx","index":"one","value":"visited","scale":8},{"instruction_type":"array_write","base":"rctx","index":"two","value":"worklist","scale":8},{"instruction_type":"array_write","base":"rctx","index":"three","value":"index","scale":8},{"instruction_type":"function_invocation","invocation_name":"locate-compilation-target-through-context","invocation_arguments":[{"kind":"var","value":"target_name"},{"kind":"var","value":"rctx"},{"kind":"var","value":"universe"}],"result_assignment_variable":"_l","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"compute-worklist-cycle-through-context","invocation_arguments":[{"kind":"var","value":"z"},{"kind":"var","value":"rctx"},{"kind":"var","value":"universe"}],"result_assignment_variable":"_c","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"convert-closure-object-towards-array","invocation_arguments":[{"kind":"var","value":"closure"}],"result_assignment_variable":"result","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"result"}}]}}}