{"build_type":"library","description":"Fill the poll descriptor array entries for the service timers: for service index, write its timerfd (entry slot 2) and POLLIN into poll slot index plus one (each pollfd is eight bytes: fd low byte at the slot base, events one at base plus four). The caller fills poll slot zero with the shared signal descriptor. Tail-recursive over the service table.","module_name":"populate-descriptor-watch-array-across-daemon-timers","package_name":"populate-descriptor-watch-array-across-daemon-timers","function_definitions":{"populate-descriptor-watch-array-across-daemon-timers":{"return_type":"i64","parameter_definitions":[{"parameter_name":"table","parameter_type":"i64"},{"parameter_name":"count","parameter_type":"i64"},{"parameter_name":"pollbuf","parameter_type":"i64"},{"parameter_name":"index","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"array_read","dest":"entry","base":"table","index":"index","scale":8},{"instruction_type":"array_read","dest":"tfd","base":"entry","index":"two","scale":8},{"instruction_type":"variable_declaration","variable_name":"pollslot","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"pollslot","lhs":{"value":"index"},"