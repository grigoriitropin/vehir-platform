{"build_type":"library","description":"Control verb handler for stop and restart over the supervisor control connection. Reads the target service name from the control message, walks the supervision table to find and SIGTERM the matching service process. When the disable flag is set (stop) it also nulls the matched entry path slot so the supervisor will not respawn it; when clear (restart) the existing crash backoff respawns it. Acknowledges on the control connection and closes it.","module_name":"terminate-named-daemon-process-honoring-disable-request","package_name":"terminate-named-daemon-process-honoring-disable-request","function_definitions":{"terminate-named-daemon-process-honoring-disable-request":{"return_type":"i64","parameter_definitions":[{"parameter_name":"ctx","parameter_type":"i64"},{"parameter_name":"conn","parameter_type":"i64"},{"parameter_name":"msg","parameter_type":"i64"},{"parameter_name":"stopflag","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"k_name","variable_type":"str","assignment_operation":"string","source_target":"name"},{"instruction_type":"variable_declaration","variable_name":"s_ok","variable_type":"str","assignment_operation":"string","source_target":"ok\n"},{"instruction_type":"array_read","dest":"count","base":"ctx","index":"one","scale":8},{"instruction_type":"array_read","dest":"table","base":"ctx","index":"two","scale":8},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var"