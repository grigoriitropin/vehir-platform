{"build_type":"library","description":"Accept loop of the Channel-B HTTP MCP edge daemon: accept one TCP connection on the listening socket, hand it to the per-connection HTTP request handler (which reads one HTTP request, dispatches the JSON-RPC body, writes the HTTP reply, and closes the connection), then tail-recurse to accept the next connection. Runs until the process is terminated. The scratch buffer is allocated once by the caller and reused for every connection.","module_name":"serve-internet-socket-connections-repeatedly","package_name":"serve-internet-socket-connections-repeatedly","function_definitions":{"serve-internet-socket-connections-repeatedly":{"return_type":"i64","parameter_definitions":[{"parameter_name":"listen_fd","parameter_type":"i64"},{"parameter_name":"scratch","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"43","arg1":"listen_fd","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"conn"},{"instruction_type":"function_invocation","invocation_name":"answer-internet-request-message-writing-reply","invocation_arguments":[{"kind":"var","value":"conn"},{"kind":"var","value":"scratch"}],"result_assignment_variable":"d","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"serve-internet-socket-connections-repeatedly","invocation_arguments":[{"kind":"var","value":"listen_fd"},{"kind":"var","value":"scratch"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}