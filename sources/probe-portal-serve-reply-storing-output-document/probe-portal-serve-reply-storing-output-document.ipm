":"resp","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"resp"}],"result_assignment_variable":"resplen","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"acquire-filepath-towards-writing-operations","invocation_arguments":[{"kind":"var","value":"out_path"}],"result_assignment_variable":"fd","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"transmit-bytes-writing-descriptor-stream","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"resp"},{"kind":"var","value":"resplen"}],"result_assignment_variable":"wr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"release-allocated-system-descriptor-resource","invocation_arguments":[{"kind":"var","value":"fd"}],"result_assignment_variable":"cl","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}