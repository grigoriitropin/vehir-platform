{"build_type":"library","description":"Parent-side event-driven join: blocks reading the completion doorbell (eventfd, semaphore mode) once per outstanding child. Tail-recursive: if remaining is zero return; else block-read 8 bytes from the doorbell (woken by a child completion signal, no spin), then recurse with remaining minus one. Replaces the bounded-spin stand-in with a real wait.","module_name":"await-children-through-blocking-doorbell-reads","package_name":"await-children-through-blocking-doorbell-reads","function_definitions":{"await-children-through-blocking-doorbell-reads":{"return_type":"i64","parameter_definitions":[{"parameter_name":"efd","parameter_type":"i64"},{"parameter_name":"readbuf","parameter_type":"i64"},{"parameter_name":"remaining","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"remaining"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"consume-bytes-reading-descriptor-stream","invocation_arguments":[{"kind":"var","value":"efd"},{"kind":"var","value":"readbuf"},{"kind":"var","value":"eight"}],"result_assignment_variable":"rr","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"nrem","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"-","target":"nrem","lhs":{"value":"remaining"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"await-children-through-blocking-doorbell-reads","invocation_arguments":[{"kind":"var","value":"efd"},{"kind":"var","value":"readbuf"},{"kind":"var","value":"nrem"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}