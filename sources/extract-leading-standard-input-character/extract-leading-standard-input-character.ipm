{"build_type":"executable","description":"Isolation test: reads all of stdin via read_all_of_stdin (which uses the mmap arena allocator and the read syscall across several linked functions) and returns the first byte. Object-emitted and run via the loader with a file on stdin starting with '{' (123), it must exit 123 — proving the stdin+arena chain works when linked by name.","module_name":"extract-leading-standard-input-character","package_name":"extract-leading-standard-input-character","function_definitions":{"extract-leading-standard-input-character":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"consume-entire-content-within-stdin","invocation_arguments":[],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"array_read","dest":"b","base":"buf","index":"zero","scale":1},{"instruction_type":"return_statement","return_payload":{"value":"b"}}]}}}