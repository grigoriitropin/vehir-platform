{"build_type":"library","description":"Write the live kernel state into the process table so it survives an in-process kernel swap (a swap remaps the code region, zeroing all globals). Saves the current arena bump cursor, arena end, core and thread counts (read from globals), the current kernel code-region base (for freeing the old region after a swap), and the supervised init pid. The init service definition pointers (path and request) are written separately by record-init-service-definition-into-process-table to stay within the four-argument ABI.","module_name":"checkpoint-kernel-state-within-process-table","package_name":"checkpoint-kernel-state-within-process-table","function_definitions":{"checkpoint-kernel-state-within-process-table":{"return_type":"i64","parameter_definitions":[{"parameter_name":"table_base","parameter_type":"i64"},{"parameter_name":"ld_region_base","parameter_type":"i64"},{"parameter_name":"init_pid","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"i1","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"i2","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"i3","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"i4","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"i5","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"i6","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"global_read","dest":"cur","name":"arena_cursor_address"},{"instruction_type":"global_read","dest":"end","name":"arena_end_address"},{"instruction_type":"global_read","dest":"cores","name":"vehir_core_count"},{"instruction_type":"global_read","dest":"threads","name":"vehir_thread_count"},{"instruction_type":"array_write","base":"table_base","index":"i1","value":"cur","scale":8},{"instruction_type":"array_write","base":"table_base","index":"i2","value":"end","scale":8},{"instruction_type":"array_write","base":"table_base","index":"i3","value":"cores","scale":8},{"instruction_type":"array_write","base":"table_base","index":"i4","value":"threads","scale":8},{"instruction_type":"array_write","base":"table_base","index":"i5","value":"ld_region_base","scale":8},{"instruction_type":"array_write","base":"table_base","index":"i6","value":"init_pid","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"table_base"}}]}}}