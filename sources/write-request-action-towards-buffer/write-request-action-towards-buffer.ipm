{"build_type":"library","description":"Zero-syscall tool-side verb call: write verb id (slot 256) + args (257,258) into the INHERITED shared region, set result (260) to sentinel, raise the memory doorbell flag (261), then spin-read the result. Pure array_write/array_read on the inherited region pointer - NO call to any module primitive, NO sys instruction. The kernel process polls slot 261, performs the verb via the module, writes slot 260. So this tool-side binary executes ZERO syscalls.","module_name":"write-request-action-towards-buffer","package_name":"write-request-action-towards-buffer","function_definitions":{"write-request-action-towards-buffer":{"return_type":"i64","parameter_definitions":[{"parameter_name":"region","parameter_type":"i64"},{"parameter_name":"verb","parameter_type":"i64"},{"parameter_name":"a0","parameter_type":"i64"},{"parameter_name":"a1","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"sentinel","variable_type":"i64","assignment_operation":"literal","source_target":-999},{"instruction_type":"variable_declaration","variable_name":"i256","variable_type":"i64","assignment_operation":"literal","source_target":256},{"instruction_type":"variable_declaration","variable_name":"i257","variable_type":"i64","assignment_operation":"literal","source_target":257},{"instruction_type":"variable_declaration","variable_name":"i258","variable_type":"i64","assignment_operation":"literal","source_target":258},{"instruction_type":"variable_declaration","variable_name":"i260","variable_type":"i64","assignment_operation":"literal","source_target":260},{"instruction_type":"variable_declaration","variable_name":"i261","variable_type":"i64","assignment_operation":"literal","source_target":261},{"instruction_type":"array_write","base":"region","index":"i256","value":"verb","scale":8},{"instruction_type":"array_write","base":"region","index":"i257","value":"a0","scale":8},{"instruction_type":"array_write","base":"region","index":"i258","value":"a1","scale":8},{"instruction_type":"array_write","base":"region","index":"i260","value":"sentinel","scale":8},{"instruction_type":"array_write","base":"region","index":"i261","value":"one","scale":8},{"instruction_type":"function_invocation","invocation_name":"repeatedly-inspect-shared-region-result-value","invocation_arguments":[{"kind":"var","value":"region"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}