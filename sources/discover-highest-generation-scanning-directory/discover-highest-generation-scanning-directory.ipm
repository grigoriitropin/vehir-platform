{"build_type":"executable","description":"Corrupt or missing boot-config recovery: scans the generations directory named in the request with one getdents64 read into a large buffer and returns the highest numbered subdirectory, so the loader can boot the latest valid generation when no boot-state is available. Single getdents call with a large buffer covers the whole directory at the current generation scale; a fully general version would loop until getdents returns zero.","module_name":"discover-highest-generation-scanning-directory","package_name":"discover-highest-generation-scanning-directory","function_definitions":{"discover-highest-generation-scanning-directory":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"big","variable_type":"i64","assignment_operation":"literal","source_target":262144},{"instruction_type":"variable_declaration","variable_name":"k_dir","variable_type":"str","assignment_operation":"string","source_target":"dir"},{"instruction_type":"variable_declaration","variable_name":"k_highest","variable_type":"str","assignment_operation":"string","source_target":"highest_generation"},{"instruction_type":"function_invocation","invocation_name":"parse-argument-vector-json-request","invocation_arguments":[{"kind":"var","value":"__argc"},{"kind":"var","value":"__argv"}],"result_assignment_variable":"req","result_type":"i64"},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"req","dest":"reqch"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"reqch"},{"kind":"var","value":"k_dir"}],"result_assignment_variabl