{"build_type":"library","description":"Concise-lens field setter: add a string-valued key to a structured mapping. Thin delegate to add_str_field (identical semantics) — kept as the concise lens's named entry point while the actual logic lives in one place (§7 DRY; the compiler rejects byte-identical bodies, so this must not re-inline add_str_field's body).","module_name":"render-concise-package-field-entry","package_name":"render-concise-package-field-entry","function_definitions":{"render-concise-package-field-entry":{"return_type":"i64","parameter_definitions":[{"parameter_name":"obj","parameter_type":"i64"},{"parameter_name":"key","parameter_type":"i64"},{"parameter_name":"val","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"obj"},{"kind":"var","value":"key"},{"kind":"var","value":"val"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}