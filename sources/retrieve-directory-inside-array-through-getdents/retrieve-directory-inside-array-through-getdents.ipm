{"build_type":"library","description":"Drain a directory fd completely: call getdents64 (syscall 217) into buf repeatedly, parsing each returned block via collect_dirent_block_with_type into arr, until getdents returns 0 (end) or negative (error). Looping is what makes the listing COMPLETE — a single getdents call only returns one buffer's worth, so a large directory would otherwise be silently truncated. The buffer is reused across iterations (and across directories by the caller), so memory is bounded regardless of entry count. Tail-recursive over batches. Reuses collect_dirent_block_with_type.","module_name":"retrieve-directory-inside-array-through-getdents","package_name":"retrieve-directory-inside-array-through-getdents","function_definitions":{"retrieve-directory-inside-array-through-getdents":{"return_type":"i64","parameter_definitions":[{"parameter_name":"fd","parameter_type":"i64"},{"parameter_name":"buf","parameter_type":"i64"},{"parameter_name":"bufsize","parameter_type":"i64"},{"parameter_name":"arr","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"fetch-directory-entries-filling-caller-buffer","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"buf"},{"kind":"var","value":"bufsize"}],"result_assignment_variable":"nbytes","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"nbytes"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"collect-directory-entry-block-bearing-classification","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"zero"},{"kind":"var","value":"nbytes"},{"kind":"var","value":"arr"}],"result_assignment_variable":"cw","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"retrieve-directory-inside-array-through-getdents","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"buf"},{"kind":"var","value":"bufsize"},{"kind":"var","value":"arr"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}