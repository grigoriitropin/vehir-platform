{"build_type":"daemon","description":"Minimal event-driven service supervisor (no sleep). Reads service_path (a string) and service_request (any document value, which it RENDERS to a cstring so callers can pass a nested request object without manual escaping) from its request via the sanctioned entry, blocks SIGCHLD and opens a signalfd for it so child death arrives as a poll event, creates a disarmed monotonic timerfd for restart backoff, packs all state into a context struct (service_path 0, service_request 8, signalfd 16, timerfd 24, failures 32, child_pid 40), launches the service once handing it the rendered request as argv one, then enters the poll-driven event loop that reaps deaths and restarts with backoff plus a crash-limit park.","module_name":"supervise-managed-daemon-process-lifecycle","package_name":"supervise-managed-daemon-process-lifecycle","function_definitions":{"supervise-managed-daemon-process-lifecycle":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","va