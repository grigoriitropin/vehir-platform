{"build_type":"library","description":"Per-verb relocation handler for the openat verb. Reads the directory descriptor from request slot 257, the region-relative path offset from slot 258 and the open flags from slot 259, each once into a local. Relocates the path offset through the string bounds primitive and, only when relocation succeeds, performs the openat module realization which writes the resulting descriptor into result slot 260. On a denied offset the result slot is left at the deny sentinel placed by the caller.","module_name":"relocate-offset-arguments-performing-openat-handler","package_name":"relocate-offset-arguments-performing-openat-handler","function_definitions":{"relocate-offset-arguments-performing-openat-handler":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"i257","variable_type":"i64","assignment_operation":"literal","source_target":257},{"instruction_type":"variable_declaration","variable_name":"i258","variable_type":"i64","assignment_operation":"literal","source_target":258},{"instruction_type":"variable_declaration","variable_name":"i259","variable_type":"i64","assignment_operation":"literal","source_target":259},{"instruction_type":"array_read","dest":"dirfd","base":"base","index":"i257","scale":8},{"instruction_type":"array_read","dest":"pathoff","base":"base","index":"i258","scale":8},{"instruction_type":"array_read","dest":"flags","base":"base","index":"i259","scale":8},{"instruction_type":"function_invocation","invocation_name":"bounds-check-string-offset-returning-relocated-pointer","invocation_arguments":[{"kind":"var","value":"base"},{"kind":"var","value":"pathoff"}],"result_assignment_variable":"pathptr","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"pathptr"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"perform-openat-syscall-writing-shared-region-result","invocation_arguments":[{"kind":"var","value":"base"},{"kind":"var","value":"dirfd"},{"kind":"var","value":"pathptr"},{"kind":"var","value":"flags"}],"result_assignment_variable":"pr","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}