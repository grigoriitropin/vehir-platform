{"build_type":"library","description":"Walk the children of the buckets object (each child is an array of function names sharing an identical serialized definition); for every bucket with two or more members, tally it into the two-slot counts buffer (slot zero group count, slot one total cloned) AND append the serialized member-name array as a string to the groups array so the report names which functions are clones. The serialization is a fresh string so no node is reparented. Recurses along next. Arguments: first bucket node, counts buffer, groups array.","module_name":"collect-clone-buckets-holding-multiple-function-members","package_name":"collect-clone-buckets-holding-multiple-function-members","function_definitions":{"collect-clone-buckets-holding-multiple-function-members":{"return_type":"i64","parameter_definitions":[{"parameter_name":"bucket_node","parameter_type":"i64"},{"parameter_name":"counts","parameter_type":"i64"},{"parameter_name":"groups","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"bucket_node"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"bucket_node"}],"result_assignment_variable":"size","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"one"},"rhs":{"value":"size"},"branch_on_success":[{"instruction_type":"array_read","dest":"g","base":"counts"