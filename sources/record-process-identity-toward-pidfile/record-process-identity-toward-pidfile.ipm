{"build_type":"library","description":"Record the running process identity into the pidfile at the given path so an external power-button tool can reach it. Writes the process identifier as eight raw little-endian octets and returns it. The path is supplied by the caller (from the boot request), never hardcoded.","module_name":"record-process-identity-toward-pidfile","package_name":"record-process-identity-toward-pidfile","function_definitions":{"record-process-identity-toward-pidfile":{"return_type":"i64","parameter_definitions":[{"parameter_name":"path","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"39","arg1":"zero","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"pid"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"eight"}],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"array_write","base":"buf","index":"zero","value":"pid","scale":8},{"instruction_type":"function_invocation","invocation_name":"acquire-filepath-towards-writing-operations","invocation_arguments":[{"kind":"var","value":"path"}],"result_assignment_variable":"fd","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"transmit-bytes-writing-descriptor-stream","invocation_arguments":[{