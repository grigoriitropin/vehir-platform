{"build_type":"library","description":"Lay out a launch child context with a pointed-to doorbell. In the caller-owned region: places a three-word doorbell (counter, waiters-flag, sequence) at region+16, zeroes it, and writes its address into context slot 1 (region+8) so the render-clone child epilogue rings the doorbell THROUGH the pointer (pointer-mode). Returns the doorbell address for the parent to park on. Single-child uses the inline doorbell here; parallel collectors pass a shared doorbell address instead.","module_name":"prepare-launch-doorbell-context","package_name":"prepare-launch-doorbell-context","function_definitions":{"prepare-launch-doorbell-context":{"return_type":"i64","parameter_definitions":[{"parameter_name":"region","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"sixteen","variable_type":"i64","assignment_operation":"literal","source_target":16},{"instruction_type":"variable_declaration","variable_name":"dbaddr","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"dbaddr","lhs":{"value":"region"},"rhs":{"value":"sixteen"}},{"instruction_type":"array_write","base":"region","index":"one","value":"dbaddr","scale":8},{"instruction_type":"array_write","base":"dbaddr","index":"zero","value":"zero","scale":8},{"instruction_type":"array_write","base":"dbaddr","index":"one","value":"zero","scale":8},{"instruction_type":"array_write","base":"dbaddr","index":"two","value":"zero","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"dbaddr"}}]}}}