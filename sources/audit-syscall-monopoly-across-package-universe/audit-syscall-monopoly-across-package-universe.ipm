{"build_type":"executable","description":"Read-only detector and seed of the syscall-monopoly enforcer. Walks every package under the given roots and reports every syscall site as a package and syscall-number pair, plus a count and the number of packages scanned. The scalar count and packages scanned are emitted first so they are visible without reading the whole site array. This is the exhaustive ground-truth atom inventory for the host-module design and the basis for the future fail-closed enforcer.","module_name":"audit-syscall-monopoly-across-package-universe","package_name":"audit-syscall-monopoly-across-package-universe","function_definitions":{"audit-syscall-monopoly-across-package-universe":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_roots","variable_type":"str","assignment_operation":"string","source_target":"roots"},{"instruction_type":"variable_declaration","variable_name":"s_sites","variable_type":"str","assignment_operation":"string","source_target":"syscall_sites"},{"instruction_type":"variable_declaration","variable_name":"s_count","variable_type":"str","assignment_operation":"string","source_target":"count"},{"instruction_type":"variable_declaration","variable_name":"s_scanned","variable_type":"str","assignment_operation":"string","source_target":"packages_scanned"},{"instruction_type":"function_invocation","invocation_name":"parse-argument-vector-json-request","invocation_arguments":[{"kind":"var","value":"__argc"},{"kind":"var","value":"__argv"}],"result_assignment_variable":"req","result_type":"i64"},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"req","dest":"reqch"},{"instruction_type