{"build_type":"executable","description":"Increment-3a-ii mini-kernel, now funnelled - every host syscall goes through the host-port module primitives instead of raw sys. Creates two independent channels each with its own memfd region, doorbell pair and capability mask, forks two children fd-scoped so each child holds only its own channel, then epoll-multiplexes both request doorbells serving whichever fires with that channel mask. Proves epoll multiplex, per-channel mask, fd-scoped identity, and the funnelled module path together.","module_name":"multiplex-paired-offset-channels-using-masks","package_name":"multiplex-paired-offset-channels-using-masks","function_definitions":{"multiplex-paired-offset-channels-using-masks":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"sixteen","variable_type":"i64","assignment_operation