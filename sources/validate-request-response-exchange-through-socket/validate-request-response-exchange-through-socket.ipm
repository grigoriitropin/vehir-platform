{"build_type":"executable","description":"Client probe for the minimal bus daemon. Connects to the abstract bus socket, writes a fixed tool request (help), shuts down its write side so the daemon read sees end of stream, reads the whole response back to end of stream, and emits it under the response key. A non-empty response that looks like the shell help output proves the end to end no pipe path: client to daemon to fork to dup2 to shell to tool to socket to client.","module_name":"validate-request-response-exchange-through-socket","package_name":"validate-request-response-exchange-through-socket","function_definitions":{"validate-request-response-exchange-through-socket":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"addrsize","variable_type":"i64","assignment_operation":"literal","source_target":116},{"instruction_type":"variable_declaration","variable_name":"capbig","variable_type":"i64","assignment_operation":"literal","source_target":1048576},{"instruction_type":"variable_declaration","variable_name":"sockname","variable_type":"str","assignment_operation":"string","source_target":"vehir-bus-socket"},{"instruction_type":"variable_declaration","variable_name":"s_response","variable_type":"str","assignment_operation":"string","source_target":"response"},{"instruction_type":"variable_declaration","variable_name":"req","variable_type":"str","assignment_operation":"stri