{"build_type":"library","module_name":"terminate-listener-setup-on-anomaly","package_name":"terminate-listener-setup-on-anomaly","description":"Fail-hard primitive for socket listener setup: writes a diagnostic line to standard error then terminates the whole process loudly via exit_group with a distinctive nonzero code. Used when a listener's bind/getsockname/listen invariant is violated, so the service can NEVER silently continue on a wrong port; the process supervisor restarts the kernel, which retries the bind cleanly.","function_definitions":{"terminate-listener-setup-on-anomaly":{"return_type":"i64","parameter_definitions":[{"parameter_name":"diag","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"fd_err","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"exit_code","variable_type":"i64","assignment_operation":"literal","source_target":77},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"diag"}],"result_assignment_variable":"dlen","result_type":"i64"},{"instruction_type":"invoke_kernel_syscall","syscall_number":"1","arg1":"fd_err","arg2":"diag","arg3":"dlen","arg4":"exit_code","arg5":"exit_code","arg6":"exit_code","result_variable":"wr"},{"instruction_type":"invoke_kernel_syscall","syscall_number":"231","arg1":"exit_code","arg2":"exit_code","arg3":"exit_code","arg4":"exit_code","arg5":"exit_code","arg6":"exit_code","result_variable":"nx"},{"instruction_type":"return_statement","return_payload":{"value":"exit_code"}}]}}}