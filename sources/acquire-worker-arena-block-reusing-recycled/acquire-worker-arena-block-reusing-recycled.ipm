{"build_type":"library","description":"Hand a per-worker arena block to a spawner, reusing a block recycled by a finished worker before asking the system for fresh memory. While parked, a recycled block's first slot links the singly-linked free list (declared here as the pool head). Touched only by the spawning/collecting parent thread, serially, so no atomics. Pairs with recycle-worker-arena-block-into-recycled-pool to keep serial fan-out in bounded memory instead of carving a fresh block per worker.","module_name":"acquire-worker-arena-block-reusing-recycled","package_name":"acquire-worker-arena-block-reusing-recycled","function_definitions":{"acquire-worker-arena-block-reusing-recycled":{"return_type":"i64","parameter_definitions":[{"parameter_name":"size","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"global_read","dest":"head","name":"g_worker_block_free_list"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"head"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"array_read","dest":"next","base":"head","index":"zero","scale":8},{"instruction_type":"global_write","name":"g_worker_block_free_list","value":"next"},{"instruction_type":"return_statement","return_payload":{"value":"head"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"allocate-system-memory-chunk-region","invocation_arguments":[{"kind":"var","value":"size"}],"result_assignment_variable":"block","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"block"}}]}},"module_globals":[{"global_name":"g_worker_block_free_list","global_type":"i64","global_init":"0"}]}