{"build_type":"executable","description":"Throwaway verification probe for the Model Context Protocol tools/call handler. Reads shell_path and libdir from its own request, builds the handler config context, parses a fixed inner request (a checkname call), and invokes the tools/call handler with the connection descriptor set to file descriptor one so the wrapped JSON-RPC result (a content text block carrying the captured tool output) is printed to stdout. Verifies the fork plus pipe plus loader capture path end to end without a socket.","module_name":"probe-protocol-invocation-handler-capture-roundtrip","package_name":"probe-protocol-invocation-handler-capture-roundtrip","function_definitions":{"probe-protocol-invocation-handler-capture-roundtrip":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"c24","variable_type":"i64","assignment_operation":"literal","source_target":24},{"instruction_type":"variable_declaration","variable_name":"k_shell","variable_type":"str","assignment_operation":"string","source_target":"shell_path"},{"instruction_type":"variable_declaration","variable_name":"k_libdir","variable_type":"str","assignment_operation":"string","source_target":"libdir"},{"instruction_type":"variable_declaration","variable_name":"entry","variable_type":"str","assignment_operation":"string","source_target":"dispatch_capability_gated_json_request"},{"instruction_type":"variabl