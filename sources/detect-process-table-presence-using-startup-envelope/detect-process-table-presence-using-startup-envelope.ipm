{"build_type":"library","description":"Discriminate a cold boot from an in-process swap re-entry. Reads the arena base from the boot envelope (slot 0), records it as the table base in g_process_table_base, and returns 1 when the table magic is already present at the base (a swap re-entry over a live arena) or 0 when it is absent (a cold boot over a fresh zero-filled arena). Reads only memory, depends on no global, so it is safe before the arena allocator is installed.","module_name":"detect-process-table-presence-using-startup-envelope","package_name":"detect-process-table-presence-using-startup-envelope","function_definitions":{"detect-process-table-presence-using-startup-envelope":{"return_type":"i64","parameter_definitions":[{"parameter_name":"env","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"s0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"magicc","variable_type":"i64","assignment_operation":"literal","source_target":1448888908},{"instruction_type":"array_read","dest":"table_base","base":"env","index":"s0","scale":8},{"instruction_type":"global_write","name":"g_process_table_base","value":"table_base"},{"instruction_type":"array_read","dest":"m","base":"table_base","index":"s0","scale":8},{"instruction_type":"variable_declaration","variable_name":"r","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"m"},"rhs":{"value":"magicc"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"r","variable_type":"i64","assignment_operation":"literal","source_target":1}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}