{"build_type":"library","module_name":"acquire-arena-chunk-reusing-released-region","package_name":"acquire-arena-chunk-reusing-released-region","description":"Allocator HALF-A chunk grabber: returns a usable base for needed_bytes by reusing a released chunk off the free-list (first-fit) or mmapping a fresh one. Each chunk carries a 16-byte header (slot 0 = total size, slot 1 = link to previous live chunk). Pushes the chunk onto the live stack via g_arena_current_chunk, sets the bump cursor to base+16 and the end to base+size. Declares the five HALF-A globals.","function_definitions":{"acquire-arena-chunk-reusing-released-region":{"return_type":"i64","parameter_definitions":[{"parameter_name":"needed_bytes","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"sixteen","variable_type":"i64","assignment_operation":"literal","source_target":16},{"instruction_type":"variable_declaration","variable_name":"defreg","variable_type":"i64","assignment_operation":"literal","source_target":1048576},{"instruction_type":"variable_declaration","variable_name":"want","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"want","lhs":{"value":"needed_bytes"},"rhs":{"value":"sixteen"}},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"defreg"},"rhs":{"value":"want"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"want","lhs":{"value":"defreg"},"rhs":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"global_read","dest":"fl","name":"g_arena_free_list"},{"instruction_type":"