{"build_type":"library","description":"Selection-sort a {name,type} entry list into the `sorted` array by repeatedly taking the smallest name strictly greater than prev_name (find_min_entry_above_name) and appending a FRESH COPY {name,type} of it. Copying (not relinking) keeps the source list read-only: it is never mutated, so it cannot be corrupted. Tail-recursive (prev_name advances to the just-emitted name each step). O(n^2) per directory, but n is one directory's entry count (small in practice); a faster O(n log n) is a later optimization. Reuses find_min_entry_above_name, locate_named_member_inside_mapping, begin_empty_mapping_document_value, encode_textual_payload_document_value, attach_named_member_inside_mapping, add_number_to_object, append_element_extending_document_sequence.","module_name":"build-sorted-entry-copies-sequence","package_name":"build-sorted-entry-copies-sequence","function_definitions":{"build-sorted-entry-copies-sequence":{"return_type":"i64","parameter_definitions":[{"parameter_name":"head","parameter_type":"i64"},{"parameter_name":"sorted","parameter_type":"i64"},{"parameter_name":"prev_name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_name","variable_type":"str","assignment_operation":"string","source_target":"name"},{"instruction_type":"variable_declaration","variable_name":"s_type","variable_type":"str","assignment_operation":"string","source_target":"type"},{"instruction_type":"function_invocation","invocation_name":"identify-lexicographically-smallest-remaining-directory-entry","invocation_arguments":[{"kind":"var","value":"head"},{"kind":"var","value":"prev_name"},{"kind":"var","value":"zero"}],"result_assignment_variable":"best","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"best"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"sorted"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"best"},{"kind":"var","value":"s_name"}],"result_assignment_variable":"bnn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"bnn"}],"result_assignment_variable":"bn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"best"},{"kind":"var","value":"s_type"}],"result_assignment_variable":"btn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-number-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"btn"}],"result_assignment_variable":"bt","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"ent","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"encode-textual-payload-document-value","invocation_arguments":[{"kind":"var","value":"bn"}],"result_assignment_variable":"ns","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"ent"},{"kind":"var","value":"s_name"},{"kind":"var","value":"ns"}]},{"instruction_type":"function_invocation","invocation_name":"attach-numeric-value-towards-object","invocation_arguments":[{"kind":"var","value":"ent"},{"kind":"var","value":"s_type"},{"kind":"var","value":"bt"}]},{"instruction_type":"function_invocation","invocation_name":"append-element-extending-document-sequence","invocation_arguments":[{"kind":"var","value":"sorted"},{"kind":"var","value":"ent"}]},{"instruction_type":"function_invocation","invocation_name":"build-sorted-entry-copies-sequence","invocation_arguments":[{"kind":"var","value":"head"},{"kind":"var","value":"sorted"},{"kind":"var","value":"bn"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}