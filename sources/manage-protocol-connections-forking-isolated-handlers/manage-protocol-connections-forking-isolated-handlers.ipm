{"build_type":"library","description":"Connection manager that decouples the durable service from the per-socket writer. Accepts one connection on the listen socket, forks an isolated handler child that reads, dispatches and writes the reply on that one connection then terminates via exit_group, while the manager closes its copy of the connection (it never writes a client socket, so a broken-pipe signal can never reach it), reaps the handler, and tail-recurses to keep accepting. A client disconnect during a reply kills at most the one handler child, never the service. Portal access stays serialized because the manager reaps each handler before accepting the next; true parallelism arrives later with per-connection portal channels.","module_name":"manage-protocol-connections-forking-isolated-handlers","package_name":"manage-protocol-connections-forking-isolated-handlers","function_definitions":{"manage-protocol-connections-forking-isolated-handlers":{"return_type":"i64","parameter_definitions":[{"parameter_name":"listen_fd","parameter_type":"i64"},{"parameter_name":"scratch","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"accept-pending-connection-returning-stream-descriptor","invocation_arguments":[{"kind":"var","value":"listen_fd"},{"kind":"var","value":"zero"},{"kind":"var","value":"zero"}],"result_assignment_variable":"conn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"duplicate-current-process-returning-child-identifier","invocation_arguments":[],"result_assignment_variable":"pid","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"pid"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"answer-protocol-request-framing-internet-reply","invocation_arguments":[{"kind":"var","value":"conn"},{"kind":"var","value":"scratch"}],"result_assignment_variable":"d","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"__e","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"231","arg1":"zero","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"ex"}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"close-descriptor-releasing-kernel-resource","invocation_arguments":[{"kind":"var","value":"conn"}],"result_assignment_variable":"clc","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"__w","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"__t1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"61","arg1":"pid","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"wr"},{"instruction_type":"function_invocation","invocation_name":"manage-protocol-connections-forking-isolated-handlers","invocation_arguments":[{"kind":"var","value":"listen_fd"},{"kind":"var","value":"scratch"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}