{"build_type":"tool","description":"Surgical edit of ANY file: replace the FIRST occurrence of the exact text `old` with `new`, written back atomically (temp then rename syscall 82). Lets a shell-locked agent edit arbitrary files (memory notes, plans, configs) without rewriting the whole file. Reads the file, finds `old` via compute_substring_match_offset_within_string, splices prefix + new + suffix, writes atomically. old absent -> {error,code:old_not_found}, no change; unreadable file -> {error,code:read_failed}. Request: {path, old, new}. Emits {edited:<path>, bytes:<new length>}. NOTE: only the first occurrence; make `old` long/unique to target the right spot.","module_name":"replace-matched-content-within-existing-target","package_name":"replace-matched-content-within-existing-target","function_definitions":{"replace-matched-content-within-existing-target":{"return_type":"i64","parameter_definitions":[{"parameter_name":"request","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_path","variable_type":"str","assignment_operation":"string","source_target":"path"},{"instruction_type":"variable_declaration","variable_name":"s_old","variable_type":"str","assignment_operation":"string","source_target":"old"},{"instruction_type":"variable_declaration","variable_name":"s_new","variable_type":"str","assignment_operation":"string","source_target":"new"},{"instruction_type":"variable_declaration","variable_name":"s_edited","variable_type":"str","assignment_operation":"string","source_target":"edited"},{"instruction_type":"variable_declaration","variable_name":"s_bytes","variable_type":"str","assignment_operation":"string","source_target":"bytes"},{"instruction_type":"variable_declaration","variable_name":"s_dotmp","variable_type":"str","assignment_operation":"string","sourc