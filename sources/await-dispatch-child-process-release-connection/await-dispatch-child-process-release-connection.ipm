{"build_type":"library","description":"Parent side of the bus daemon after fork: wait4 to reap the dispatch child (no zombies), then close the daemon own copy of the accepted connection. Closing the last write reference lets the client see end of stream on the response. Runs in its own function so the parent path temporaries stay independent of the child path.","module_name":"await-dispatch-child-process-release-connection","package_name":"await-dispatch-child-process-release-connection","function_definitions":{"await-dispatch-child-process-release-connection":{"return_type":"i64","parameter_definitions":[{"parameter_name":"child_pid","parameter_type":"i64"},{"parameter_name":"conn_fd","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"await-child-process-termination-returning-status","invocation_arguments":[{"kind":"var","value":"child_pid"},{"kind":"var","value":"zero"}],"result_assignment_variable":"pw","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"t1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"close-descriptor-releasing-kernel-resource","invocation_arguments":[{"kind":"var","value":"conn_fd"}],"result_assignment_variable":"cl","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}