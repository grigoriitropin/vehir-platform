{"build_type":"library","description":"Kernel-side HTTP health client: opens an IPv4 stream socket to loopback 127.0.0.1 on the given network-order port bytes (port_hi, port_lo), sends the request string, reads the response, and returns 1 if the HTTP status line is 200 (bytes 9..11 equal the ASCII digits 2,0,0 right after the protocol token plus space), else 0. On connect failure it closes, naps briefly (nanosleep 20ms), and retries up to attempts times so the call can race the in-boot HTTP edge coming up. Pure socket syscalls reusing the proven endpoint/connect/transmit/consume primitives -- no shell, no portal, so the kernel can run it during bring-up without re-entrancy.","module_name":"confirm-internet-endpoint-returns-success-status","package_name":"confirm-internet-endpoint-returns-success-status","function_definitions":{"confirm-internet-endpoint-returns-success-status":{"return_type":"i64","parameter_definitions":[{"parameter_name":"port_hi","parameter_type":"i64"},{"parameter_name":"port_lo","parameter_type":"i64"},{"parameter_name":"request","parameter_type":"i64"},{"parameter_name":"attempts","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"i1","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"sixteen","variable_type":"i64","assignment_operation":"literal","source