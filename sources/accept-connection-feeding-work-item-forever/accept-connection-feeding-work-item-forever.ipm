{"build_type":"library","module_name":"accept-connection-feeding-work-item-forever","package_name":"accept-connection-feeding-work-item-forever","description":"SM.1 forever accept loop for the MCP assessor: accepts one connection on the listen descriptor, pushes {conn} as a work-item into the collector channel (the connection fd only; the request I/O happens in the per-connection handler worker, so a slow/faulting handler costs one connection, not the service), then tail-recurses forever. Never closes the stream.","function_definitions":{"accept-connection-feeding-work-item-forever":{"return_type":"i64","parameter_definitions":[{"parameter_name":"channel","parameter_type":"i64"},{"parameter_name":"sfd","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"k_conn","variable_type":"str","assignment_operation":"string","source_target":"conn"},{"instruction_type":"function_invocation","invocation_name":"accept-pending-connection-returning-stream-descriptor","invocation_arguments":[{"kind":"var","value":"sfd"},{"kind":"var","value":"zero"},{"kind":"var","value":"zero"}],"result_assignment_variable":"conn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"obj","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-numeric-value-towards-object","invocation_arguments":[{"kind":"var","value":"obj"},{"kind":"var","value":"k_conn"},{"kind":"var","value":"conn"}]},{"instruction_type":"function_invocation","invocation_name":"append-work-item-json-ringing-collector-doorbell","invocation_arguments":[{"kind":"var","value":"channel"},{"kind":"var","value":"obj"}]},{"instruction_type":"function_invocation","invocation_name":"accept-connection-feeding-work-item-forever","invocation_arguments":[{"kind":"var","value":"channel"},{"kind":"var","value":"sfd"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}