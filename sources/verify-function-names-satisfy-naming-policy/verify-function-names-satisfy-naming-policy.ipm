{"build_type":"library","description":"Compile-time naming gate. Given the merged module, walk every function name in function_definitions and report a name_policy_violation for each that fails the naming policy. Returns the number of new violations (delta of the error accumulator) so the compiler driver fails closed when any name is non-compliant. Mirrors verify_no_duplicate_function_bodies. Function names equal package, folder, and file names by the one-function-per-package convention, so this gate covers all four name kinds.","module_name":"verify-function-names-satisfy-naming-policy","package_name":"verify-function-names-satisfy-naming-policy","function_definitions":{"verify-function-names-satisfy-naming-policy":{"return_type":"i64","parameter_definitions":[{"parameter_name":"merged","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"k_fns","variable_type":"str","assignment_operation":"string","source_target":"function_definitions"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"merged"},{"kind":"var","value":"k_fns"}],"result_assignment_variable":"fns","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"fns"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"calculate-total-reported-errors-count","invocation_arguments":[],"result_assignment_variable":"snap","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"naming-abbreviation-allowlist-json-values","invocation_arguments":[],"result_assignment_variable":"allowlist","result_type":"i64"},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"fns","dest":"fn_first"},{"instruction_type":"function_invocation","invocation_name":"inspect-function-names-flagging-policy-violations","invocation_arguments":[{"kind":"var","value":"fn_first"},{"kind":"var","value":"allowlist"}],"result_assignment_variable":"ignored","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"calculate-total-reported-errors-count","invocation_arguments":[],"result_assignment_variable":"now","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"delta","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"-","target":"delta","lhs":{"value":"now"},"rhs":{"value":"snap"}},{"instruction_type":"return_statement","return_payload":{"value":"delta"}}]}}}