{"build_type":"library","module_name":"allocate-bytes-within-fixed-arena","package_name":"allocate-bytes-within-fixed-arena","description":"The kernel pure bump allocator over a FIXED given arena. Reads the arena cursor and end globals, hands out a 16-byte-aligned slice by advancing the cursor, and returns it. Unlike the compiler/loader allocator it has NO host escape: on exhaustion it does NOT grab a host memory chunk (no mmap, no syscall) but returns 0, because pretend-hardware RAM is fixed at boot and the kernel never acquires more (an out-of-memory condition is the kernel internal concern, never a host crossing). The arena bounds are GIVEN by the loader before the kernel runs; this function only reads and bumps them.","function_definitions":{"allocate-bytes-within-fixed-arena":{"return_type":"i64","parameter_definitions":[{"parameter_name":"size","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"fifteen","variable_type":"i64","assignment_operation":"literal","source_target":15},{"instruction_type":"variable_declaration","variable_name":"mask","variable_type":"i64","assignment_operation":"literal","source_target":-16},{"instruction_type":"variable_declaration","variable_name":"size_padded","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"size_padded","lhs":{"value":"size"},"rhs":{"value":"fifteen"}},{"instruction_type":"alu_operation","operator":"&","target":"size_padded","lhs":{"value":"size_padded"},"rhs":{"value":"mask"}},{"instruction_type":"global_read","dest":"cur","name":"arena_cursor_address"},{"instruction_type":"variable_declaration","variable_name":"probe","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"probe","lhs":{"value":"cur"},"rhs":{"value":"size_padded"}},{"instruction_type":"global_read","dest":"endv","name":"arena_end_address"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"probe"},"rhs":{"value":"endv"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"m_oom","variable_type":"str","assignment_operation":"string","source_target":"VEHIR_OOM-fixed-arena-exhausted-deny"},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"m_oom"}],"result_assignment_variable":"lo","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"transmit-bytes-writing-descriptor-stream","invocation_arguments":[{"kind":"var","value":"two"},{"kind":"var","value":"m_oom"},{"kind":"var","value":"lo"}],"result_assignment_variable":"wo","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"newcur","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"newcur","lhs":{"value":"cur"},"rhs":{"value":"size_padded"}},{"instruction_type":"global_write","name":"arena_cursor_address","value":"newcur"},{"instruction_type":"return_statement","return_payload":{"value":"cur"}}]}}}