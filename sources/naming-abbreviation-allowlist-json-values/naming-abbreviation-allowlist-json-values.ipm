{"build_type":"library","description":"Data-only: parse and return the registered allowlist of established technical abbreviations exempt from the >=5-letter-per-word rule of the naming policy (elf, ast, i64, cas, sha, json, ipm, cpu, gpu). Returned as parsed JSON text which builds a document tree of strings for membership testing. Extend this list (not the validator logic) to register a new abbreviation.","module_name":"naming-abbreviation-allowlist-json-values","package_name":"naming-abbreviation-allowlist-json-values","function_definitions":{"naming-abbreviation-allowlist-json-values":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"s","variable_type":"str","assignment_operation":"string","source_target":"[\"elf\",\"ast\",\"i64\",\"cas\",\"sha\",\"json\",\"ipm\",\"cpu\",\"gpu\"]"},{"instruction_type":"function_invocation","invocation_name":"decode-entire-source-building-document","invocation_arguments":[{"kind":"var","value":"s"}],"result_assignment_variable":"arr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"arr"}}]}}}