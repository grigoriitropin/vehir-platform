{"build_type":"library","description":"Copies a null-terminated C string from a source pointer into the shared region starting at the given index, byte by byte including the terminating null, so a request path can be placed in the region at an address valid in both the tool and the kernel. Null-guard: if src==0 return 0 (prevents SIGSEGV on NULL source string).","module_name":"transfer-cstring-octets-inside-region","package_name":"transfer-cstring-octets-inside-region","function_definitions":{"transfer-cstring-octets-inside-region":{"return_type":"i64","parameter_definitions":[{"parameter_name":"src","parameter_type":"i64"},{"parameter_name":"region","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"src"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"array_read","dest":"b","base":"src","index":"i","scale":1},{"instruction_type":"array_write","base":"region","index":"i","value":"b","scale":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"b"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[{"instruction_type":"variable_declaration","variable_name":"inext","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"inext","lhs":{"value":"i"},"rhs":{"value":"one"}},{"instruction_type":"function_invocatio