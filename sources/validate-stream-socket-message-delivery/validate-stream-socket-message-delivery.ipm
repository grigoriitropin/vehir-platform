{"build_type":"executable","description":"Step-2 probe validating AF_UNIX SOCK_STREAM socket plumbing in this runtime using an abstract-namespace socket (no filesystem path, no stale files, no unlink). Builds a sockaddr_un with a leading null marker and an abstract name, creates a socket, binds, listens, then forks. The child connects and sends a known literal; the parent accepts one connection, reads the bytes, and emits them under the received key. If received equals the literal then socket, bind, listen, accept, and connect all work. Branch bodies live in separate functions to keep per-path temporaries independent.","module_name":"validate-stream-socket-message-delivery","package_name":"validate-stream-socket-message-delivery","function_definitions":{"validate-stream-socket-message-delivery":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"addrsize","variable_type":"i64","assignment_operation":"literal","source_target":116},{"instruction_type":"variable_declaration","variable_name":"sockname","variable_type":"str","assignment_operation":"string","source_target":"vehir-bus-probe-socket"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","