{"build_type":"library","description":"Fail-closed single-sanctioned-exit auditor. Given roots and an array of tool entry function names under the key targets, enumerates the package universe, builds the function index, and for each target computes its call closure and checks whether the sanctioned output emitter package is reachable. Emits missing_count, a catalog code silent_exit_path when any target cannot reach the emitter, then the missing target list, and returns the missing count as the exit status so a build gate fails closed when any tool could exit without emitting through the single sanctioned emitter.","module_name":"report-binaries-missing-sanctioned-emitter-reachability","package_name":"report-binaries-missing-sanctioned-emitter-reachability","function_definitions":{"report-binaries-missing-sanctioned-emitter-reachability":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"c40","variable_type":"i64","assignment_operation":"literal","source_target":40},{"instruction_type":"variable_declaration","variable_name":"s_roots","variable_type":"str","assignment_operation":"string","source_target