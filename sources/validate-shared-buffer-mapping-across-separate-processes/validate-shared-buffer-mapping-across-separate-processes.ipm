{"build_type":"executable","description":"Make-or-break probe for the kernel native gate hosted by the compatibility module. Maps an anonymous MAP_SHARED buffer (the module mechanic), writes a marker, then forks a Vehir process. The forked process touches ONLY the inherited shared buffer with zero setup syscalls: it reads the parent marker, increments it, and writes it back. The parent reaps the child and reads the shared buffer; seeing the incremented value proves a buffer shared across a module-driven fork at zero per-operation syscall cost for the spawned process.","module_name":"validate-shared-buffer-mapping-across-separate-processes","package_name":"validate-shared-buffer-mapping-across-separate-processes","function_definitions":{"validate-shared-buffer-mapping-across-separate-processes":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"cap","variable_type":"i64","assignment_operation":"literal","source_target":4096},{"instruction_type":"variable_declaration","variable_name":"seventyfive","variable_type":"i64","assignment_operation":"literal","source_target":75},{"instruction_type":"function_invocation","invocation_name":"allocate-anonymous-shared-mapping-region","invocation_arguments":[{"kind":"var","value":"cap"}],"result_assignment_variable":"region","result_type":"i64"},{"instruction_type":"array_write","base":"region","index":"zero","value":"seventyfive","scale":1},{"instruction_type":"function_invocation","invocation_name":"duplicate-current-process-returning-child-identifier","invocation_arguments":[],"result_assignment_variable":"pid","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"pid"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"stamp-incremented-marker-inside-inherited-shared-buffer","invocation_arguments":[{"kind":"var","value":"region"}],"result_assignment_variable":"cr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"cr"}}],"branch_on_failure":[{"instruction_type":"function_invocation","invocation_name":"harvest-shared-buffer-marker-after-child-completes","invocation_arguments":[{"kind":"var","value":"pid"},{"kind":"var","value":"region"}],"result_assignment_variable":"pr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"pr"}}]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}