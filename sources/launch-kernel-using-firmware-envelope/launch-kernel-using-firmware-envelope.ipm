{"build_type":"executable","description":"Single self-booting driver with imperative generation selection. The boot target generation is chosen IN the launch request: pass generation (a number) plus store (the content-addressed store root) and the driver resolves the libdir to store/generations/N/bin/objlib; or pass an explicit libdir. It then runs the full firmware envelope (counts, threads, granted per-class masks, arena clamped to real RAM), pins this process onto the granted CPU set, builds the kernel env, records its pid, and loads the kernel entry so it parks. Emits the granted envelope, the confirmed pinned affinity, and the kernel result.","module_name":"launch-kernel-using-firmware-envelope","package_name":"launch-kernel-using-firmware-envelope","function_definitions":{"launch-kernel-using-firmware-envelope":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_ty