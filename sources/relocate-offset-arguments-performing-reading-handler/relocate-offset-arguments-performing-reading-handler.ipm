{"build_type":"library","description":"Per-verb relocation handler for the read verb. Reads the file descriptor from request slot 257, the region-relative buffer offset from slot 258 and the byte count from slot 259, each once into a local. Relocates the buffer offset through the overflow-safe buffer bounds primitive passing the count as the length, and only when relocation succeeds performs the read module realization which writes the byte count returned into result slot 260. On a denied offset or length the result slot is left at the deny sentinel placed by the caller.","module_name":"relocate-offset-arguments-performing-reading-handler","package_name":"relocate-offset-arguments-performing-reading-handler","function_definitions":{"relocate-offset-arguments-performing-reading-handler":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"i257","variable_type":"i64","assignment_operation":"literal","source_target":257},{"instruction_type":"variable_declaration","variable_name":"i258","variable_type":"i64","assignment_operation":"literal","source_target":258},{"instruction_type":"variable_declaration","variable_name":"i259","variable_type":"i64","assignment_operation":"literal","source_target":259},{"instruction_type":"array_read","dest":"fd","base":"base","index":"i257","scale":8},{"instruction_type":"array_read","dest":"bufoff","base":"base","index":"i258","scale":8},{"instruction_type":"array_read","dest":"count","base":"base","index":"i259","scale":8},{"instruction_type":"function_invocation","invocation_name":"bounds-check-buffer-offset-returning-relocated-pointer","invocation_arguments":[{"kind":"var","value":"base"},{"kind":"var","value":"bufoff"},{"kind":"var","value":"count"}],"result_assignment_variable":"bufptr","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"bufptr"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"perform-reading-syscall-writing-shared-region-result","invocation_arguments":[{"kind":"var","value":"base"},{"kind":"var","value":"fd"},{"kind":"var","value":"bufptr"},{"kind":"var","value":"count"}],"result_assignment_variable":"pr","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}