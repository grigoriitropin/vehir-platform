{"build_type":"library","description":"Gate-aware boot kernel entry (Channel B, additive -- does not touch enter-kernel-arena-launching-supervisor-awaiting-shutdown). Installs the handed memory as the fixed world arena; reads the boot config (shell_path, init_path, init_request, pidfile) the launcher passes its path as the second argument; records its own identity for the power button; brings up the portal (region + request/response eventfds on fd3/fd4/fd5) so descendants inherit it; launches init (the supervisor) as a child; then runs one unified poll loop that both serves portal requests (running real tools through the shell with output back through the region, no Linux pipe) and handles the shutdown signal (stops init and returns). The shell path comes from the boot config (a reliable source, not g_ld_libdir).","module_name":"enter-portal-kernel-arena-serving-helper-requests-parking","package_name":"enter-portal-kernel-arena-serving-helper-requests-parking","function_definitions":{"enter-portal-kernel-arena-serving-helper-requests-parking":{"return_type":"i64","parameter_definitions":[{"parameter_name":"env","parameter_type":"i64"},{"parameter_name":"config_path","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"c40","variable_type":"i64","assignment_operation":"literal","source_target":40},{"instruction_type":"variable_declaration","variable_name":"k_shell","variable_type":"str","assignment_operation":"string","source_target":"shell_path"},{"instruction_type":"variable_declaration","variable