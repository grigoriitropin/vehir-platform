{"build_type":"library","description":"Walks cpu index i from zero; for each cpu reads its core id and that core id frequency. Frequency two or more means an SMT-paired performance core, so its bit is added to the performance mask and the performance cpu counter is incremented; otherwise the efficiency mask and counter. ctx2 slots: zero count, one performance mask, two efficiency mask, three running bit (starts one doubles each step), four performance cpu count, five efficiency cpu count.","module_name":"accumulate-hybrid-processor-class-masks","package_name":"accumulate-hybrid-processor-class-masks","function_definitions":{"accumulate-hybrid-processor-class-masks":{"return_type":"i64","parameter_definitions":[{"parameter_name":"coreid_arr","parameter_type":"i64"},{"parameter_name":"freq_arr","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"},{"parameter_name":"ctx2","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"array_read","dest":"n","base":"ctx2","index":"zero","scale":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">=","lhs":{"value":"i"},"rhs":{"value":