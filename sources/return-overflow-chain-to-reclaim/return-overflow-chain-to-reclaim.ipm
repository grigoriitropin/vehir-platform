{"build_type":"library","module_name":"return-overflow-chain-to-reclaim","package_name":"return-overflow-chain-to-reclaim","description":"Walk a worker's overflow-chunk chain (block[5]) or released free-list (block[15]) from cur down to base (chunk[1]=link), returning each grown chunk to the SHARED lock-free reclaim ring. Routes a grower's GiB of 1MiB grown chunks into the shared ring for cross-thread/cross-reconcile reuse instead of a thread-local list that dies with the thread. Tail-recursive.","function_definitions":{"return-overflow-chain-to-reclaim":{"return_type":"i64","parameter_definitions":[{"parameter_name":"slab","parameter_type":"i64"},{"parameter_name":"cur","parameter_type":"i64"},{"parameter_name":"base","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"cur"},"rhs":{"value":"base"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"array_read","dest":"older","base":"cur","index":"one","scale":8},{"instruction_type":"function_invocation","invocation_name":"return-chunk-to-reclaim-or-local","invocation_arguments":[{"kind":"var","value":"slab"},{"kind":"var","value":"cur"}],"result_assignment_variable":"_r","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"return-overflow-chain-to-reclaim","invocation_arguments":[{"kind":"var","value":"slab"},{"kind":"var","value":"older"},{"kind":"var","value":"base"}],"result_assignment_variable":"rr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"rr"}}]}}}