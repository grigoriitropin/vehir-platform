{"build_type":"library","description":"Trace-flag dump: walk the scheduler fiber table in buffer s (base slot 50, stride 8) for fibers 0..count-1 and append one record per fiber to the out document sequence. Each record is {id (= launch order), kind, discipline (derived from kind: 0 = tail-chain), awaiter (= who this fiber answers to, the dependency-graph edge), result (= this worker output log)}. Together the array is the full execution trace: launch order + per-worker discipline + per-worker output + the whole who-depends-on-what graph. Tail-recursive.","module_name":"record-scheduler-fiber-trace-toward-document-sequence","package_name":"record-scheduler-fiber-trace-toward-document-sequence","function_definitions":{"record-scheduler-fiber-trace-toward-document-sequence":{"return_type":"i64","parameter_definitions":[{"parameter_name":"s","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"},{"parameter_name":"count","parameter_type":"i64"},{"parameter_name":"out","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"fifty","variable_type":"i64","assignment_operation":"literal","source_target":50},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"i"}