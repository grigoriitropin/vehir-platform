},{"instruction_type":"variable_declaration","variable_name":"ka","variable_type":"str","assignment_operation":"string","source_target":"awaiter"},{"instruction_type":"variable_declaration","variable_name":"kr","variable_type":"str","assignment_operation":"string","source_target":"result"},{"instruction_type":"variable_declaration","variable_name":"vtc","variable_type":"str","assignment_operation":"string","source_target":"tail-chain"},{"instruction_type":"function_invocation","invocation_name":"attach-numeric-value-towards-object","invocation_arguments":[{"kind":"var","value":"rec"},{"kind":"var","value":"kid"},{"kind":"var","value":"i"}]},{"instruction_type":"function_invocation","invocation_name":"attach-numeric-value-towards-object","invocation_arguments":[{"kind":"var","value":"rec"},{"kind":"var","value":"kk"},{"kind":"var","value":"kind"}]},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"rec"},{"kind":"var","value":"kd"},{"kind":"var","value":"vtc"}]},{"instruction_type":"function_invocation","invocation_name":"attach-numeric-value-towards-object","invocation_arguments":[{"kind":"var","value":"rec"},{"kind":"var","value":"ka"},{"kind":"var","value":"aw"}]},{"instruction_type":"function_invocation","invocation_name":"attach-numeric-value-towards-object","invocation_arguments":[{"kind":"var","value":"rec"},{"kind":"var","value":"kr"},{"kind":"var","value":"res"}]},{"instruction_type":"function_invocation","invocation_name":"append-element-extending-document-sequence","invocation_arguments":[{"kind":"var","value":"out"},{"kind":"var","value":"rec"}]},{"instruction_type":"variable_declaration","variable_name":"ni","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"ni","lhs":{"value":"i"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"record-schedul