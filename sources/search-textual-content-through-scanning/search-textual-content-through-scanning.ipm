{"build_type":"library","description":"Walk an enumerated package-universe entry list ({path,doc} objects via .next) and, for each whose RAW source file (read by path) contains the query substring, append its path string to the results array. Searches the actual file bytes (so it finds anything: function names, field values, TODO-style text), unlike grep which only matches instruction KINDs. Tail-recurses over .next. Reuses locate_named_member_inside_mapping, read_entire_file_into_string, string_contains_substring, encode_textual_payload_document_value, append_element_extending_document_sequence.","module_name":"search-textual-content-through-scanning","package_name":"search-textual-content-through-scanning","function_definitions":{"search-textual-content-through-scanning":{"return_type":"i64","parameter_definitions":[{"parameter_name":"node","parameter_type":"i64"},{"parameter_name":"query","parameter_type":"i64"},{"parameter_name":"results","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_path","variable_type":"str","assignment_operation":"string","source_target":"path"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"node"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"node"},{"kind":"var","value":"s_path"}],"result_assignment_variable":"pathn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"pathn"}],"result_assignment_variable":"path","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"retrieve-entire-document-inside-string","invocation_arguments":[{"kind":"var","value":"path"}],"result_assignment_variable":"raw","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"verify-string-contains-target-substring","invocation_arguments":[{"kind":"var","value":"raw"},{"kind":"var","value":"query"}],"result_assignment_variable":"hit","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"hit"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"encode-textual-payload-document-value","invocation_arguments":[{"kind":"var","value":"path"}],"result_assignment_variable":"ns","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-element-extending-document-sequence","invocation_arguments":[{"kind":"var","value":"results"},{"kind":"var","value":"ns"}]}],"branch_on_failure":[]},{"instruction_type":"field_read","struct":"json-tree-node","field":"next","base":"node","dest":"nxt"},{"instruction_type":"function_invocation","invocation_name":"search-textual-content-through-scanning","invocation_arguments":[{"kind":"var","value":"nxt"},{"kind":"var","value":"query"},{"kind":"var","value":"results"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}