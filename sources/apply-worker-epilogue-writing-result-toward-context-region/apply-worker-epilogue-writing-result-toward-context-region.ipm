{"build_type":"library","description":"Shared worker-runtime EPILOGUE (worker-runtime-FINAL A7): the single shared-library routine every worker references at completion. Given the worker's context pointer (its per-instance shared region) and its result value, it writes the result into the first slot of the region (A3: result delivered as flat bytes through the per-instance region), releases the worker's transient arena frontier, and EXITS the worker (A3: the exit IS the completion event). Referenced, never inlined (A7).","module_name":"apply-worker-epilogue-writing-result-toward-context-region","package_name":"apply-worker-epilogue-writing-result-toward-context-region","function_definitions":{"apply-worker-epilogue-writing-result-toward-context-region":{"return_type":"i64","parameter_definitions":[{"parameter_name":"context","parameter_type":"i64"},{"parameter_name":"value","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"array_write","base":"context","index":"zero","value":"value","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}