{"build_type":"library","description":"authoring sugar generator - full-IR passthrough: a statement already carrying an instruction_type key is a complete low-level instruction (raw invoke_computed_address, atomic, spawn, etc.); deep-copy it (so the source body is not reparented) and append the copy verbatim to the current instruction sequence g_cur_instr. One branch covers every special instruction with no per-op generator.","module_name":"append-verbatim-instruction-statement-preserving-fields","package_name":"append-verbatim-instruction-statement-preserving-fields","function_definitions":{"append-verbatim-instruction-statement-preserving-fields":{"return_type":"i64","parameter_definitions":[{"parameter_name":"stmt","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"global_read","dest":"instr","name":"g_cur_instr"},{"instruction_type":"function_invocation","invocation_name":"replicate-document-value-graph-structurally","invocation_arguments":[{"kind":"var","value":"stmt"}],"result_assignment_variable":"copy","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-element-extending-document-sequence","invocation_arguments":[{"kind":"var","value":"instr"},{"kind":"var","value":"copy"}]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}