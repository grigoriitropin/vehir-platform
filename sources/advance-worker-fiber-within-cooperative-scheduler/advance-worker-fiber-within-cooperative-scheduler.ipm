{"build_type":"library","description":"Advance function for the cooperative worker fiber kind (category 2). A worker has no recursion: in a single dispatch it reads its input from the fiber table input slot, brackets the arena (capture on entry, release on exit so the worker body's transient allocations are reclaimed), runs the clean worker body, stores the returned value into the fiber result slot, and calls completion routing -- which writes the result into the awaiter's child-result slot and re-readies it (the cooperative wake), or finalizes the scheduler result for a root worker. No clone, no eventfd, no global state for the per-worker result.","module_name":"advance-worker-fiber-within-cooperative-scheduler","package_name":"advance-worker-fiber-within-cooperative-scheduler","function_definitions":{"advance-worker-fiber-within-cooperative-scheduler":{"return_type":"i64","parameter_definitions":[{"parameter_name":"s","parameter_type":"i64"},{"parameter_name":"t","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"fifty","variable_type":"i64","assignment_operation":"literal","source_target":50},{"instruction_type":"variable_declaration","variable_name":"t8","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"*","target":"t8","lhs":{"value":"t"},"rhs":{"value":"eight"}},{"instruction_type"