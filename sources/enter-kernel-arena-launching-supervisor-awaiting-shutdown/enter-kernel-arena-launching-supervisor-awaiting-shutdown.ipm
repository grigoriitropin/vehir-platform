{"build_type":"library","description":"Real boot kernel entry, the GRUB-target loaded first by the boot launcher. Installs the handed memory as the fixed world arena, then reads its init configuration from the boot config file whose path the launcher passes as the second argument: the supervisor daemon path, the request to hand it, and the pidfile path. Records its own identity for the power button, launches the service supervisor as a separate child process, then parks with zero CPU on the shutdown signal. On shutdown it stops the supervisor child and returns for orderly teardown. All paths come from the boot config data, never embedded as literals.","module_name":"enter-kernel-arena-launching-supervisor-awaiting-shutdown","package_name":"enter-kernel-arena-launching-supervisor-awaiting-shutdown","function_definitions":{"enter-kernel-arena-launching-supervisor-awaiting-shutdown":{"return_type":"i64","parameter_definitions":[{"parameter_name":"env","parameter_type":"i64"},{"parameter_name":"config_path","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"negone","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"variable_declaration","variable_name":"sigterm","variable_type":"i64","assignment_operation":"literal","source_target":15},{"instruction_type":"variable_declaration","variable_name":"c40","variable_type":"i64","assignment_operation":"literal","source_target":40},{"instruction_type":"variable_declaration","variable_name":"k_init_path","variable_t