{"build_type":"library","description":"The living Vehir kernel entry. Acquires the handed resource arena, arms the shutdown signal as the soft power button, then parks indefinitely on it with zero CPU until the button is pressed, at which point it returns for orderly shutdown. Invoked by the loader with the firmware handoff env. Reboot is relaunching the loader; this is the persistent park-serve root.","module_name":"serve-parked-kernel-until-shutdown","package_name":"serve-parked-kernel-until-shutdown","function_definitions":{"serve-parked-kernel-until-shutdown":{"return_type":"i64","parameter_definitions":[{"parameter_name":"env","parameter_type":"i64"},{"parameter_name":"unused","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"negone","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"function_invocation","invocation_name":"install-fixed-arena-before-entering-kernel","invocation_arguments":[{"kind":"var","value":"env"},{"kind":"var","value":"zero"}],"result_assignment_variable":"ar","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"block-shutdown-signal-creating-descriptor","invocation_arguments":[],"result_assignment_variable":"sfd","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"await-shutdown-signal-descriptor-readiness","invocation_arguments":[{"kind":"var","value":"sfd"},{"kind":"var","value":"negone"}],"result_assignment_variable":"rn","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}