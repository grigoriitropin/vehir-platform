{"build_type":"library","description":"Open a child directory by name relative to an already-open parent directory fd via openat (syscall 257), read-only with O_DIRECTORY (flags=O_RDONLY|O_DIRECTORY=65536). Returns the new fd (negative = errno). The dirfd-relative analog of open_file_for_reading; lets getdents/fstatat/readlinkat run relative to the returned fd (O(1) dcache resolution) instead of re-resolving an absolute path from / on every call.","module_name":"acquire-directory-handle-relative-reading","package_name":"acquire-directory-handle-relative-reading","function_definitions":{"acquire-directory-handle-relative-reading":{"return_type":"i64","parameter_definitions":[{"parameter_name":"parent_fd","parameter_type":"i64"},{"parameter_name":"name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"flags","variable_type":"i64","assignment_operation":"literal","source_target":65536},{"instruction_type":"variable_declaration","variable_name":"fd","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"acquire-descriptor-opening-resolved-pathname-flags","invocation_arguments":[{"kind":"var","value":"parent_fd"},{"kind":"var","value":"name"},{"kind":"var","value":"flags"},{"kind":"var","value":"zero"}],"result_assignment_variable":"fd","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"fd"}}]}}}