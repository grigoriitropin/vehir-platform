{"build_type":"library","description":"For each call name in the calls array (index [i,n) computed from the array), check whether the function-index defines it (locate_named_member_inside_mapping(index, name) != 0). If not, the call is dangling: append a {function, call} record to out, with the calling function read from the module global g_dangling_fn_name (set by scan_each_function_for_dangling_calls before this is called; the >=4-param ABI leaves no room to thread it). Tail-recurses. Reuses count_members_inside_container_value, fetch_member_residing_within_sequence, locate_named_member_inside_mapping, append_dangling_call_record.","module_name":"check-function-calls-against-index","package_name":"check-function-calls-against-index","module_globals":[{"global_name":"g_dangling_fn_name","global_type":"i64","global_init":"0"}],"function_definitions":{"check-function-calls-against-index":{"return_type":"i64","parameter_definitions":[{"parameter_name":"calls","parameter_type":"i64"},{"parameter_name":"index","parameter_type":"i64"},{"parameter_name":"out","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"calls"}],"result_assignment_variable":"n","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"i"},"rhs":{"value":"n"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"fetch-member-residing-within-sequence","invocation_arguments":[{"kind":"var","value":"calls"},{"kind":"var","value":"i"}],"result_assignment_variable":"callnode","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"callnode"}],"result_assignment_variable":"callname","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"index"},{"kind":"var","value":"callname"}],"result_assignment_variable":"defn","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"defn"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"global_read","dest":"fnname","name":"g_dangling_fn_name"},{"instruction_type":"function_invocation","invocation_name":"append-dangling-invocation-record-inside-report","invocation_arguments":[{"kind":"var","value":"out"},{"kind":"var","value":"fnname"},{"kind":"var","value":"callname"}],"result_assignment_variable":"_a","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"i2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"i2","lhs":{"value":"i"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"check-function-calls-against-index","invocation_arguments":[{"kind":"var","value":"calls"},{"kind":"var","value":"index"},{"kind":"var","value":"out"},{"kind":"var","value":"i2"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}