{"build_type":"library","description":"A fiber t has finished. Read its result (table field 5) and its awaiter (field 3). If it has an awaiter, deliver the result into the awaiter child_result slot (field 4) and re-ready the awaiter by pushing it onto the ready stack -- the completion itself is the wake event, all in scheduler state, no eventfd. If awaiter is -1 the fiber is the root: store the result in slot 41 and set the done flag in slot 42.","module_name":"complete-fiber-routing-result-toward-awaiter","package_name":"complete-fiber-routing-result-toward-awaiter","function_definitions":{"complete-fiber-routing-result-toward-awaiter":{"return_type":"i64","parameter_definitions":[{"parameter_name":"s","parameter_type":"i64"},{"parameter_name":"t","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"fifty","variable_type":"i64","assignment_operation":"literal","source_target":50},{"instruction_type":"variable_declaration","variable_name":"fortyone","variable_type":"i64","assignment_operation":"literal","source_target":41},{"instruction_type":"variable_declaration","variable_name":"fo