{"build_type":"library","description":"Tail-recursive scan of c-string name over [i,len): at each hyphen (ASCII 45) it appends the token [g_name_token_start, i) to arr and advances g_name_token_start past the hyphen; at the end it appends the final token [g_name_token_start, len). The token-start cursor is a module global because the >=4-parameter ABI leaves no room to thread it; the wrapper resets it before each call (validation is sequential, one name at a time). Reuses append_substring_token_into_token_array.","module_name":"split-hyphenated-identifier-inside-token-array-iteration","package_name":"split-hyphenated-identifier-inside-token-array-iteration","module_globals":[{"global_name":"g_name_token_start","global_type":"i64","global_init":"0"}],"function_definitions":{"split-hyphenated-identifier-inside-token-array-iteration":{"return_type":"i64","parameter_definitions":[{"parameter_name":"name","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"},{"parameter_name":"len","parameter_type":"i64"},{"parameter_name":"arr","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"hyphen","variable_type":"i64","assignment_operation":"literal","source_target":45},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"i"},"rhs":{"value":"len"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"b","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"array_read","dest":"b","base":"name","index":"i","scale":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{