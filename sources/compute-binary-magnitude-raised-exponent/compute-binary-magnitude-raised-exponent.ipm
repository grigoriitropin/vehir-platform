{"build_type":"library","description":"Compute two raised to the given exponent (a binary magnitude) by TAIL-recursive doubling with an accumulator (the compiler permits only tail self-recursion). Call with accumulator one. Used to build contiguous low-bit affinity masks without a left-shift operator: two-to-the-k minus one is the lowest k set bits, and multiplying by two-to-the-offset shifts that block up.","module_name":"compute-binary-magnitude-raised-exponent","package_name":"compute-binary-magnitude-raised-exponent","function_definitions":{"compute-binary-magnitude-raised-exponent":{"return_type":"i64","parameter_definitions":[{"parameter_name":"exponent","parameter_type":"i64"},{"parameter_name":"accumulator","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"exponent"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"accumulator"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"e1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"-","target":"e1","lhs":{"value":"exponent"},"rhs":{"value":"one"}},{"instruction_type":"variable_declaration","variable_name":"a2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"*","target":"a2","lhs":{"value":"accumulator"},"rhs":{"value":"two"}},{"instruction_type":"function_invocation","invocation_name":"compute-binary-magnitude-raised-exponent","invocation_arguments":[{"kind":"var","value":"e1"},{"kind":"var","value":"a2"}],"result_assignment_variable":"rr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"rr"}}]}}}