{"build_type":"library","description":"Concise lens: walk a call's invocation_arguments as a json-tree-node linked list (node = first arg, follow .next), emitting each arg's 'value' string into args_out. Native .child/.next traversal — no fetch_member_residing_within_sequence index counting (O(n^2) + NULL-deref source). Caller passes the first child (invocation_arguments.child); 0 means no args. Tail-recursive on .next. Reuses locate_named_member_inside_mapping, encode_textual_payload_document_value, append_element_extending_document_sequence.","module_name":"render-concise-invocation-arguments-representation","package_name":"render-concise-invocation-arguments-representation","function_definitions":{"render-concise-invocation-arguments-representation":{"return_type":"i64","parameter_definitions":[{"parameter_name":"node","parameter_type":"i64"},{"parameter_name":"args_out","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"s_value","variable_type":"str","assignment_operation":"string","source_target":"value"},{"instruction_type":"variable_declaration","variable_name":"s_kind","variable_type":"str","assignment_operation":"string","source_target":"kind"},{"instruction_type":"variable_declaration","variable_name":"s_int","variable_type":"str","assignment_operation":"string","source_target":"int"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"node"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"node"},{"kind":"var","value":"s_value"}],"result_assignment_variable":"valn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"node"},{"kind":"var","value":"s_kind"}],"result_assignment_variable":"kind_n","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"kind_n"}],"result_assignment_variable":"kind_s","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"isint","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"kind_s"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"compare-paired-strings-octet-through-octet","invocation_arguments":[{"kind":"var","value":"kind_s"},{"kind":"var","value":"s_int"}],"result_assignment_variable":"isint","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"isint"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"fetch-number-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"valn"}],"result_assignment_variable":"numv","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"encode-integer-payload-document-value","invocation_arguments":[{"kind":"var","value":"numv"}],"result_assignment_variable":"snode","result_type":"i64"}],"branch_on_failure":[{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"valn"}],"result_assignment_variable":"avraw","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"encode-textual-payload-document-value","invocation_arguments":[{"kind":"var","value":"avraw"}],"result_assignment_variable":"snode","result_type":"i64"}]},{"instruction_type":"function_invocation","invocation_name":"append-element-extending-document-sequence","invocation_arguments":[{"kind":"var","value":"args_out"},{"kind":"var","value":"snode"}]},{"instruction_type":"field_read","struct":"json-tree-node","field":"next","base":"node","dest":"nxt"},{"instruction_type":"function_invocation","invocation_name":"render-concise-invocation-arguments-representation","invocation_arguments":[{"kind":"var","value":"nxt"},{"kind":"var","value":"args_out"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}