{"build_type":"library","description":"Return 1 if the NUL-terminated string `prefix` is a prefix of the NUL-terminated string `s` starting at index j (pass 0 to test from the start), else 0. Walks byte by byte: prefix exhausted (prefix[j]==0) = matched; a mismatch (or s ending first) = no match. Tail-recursive over j. Building block for substring search. Reuses nothing (pure byte reads).","module_name":"verify-string-starts-matching-prefix","package_name":"verify-string-starts-matching-prefix","function_definitions":{"verify-string-starts-matching-prefix":{"return_type":"i64","parameter_definitions":[{"parameter_name":"s","parameter_type":"i64"},{"parameter_name":"prefix","parameter_type":"i64"},{"parameter_name":"j","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"pc","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"array_read","dest":"pc","base":"prefix","index":"j","scale":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"pc"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"one"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"sc","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"array_read","dest":"sc","base":"s","index":"j","scale":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"sc"},"rhs":{"value":"pc"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"j2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"j2","lhs":{"value":"j"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"verify-string-starts-matching-prefix","invocation_arguments":[{"kind":"var","value":"s"},{"kind":"var","value":"prefix"},{"kind":"var","value":"j2"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}