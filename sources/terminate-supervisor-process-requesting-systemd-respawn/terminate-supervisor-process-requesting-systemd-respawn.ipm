{"build_type":"library","description":"Reload branch of the control handler: write a short acknowledgement to the control connection, close it, then exit_group. The supervisor is a systemd service with Restart=always and KillMode=mixed, so exiting makes systemd kill the remaining children and respawn the supervisor from the current binary -- a clean reload that picks up a new build without the operator calling systemctl.","module_name":"terminate-supervisor-process-requesting-systemd-respawn","package_name":"terminate-supervisor-process-requesting-systemd-respawn","function_definitions":{"terminate-supervisor-process-requesting-systemd-respawn":{"return_type":"i64","parameter_definitions":[{"parameter_name":"conn","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"ack","variable_type":"str","assignment_operation":"string","source_target":"reloading"},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"ack"}],"result_assignment_variable":"alen","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"1","arg1":"conn","arg2":"ack","arg3":"alen","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"wn"},{"instruction_type":"variable_declaration","variable_name":"t1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"3","arg1":"conn","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"cl"},{"instruction_type":"variable_declaration","variable_name":"t2","variable_type":"i64","assignment_op