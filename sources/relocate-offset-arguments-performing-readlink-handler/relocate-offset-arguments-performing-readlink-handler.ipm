{"build_type":"library","description":"Per-verb relocation handler for the readlink verb, migrated onto the shared overflow-safe bounds primitives so it no longer carries the old unsound buffer check. Reads the region-relative path offset from slot 257, the buffer offset from slot 258 and the buffer length from slot 259, each once into a local. Relocates the path through the string bounds primitive and the buffer through the overflow-safe buffer bounds primitive, and only when both relocations succeed performs the readlink module realization which writes the resolved length into result slot 260.","module_name":"relocate-offset-arguments-performing-readlink-handler","package_name":"relocate-offset-arguments-performing-readlink-handler","function_definitions":{"relocate-offset-arguments-performing-readlink-handler":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"i257","variable_type":"i64","assignment_operation":"literal","source_target":257},{"instruction_type":"variable_declaration","variable_name":"i258","variable_type":"i64","assignment_operation":"literal","source_target":258},{"instruction_type":"variable_declaration","variable_name":"i259","variable_type":"i64","assignment_operation":"literal","source_target":259},{"instruction_type":"array_read","dest":"pathoff","base":"base","index":"i257","scale":8},{"instruction_type":"array_read","dest":"bufoff","base":"base","index":"i258","scale":8},{"instruction_type":"array_read","dest":"bufsz","base":"base","index":"i259","scale":8},{"instruction_type":"function_invocation","invocation_name":"bounds-check-string-offset-returning-relocated-pointer","invocation_arguments":[{"kind":"var","value":"base"},{"kind":"var","value":"pathoff"}],"result_assignm