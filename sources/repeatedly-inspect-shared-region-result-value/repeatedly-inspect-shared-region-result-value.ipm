{"build_type":"library","description":"Zero-syscall tool-side: spin reading the inherited region result slot (260) until the kernel (separate process, polling the doorbell slot) writes a non-sentinel result. Pure memory reads + tail recursion - emits NO sys instruction and calls no primitive, so the compiled code contains zero syscall opcodes. The wait is cooperative-memory (the kernel side does the real blocking).","module_name":"repeatedly-inspect-shared-region-result-value","package_name":"repeatedly-inspect-shared-region-result-value","function_definitions":{"repeatedly-inspect-shared-region-result-value":{"return_type":"i64","parameter_definitions":[{"parameter_name":"region","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"i260","variable_type":"i64","assignment_operation":"literal","source_target":260},{"instruction_type":"variable_declaration","variable_name":"sentinel","variable_type":"i64","assignment_operation":"literal","source_target":-999},{"instruction_type":"array_read","dest":"cur","base":"region","index":"i260","scale":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"cur"},"rhs":{"value":"sentinel"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"repeatedly-inspect-shared-region-result-value","invocation_arguments":[{"kind":"var","value":"region"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}],"branch_on_failure":[{"instruction_type":"return_statement","return_payload":{"value":"cur"}}]}]}}}