{"build_type":"executable","description":"Child worker body for the parallel fan-out (a spawn entry, parameterless). Reads the shared fan-out region from global g_fanout_shared, atomically claims its index (fetch-add on the claim counter at slot 0), reads its input n (slot 10+idx) and its pre-allocated scheduler buffer (slot 20+idx). Runs the proven cooperative fiber scheduler entirely in that buffer (sum(n), zero global-arena allocation = no cross-thread race). Records result (slot 30+idx), OS thread id via gettid (slot 40+idx), and finally the done flag (slot 50+idx) last so the parent sees done only after result and tid (x86 TSO).","module_name":"worker-thread-computing-claimed-summation-toward-result-slots","package_name":"worker-thread-computing-claimed-summation-toward-result-slots","function_definitions":{"worker-thread-computing-claimed-summation-toward-result-slots":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"negone","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"variable_declaration","variable_name":"ten","variable_type":"i64","assignment_operation":"literal","source_target":10},{"instruction_type":"variable_declaration","variable_name":"twenty","variable_type":"i64","assignment_operation":"literal","source_target":20},{"instruction_type":"variable_declaration","variable_name":"thirty","variable_type":"i64","assignment_operation":"literal","source_target":30},{"instruction_type":"variable_declaration","variable_name":"forty","variable_type":"i64","assignment_operation":"literal","source_target":40},{"instruction_type":"variable_declaration","variable_name":"fortyone","variable_type":"i64","assignment_operation":"literal","source_target":41},{"instruction_type":"variable_declaration","variable_name":"fortytwo","variable_type":"i64","assignment_operation":"literal","source_target":42},{"instruction_type":"variable_declaration","variable_name":"fifty","variable_type":"i64","assignment_operation":"literal","source_target":50},{"instruction_type":"global_read","dest":"shared","name":"g_fanout_shared"},{"instruction_type":"atomic_fetch_add","result_assignment_variable":"idx","address":"shared","delta":"one"},{"instruction_type":"variable_declaration","variable_name":"nidx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"nidx","lhs":{"value":"ten"},"rhs":{"value":"idx"}},{"instruction_type":"array_read","dest":"n","base":"shared","index":"nidx","scale":8},{"instruction_type":"variable_declaration","variable_name":"bufidx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"bufidx","lhs":{"value":"twenty"},"rhs":{"value":"idx"}},{"instruction_type":"array_read","dest":"buf","base":"shared","index":"bufidx","scale":8},{"instruction_type":"array_write","base":"buf","index":"zero","value":"zero","scale":8},{"instruction_type":"array_write","base":"buf","index":"forty","value":"zero","scale":8},{"instruction_type":"array_write","base":"buf","index":"fortyone","value":"zero","scale":8},{"instruction_type":"array_write","base":"buf","index":"fortytwo","value":"zero","scale":8},{"instruction_type":"function_invocation","invocation_name":"allocate-fiber-inside-scheduler-table","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"zero"},{"kind":"var","value":"n"},{"kind":"var","value":"negone"}],"result_assignment_variable":"root","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-fiber-toward-scheduler-ready-stack","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"root"}],"result_assignment_variable":"_p","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"drive-fiber-scheduler-until-quiescent","invocation_arguments":[{"kind":"var","value":"buf"}],"result_assignment_variable":"_d","result_type":"i64"},{"instruction_type":"array_read","dest":"result","base":"buf","index":"fortyone","scale":8},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"186","arg1":"zero","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"tid"},{"instruction_type":"variable_declaration","variable_name":"ridx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"ridx","lhs":{"value":"thirty"},"rhs":{"value":"idx"}},{"instruction_type":"array_write","base":"shared","index":"ridx","value":"result","scale":8},{"instruction_type":"variable_declaration","variable_name":"tidx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"tidx","lhs":{"value":"forty"},"rhs":{"value":"idx"}},{"instruction_type":"array_write","base":"shared","index":"tidx","value":"tid","scale":8},{"instruction_type":"variable_declaration","variable_name":"didx","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"didx","lhs":{"value":"fifty"},"rhs":{"value":"idx"}},{"instruction_type":"array_write","base":"shared","index":"didx","value":"one","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}