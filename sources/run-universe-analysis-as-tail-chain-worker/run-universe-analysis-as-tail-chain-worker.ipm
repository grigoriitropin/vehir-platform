{"build_type":"library","description":"Tail-chain analysis worker: its single parameter IS the request {manifest, gen_dir}. Runs perform-universe-analysis-writing-results and RETURNS its verdict cstring {gate, identity, enforcement} up to the parent (the result channel), which reconcile surfaces in its MCP reply. UAF fix (typed origin): its verdict cstring is allocated in this worker's own (grown) arena; copy it into a standalone pool region before returning so it survives the launcher reaping the arena (grown chunks are now shared-reclaimed). The copy is done HERE, where the result is known to be a cstring, not in the type-blind tail-chain launcher.","module_name":"run-universe-analysis-as-tail-chain-worker","package_name":"run-universe-analysis-as-tail-chain-worker","function_definitions":{"run-universe-analysis-as-tail-chain-worker":{"return_type":"i64","parameter_definitions":[{"parameter_name":"request","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"k_manifest","variable_type":"str","assignment_operation":"string","source_target":"manifest"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"request"},{"kind":"var","value":"k_manifest"}],"result_assignment_variable":"manifest","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"k_gendir","variable_type":"str","assignment_operation":"string","source_target":"gen_dir"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"request"},{"kind":"var","value":"k_gendir"}],"result_assignment_variable":"gd_node","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"gd_node"}],"result_assignment_variable":"gen_dir","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"perform-universe-analysis-writing-results","invocation_arguments":[{"kind":"var","value":"manifest"},{"kind":"var","value":"gen_dir"}],"result_assignment_variable":"_r","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"copy-cstring-into-standalone-pool-region","invocation_arguments":[{"kind":"var","value":"_r"}],"result_assignment_variable":"verdict_c","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"verdict_c"}}]}}}