{"build_type":"library","description":"Return the byte offset of the first occurrence of the NUL-terminated needle in the NUL-terminated string at ptr (carry the running count in idx, pass 0 to start), or -1 if not found. Naive: test string_has_prefix at the current position; else advance ptr and idx by one and tail-recurse; stop at the haystack NUL. Mirrors string_contains_substring but returns the offset so callers can split for replacement. Reuses string_has_prefix.","module_name":"compute-substring-match-offset-within-string","package_name":"compute-substring-match-offset-within-string","function_definitions":{"compute-substring-match-offset-within-string":{"return_type":"i64","parameter_definitions":[{"parameter_name":"ptr","parameter_type":"i64"},{"parameter_name":"needle","parameter_type":"i64"},{"parameter_name":"idx","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"neg1","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"function_invocation","invocation_name":"verify-string-starts-matching-prefix","invocation_arguments":[{"kind":"var","value":"ptr"},{"kind":"var","value":"needle"},{"kind":"var","value":"zero"}],"result_assignment_variable":"hp","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"hp"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"idx"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"c","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"array_read","dest":"c","base":"ptr","index":"zero","scale":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"c"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"neg1"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"ptr2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"ptr2","lhs":{"value":"ptr"},"rhs":{"value":"one"}},{"instruction_type":"variable_declaration","variable_name":"idx2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"idx2","lhs":{"value":"idx"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"compute-substring-match-offset-within-string","invocation_arguments":[{"kind":"var","value":"ptr2"},{"kind":"var","value":"needle"},{"kind":"var","value":"idx2"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}