{"build_type":"library","description":"Normalize a tool result before serialization so the final response is always a well-formed JSON object: null result becomes a structured empty_result error, otherwise pass through. When the module toggle g_response_include_meta (declared here, default zero) is nonzero, also stamp a _meta timing envelope with epoch_sec and epoch_nsec from the wall clock. Default zero keeps deterministic gates and the self-hosting fixpoint byte-identical. The toggle is declared in this package so it resolves in the closure of every tool that emits.","module_name":"compose-final-structured-response-payload","package_name":"compose-final-structured-response-payload","function_definitions":{"compose-final-structured-response-payload":{"return_type":"i64","parameter_definitions":[{"parameter_name":"res","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"out","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"res"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"out","lhs":{"value":"res"},"rhs":{"value":"zero"}}],"branch_on_failure":[{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"err","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"s_code","variable_type":"str","assignment_operation":"string","source_target":"code"},{"instruction_type":"variable_declaration","variable_name":"s_codeval","variable_type":"str","assignment_operation":"string","source_target":"empty_result"},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"err"},{"kind":"var","value":"s_code"},{"kind":"var","value":"s_codeval"}]},{"instruction_type":"variable_declaration","variable_name":"s_error","variable_type":"str","assignment_operation":"string","source_target":"error"},{"instruction_type":"variable_declaration","variable_name":"s_errval","variable_type":"str","assignment_operation":"string","source_target":"tool produced no result object"},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"err"},{"kind":"var","value":"s_error"},{"kind":"var","value":"s_errval"}]},{"instruction_type":"alu_operation","operator":"+","target":"out","lhs":{"value":"err"},"rhs":{"value":"zero"}}]},{"instruction_type":"return_statement","return_payload":{"value":"out"}}]}}}