{"build_type":"executable","description":"Pre-flight generation validity check with fallback. Builds the path to the primary generation kernel-entry object (store/generations/N/bin/objlib/entry) and tests it opens; if it does, selects the primary generation, otherwise selects the fallback generation. This catches a missing or garbage-collected generation before the loader tries to boot it, since the in-process loader fail-hards on a missing object.","module_name":"select-existing-generation-otherwise-fallback","package_name":"select-existing-generation-otherwise-fallback","function_definitions":{"select-existing-generation-otherwise-fallback":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"k_store","variable_type":"str","assignment_operation":"string","source_target":"store"},{"instruction_type":"variable_declaration","variable_name":"k_entry","variable_type":"str","assignment_operation":"string","source_target":"entry"},{"instruction_type":"variable_declaration","variable_name":"k_primary","variable_type":"str","assignment_operation":"string","source_target":"primary"},{"instruction_type":"variable_declaration","variable_name":"k_fallback","variable_type":"str","assignment_operation":"string","source_target":"fallback"},{"instruction_type":"variable_declaration","variable_name":"k_gensub","variable_type":"str","assignment_operation":"string","source_target":"generations"},{"instruction_type":"variable_declaration","variable_name":"k_binsub","variable_type":"str","assignment_operation":"string","source_target":"bin"},{"instruction_type":"variable_declaration","variable_name":"k_objsub","variable_type":"str","assignment_operation":"string","sourc