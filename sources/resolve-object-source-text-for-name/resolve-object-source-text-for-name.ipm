{"build_type":"library","module_name":"resolve-object-source-text-for-name","package_name":"resolve-object-source-text-for-name","description":"The single byte-source seam of the runtime linker: given a package NAME, return the raw JSON text of its native object, or 0 if absent. Currently resolves the name to bytes by reading <g_ld_libdir>/<name> (with a ../../scratch fallback) -- the name==filename store. This is the one place that maps a name to object bytes, so switching the store to content-addressed (name -> hash -> objects/<hash>) is a change here only; the linker's place+patch stays untouched.","function_definitions":{"resolve-object-source-text-for-name":{"return_type":"i64","parameter_definitions":[{"parameter_name":"name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_dd_scratch","variable_type":"str","assignment_operation":"string","source_target":"../../scratch"},{"instruction_type":"global_read","dest":"libdir","name":"g_ld_libdir"},{"instruction_type":"function_invocation","invocation_name":"concatenate-library-directory-joining-package-identifier","invocation_arguments":[{"kind":"var","value":"libdir"},{"kind":"var","value":"name"}],"result_assignment_variable":"path","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"retrieve-entire-document-inside-string","invocation_arguments":[{"kind":"var","value":"path"}],"result_assignment_variable":"text","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"text"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"text"}],"result_assignment_variable":"tlen","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"tlen"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"concatenate-library-directory-joining-package-identifier","invocation_arguments":[{"kind":"var","value":"libdir"},{"kind":"var","value":"s_dd_scratch"}],"result_assignment_variable":"sdir","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"concatenate-library-directory-joining-package-identifier","invocation_arguments":[{"kind":"var","value":"sdir"},{"kind":"var","value":"name"}],"result_assignment_variable":"spath","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"retrieve-entire-document-inside-string","invocation_arguments":[{"kind":"var","value":"spath"}],"result_assignment_variable":"stext","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"stext"}],"result_assignment_variable":"stlen","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"stlen"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"alu_operation","operator":"+","target":"text","lhs":{"value":"stext"},"rhs":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"text"}}],"branch_on_failure":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}]}}}