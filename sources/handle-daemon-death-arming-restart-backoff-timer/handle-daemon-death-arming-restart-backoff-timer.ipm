{"build_type":"library","description":"Handle a service death event from the signal descriptor: read the siginfo record to consume the event, reap the dead child via wait4, increment the failure counter, then arm the restart backoff timer. Linear backoff: delay seconds equals the new failure count; if failures exceed nine the service is parked for 240 seconds and the failure counter resets (crash-limit, so a permanently broken service is not respawned forever). Reads and writes state through the supervisor context struct (signalfd slot 2, timerfd slot 3, failures slot 4, child_pid slot 5). No sleep, the delay is a timerfd event.","module_name":"handle-daemon-death-arming-restart-backoff-timer","package_name":"handle-daemon-death-arming-restart-backoff-timer","function_definitions":{"handle-daemon-death-arming-restart-backoff-timer":{"return_type":"i64","parameter_definitions":[{"parameter_name":"ctx","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"nine","variable_type":"i64","assignment_operation":"literal","source_target":9},{"instruction_type":"variable_declaration","variable_name":"c32","variable_type":"i64","assignment_operation":"literal","source_target":32},{"instruction_type":"variable_declaration","variable_name":"c128","variable_type":"i64","assignment_operation":"literal","source_target":128},{"instruction_type":"variable_declaration","variable_name":"parksec","variable_type":"i64","assignment_operation":"literal","source_target":240},{"instruction_type":"array_read","dest":"sigfd","base":"ctx","index":"two","scale":8},{"instruction_type":"array_read","dest":"tfd","base":"ctx","index":"three","scale":8},{"instruction_type":"array_read","dest":"failures","base":"ctx","index":"four","scale":8},{"instruction_type":"array_read","dest":"cpid","base":"ctx","index":"five","scale":8},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c128"}],"result_assignment_variable":"siginfo","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"0","arg1":"sigfd","arg2":"siginfo","arg3":"c128","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"rn"},{"instruction_type":"variable_declaration","variable_name":"t1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"61","arg1":"cpid","arg2":"zero","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"rp"},{"instruction_type":"variable_declaration","variable_name":"nf","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"nf","lhs":{"value":"failures"},"rhs":{"value":"one"}},{"instruction_type":"variable_declaration","variable_name":"delay","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"delay","lhs":{"value":"nf"},"rhs":{"value":"zero"}},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"nf"},"rhs":{"value":"nine"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"delay","lhs":{"value":"parksec"},"rhs":{"value":"zero"}},{"instruction_type":"alu_operation","operator":"+","target":"nf","lhs":{"value":"zero"},"rhs":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"array_write","base":"ctx","index":"four","value":"nf","scale":8},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c32"}],"result_assignment_variable":"its","result_type":"i64"},{"instruction_type":"array_write","base":"its","index":"two","value":"delay","scale":8},{"instruction_type":"variable_declaration","variable_name":"t2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"286","arg1":"tfd","arg2":"zero","arg3":"its","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"st"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}