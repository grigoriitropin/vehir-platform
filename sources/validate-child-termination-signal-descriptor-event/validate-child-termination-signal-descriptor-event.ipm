{"build_type":"executable","description":"Probe validating that a child process death is delivered as a poll event via signalfd (no blocking wait4, no sleep). Blocks SIGCHLD via rt_sigprocmask so it is not handled by default, creates a signalfd for SIGCHLD, then forks: the child exits immediately, the parent (in a helper) polls the signal descriptor, reads the siginfo, and reaps the child. Validates rt_sigprocmask, signalfd4, and the SIGCHLD as a poll event path needed for the event-driven supervisor.","module_name":"validate-child-termination-signal-descriptor-event","package_name":"validate-child-termination-signal-descriptor-event","function_definitions":{"validate-child-termination-signal-descriptor-event":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"negone","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"variable_declaration","variable_name":"sigchldmask","variable_type":"i64","assignment_operation":"literal","source_target":65536},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"eight"}],"result_assignment_variable":"mask","result_type":"i64"},{"instruction_type":"array_write","base":"mask","index":"zero","value":"sigchldmask","scale":8},{"instruction_type":"variable_declaration","variable_name":"t0","variable_