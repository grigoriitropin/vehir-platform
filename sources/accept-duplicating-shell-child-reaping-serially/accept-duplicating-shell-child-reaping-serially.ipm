{"build_type":"library","description":"Topology-only cutover loop (serial): accepts one connection, reads the command, forks a child that dup2s the connection onto stdout and in-process-loads the REAL shell dispatch entry with the command as argv index two, lets the shell resolve and execve the tool (direct syscalls, no gate needed), blocking-waits to reap, closes the connection, and tail-recurses. One connection at a time.","module_name":"accept-duplicating-shell-child-reaping-serially","package_name":"accept-duplicating-shell-child-reaping-serially","function_definitions":{"accept-duplicating-shell-child-reaping-serially":{"return_type":"i64","parameter_definitions":[{"parameter_name":"loopctx","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"six","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"variable_declaration","variable_name":"negone","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"array_read","dest":"lfd","base":"loopctx","index":"zero","scale":8},{"instruction_type":"array_read",