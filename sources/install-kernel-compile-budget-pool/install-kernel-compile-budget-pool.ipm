{"build_type":"library","description":"Create the kernel-owned shared memory pool from which forked compile child processes draw their transient memory, and publish its base address and size into the budget globals so the budgeted-compile wrapper knows the pool exists and where it lives. The reconcile orchestrator calls this once before the artifact loop. Only the base and size are published here; the parent never points its own allocator cursor at this pool, because the parent holds the resident universe and must keep allocating freely. Each forked child is the one that points its allocator at the pool. The pool size is a single literal here, the one knob that moves between a generous budget and the tight kernel budget.","module_name":"install-kernel-compile-budget-pool","package_name":"install-kernel-compile-budget-pool","function_definitions":{"install-kernel-compile-budget-pool":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"sz","variable_type":"i64","assignment_operation":"literal","source_target":67108864},{"instruction_type":"function_invocation","invocation_name":"allocate-anonymous-shared-mapping-region","invocation_arguments":[{"kind":"var","value":"sz"}],"result_assignment_variable":"region","result_type":"i64"},{"instruction_type":"global_write","name":"g_kernel_budget_pool_base","value":"region"},{"instruction_type":"global_write","name":"g_kernel_budget_pool_size","value":"sz"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}},"module_globals":[]}