{"build_type":"library","description":"The shell's exec substrate under the kernel (launch model, no fork/execve): given an operation NAME, reject it if it contains a '/' (path traversal), probe the store via the runtime linker's byte-source seam for the tool object, and if absent emit the structured unknown_op help with the live tool list. Otherwise resolve the NAME to a runtime code address via link-name-returning-address and invoke it in-process passing (2, [name, request_str, 0]) so the tool re-parses its own request as argv[1] and its output flows to the caller's stdout. Replaces the old execve-becomes-the-tool path; the op name is a key resolved by the linker, never a raw path.","module_name":"execute-pinned-helper-matching-operation-identifier","package_name":"execute-pinned-helper-matching-operation-identifier","function_definitions":{"execute-pinned-helper-matching-operation-identifier":{"return_type":"i64","parameter_definitions":[{"parameter_name":"argv0","parameter_type":"i64"},{"parameter_name":"op_name","parameter_type":"i64"},{"parameter_name":"request_str","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"sixteen","variable_type":"i64","assignment_operation":"literal","source_target":16},{"instruction_type":"variable_declaration","variable_name":"e_traverse","variable_type":"str","assignment_operation":"string","source_target":"op_name_has_path_separator"},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_argument