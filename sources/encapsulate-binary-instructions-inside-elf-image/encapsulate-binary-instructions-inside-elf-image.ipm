{"build_type":"library","description":"Wrap a machine-code buffer into an ELF64 image and write it to g_output_fd. Stable entry name consumed across the toolchain; byte layout lives in emit_elf_image / emit_elf_image_with_interpreter. Variant chosen from globals: if g_interp_path is set (non-zero), emit a thin ET_EXEC with a PT_INTERP program header pointing at that path (kernel auto-invokes the interpreter); else if g_emit_elf_type is 3, emit a position-independent ET_DYN/PIE (e_type 3, load 0, entry 120); else the default static ET_EXEC at base 0x400000 (e_type 2, load 0x400000, entry 0x400078) exactly as before. Code is PIC (rel32), so identical bytes run at any base.","module_name":"encapsulate-binary-instructions-inside-elf-image","package_name":"encapsulate-binary-instructions-inside-elf-image","module_globals":[{"global_name":"g_output_fd","global_type":"i64","global_init":"0"},{"global_name":"g_emit_elf_type","global_type":"i64","global_init":"0"},{"global_name":"g_interp_path","global_type":"i64","global_init":"0"}],"function_definitions":{"encapsulate-binary-instructions-inside-elf-image":{"return_type":"void","parameter_definitions":[{"parameter_name":"code","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"et_exec","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"exec_base","variable_type":"i64","assignment_operation":"literal","source_target":4194304},{"instruction_type":"variable_declaration","variable_name":"exec_entry","variable_type":"i64","assignment_operation":"literal","source_target":4194424},{"instruction_type":"variable_declaration","variable_name":"dyn_entry","variable_type":"i64","assignment_operation":"literal","source_target":120},{"instruction_type":"global_read","dest":"ip","name":"g_interp_path"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"ip"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"generate-elf-image-bearing-interpreter-pathname","invocation_arguments":[{"kind":"var","value":"code"},{"kind":"var","value":"ip"}]}],"branch_on_failure":[{"instruction_type":"global_read","dest":"et","name":"g_emit_elf_type"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"et"},"rhs":{"value":"three"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"produce-executable-elf-binary-payload","invocation_arguments":[{"kind":"var","value":"code"},{"kind":"var","value":"three"},{"kind":"var","value":"zero"},{"kind":"var","value":"dyn_entry"}]}],"branch_on_failure":[{"instruction_type":"function_invocation","invocation_name":"produce-executable-elf-binary-payload","invocation_arguments":[{"kind":"var","value":"code"},{"kind":"var","value":"et_exec"},{"kind":"var","value":"exec_base"},{"kind":"var","value":"exec_entry"}]}]}]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}