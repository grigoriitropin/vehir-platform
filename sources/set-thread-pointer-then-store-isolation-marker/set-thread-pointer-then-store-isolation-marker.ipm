{"build_type":"library","description":"Step-3 child worker for the per-thread isolation proof. Spawned with a context whose slot 4 holds this thread's own FS block. Sets its FS base to that block via arch_prctl, then global_write tls_probe_slot=222 (FS-relative -> writes into ITS block, not the parent's), then returns 99 (the clone trampoline delivers it into context[0] and rings the doorbell so the parent wakes). Proves the thread-local global is isolated per thread.","module_name":"set-thread-pointer-then-store-isolation-marker","package_name":"set-thread-pointer-then-store-isolation-marker","function_definitions":{"set-thread-pointer-then-store-isolation-marker":{"return_type":"i64","parameter_definitions":[{"parameter_name":"context","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"set_fs","variable_type":"i64","assignment_operation":"literal","source_target":4098},{"instruction_type":"variable_declaration","variable_name":"v222","variable_type":"i64","assignment_operation":"literal","source_target":222},{"instruction_type":"variable_declaration","variable_name":"ret99","variable_type":"i64","assignment_operation":"literal","source_target":99},{"instruction_type":"array_read","dest":"block","base":"context","index":"four","scale":8},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"158","arg1":"set_fs","arg2":"block","arg3":"zero","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"r_set"},{"instruction_type":"global_write","name":"tls_probe_slot","value":"v222"},{"instruction_type":"return_statement","return_payload":{"value":"ret99"}}]}}}