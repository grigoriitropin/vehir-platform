{"build_type":"library","description":"readlinkat (syscall 267) a symlink's target by name relative to an open directory fd; return it as a textual payload document value, or 0 on failure. readlinkat does not NUL-terminate, so the byte at the returned length is set to 0 before stringifying. Buffer allocated once into module global g_rellinkbuf and reused. The dirfd-relative analog of readlink_target_into_string. Reuses allocate_bytes_from_mmap_arena, encode_textual_payload_document_value.","module_name":"retrieve-relative-symlink-target-string","package_name":"retrieve-relative-symlink-target-string","module_globals":[{"global_name":"g_rellinkbuf","global_type":"i64","global_init":"0"}],"function_definitions":{"retrieve-relative-symlink-target-string":{"return_type":"i64","parameter_definitions":[{"parameter_name":"dirfd","parameter_type":"i64"},{"parameter_name":"name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"bufsize","variable_type":"i64","assignment_operation":"literal","source_target":4096},{"instruction_type":"variable_declaration","variable_name":"maxlen","variable_type":"i64","assignment_operation":"literal","source_target":4095},{"instruction_type":"global_read","dest":"buf","name":"g_rellinkbuf"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"buf"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"bufsize"}],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"global_write","name":"g_rellinkbuf","value":"buf"}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"resolve-relative-symbolic-target-buffer","invocation_arguments":[{"kind":"var","value":"dirfd"},{"kind":"var","value":"name"},{"kind":"var","value":"buf"},{"kind":"var","value":"maxlen"}],"result_assignment_variable":"rc","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"rc"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"array_write","base":"buf","index":"rc","value":"zero","scale":1},{"instruction_type":"function_invocation","invocation_name":"encode-textual-payload-document-value","invocation_arguments":[{"kind":"var","value":"buf"}],"result_assignment_variable":"ns","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"ns"}}]}}}