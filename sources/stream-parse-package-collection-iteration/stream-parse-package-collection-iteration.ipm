{"build_type":"library","description":"Walk a package-name sequence, and for each package fork a child that parses only that one package and writes its name to the shared index descriptor before exiting, while the parent reaps the child and recurses to the next. The output descriptor is held in a module global so the recursion carries only four register arguments. Because each parse happens in a child whose exit returns its arena to the operating system, the caller stays flat in memory no matter how many packages are streamed.","module_name":"stream-parse-package-collection-iteration","package_name":"stream-parse-package-collection-iteration","function_definitions":{"stream-parse-package-collection-iteration":{"return_type":"i64","parameter_definitions":[{"parameter_name":"i","parameter_type":"i64"},{"parameter_name":"n","parameter_type":"i64"},{"parameter_name":"names","parameter_type":"i64"},{"parameter_name":"root_str","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"dot","variable_type":"i64","assignment_operation":"literal","source_target":46},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"global_read","dest":"fd","name":"g_stream_index_descriptor"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"i"},"rhs":{"value":"n"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"fetch-member-residing-within-sequence","invocation_arguments":[{"kind":"var","value":"names"},{"kind":"var","value":"i"}],"result_assignment_variable":"name_n