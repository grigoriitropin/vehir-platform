{"build_type":"library","description":"Emit the hex-encoding read-file result window. Reads cursorv, eof, total, m from the packed ctxh array (slots 0..3), hex-renders the buffer window buf[0..m], and writes the result object {content, start_byte, next_cursor, eof, bytes_total}. Split out of extract-bounded-filesystem-content-window to keep that package under the 32768-byte injected-source limit.","module_name":"render-hexadecimal-window-result-payload","package_name":"render-hexadecimal-window-result-payload","function_definitions":{"render-hexadecimal-window-result-payload":{"return_type":"i64","parameter_definitions":[{"parameter_name":"buf","parameter_type":"i64"},{"parameter_name":"ctxh","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"s_content","variable_type":"str","assignment_operation":"string","source_target":"content"},{"instruction_type":"variable_declaration","variable_name":"s_startbyte","variable_type":"str","assignment_operation":"string","source_target":"start_byte"},{"instruction_type":"variable_declaration","variable_name":"s_nextcursor","variable_type":"str","assignment_operation":"string","source_target":"next_cursor"},{"instruction_type":"variable_declaration","variable_name":"s_eof","variable_type":"str","assignment_operation":"string","source_target":"eof"},{"instruction_type":"variable_declaration","variable_name":"s_total","variab