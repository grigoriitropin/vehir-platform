{"build_type":"executable","description":"Topology-only cutover test daemon: binds an abstract socket and serially serves each incoming command by forking a child that in-process-loads the REAL shell dispatch entry (argv0 is the real shell path so tool resolution works, the command is argv index two) which resolves and execve-s the named tool. The real shell as a kernel child. Real shell untouched on disk; this only forks it. No gate (topology-only, tools use direct syscalls).","module_name":"serve-socket-commands-forking-shell-child","package_name":"serve-socket-commands-forking-shell-child","function_definitions":{"serve-socket-commands-forking-shell-child":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"six","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"variable_declaration","variable_name":"c32","variable_type":"i64","assignment_operation":"literal","source_target":32},{"instruction_type":"variable_declarati