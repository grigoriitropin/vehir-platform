{"build_type":"library","description":"Allocate a fiber record in the scheduler table inside state buffer s and return its id. The table base is slot 50, stride 8 fields per fiber: 0 kind, 1 n, 2 pc, 3 awaiter, 4 child_result, 5 result. Slot 40 holds the fiber count. The new fiber starts pc 0, child_result 0, result 0, and records its awaiter (the fiber that awaits its reply, -1 for the root).","module_name":"allocate-fiber-inside-scheduler-table","package_name":"allocate-fiber-inside-scheduler-table","function_definitions":{"allocate-fiber-inside-scheduler-table":{"return_type":"i64","parameter_definitions":[{"parameter_name":"s","parameter_type":"i64"},{"parameter_name":"kind","parameter_type":"i64"},{"parameter_name":"n","parameter_type":"i64"},{"parameter_name":"awaiter","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"fifty","variable_type":"i64","assignment_operation":"literal","source_target":50},{"instruction_type":"variable_declaration","variable_name":"forty","variable_type":"i64","assignment_operation":"literal","source_target":40},{"instruction_type":"array_read","dest":"id","base":"s","index":"forty","scale":8},{"instruction_type":"variable_declaration","variable_name":"t8","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"*","target":"t8","lhs":{"value":"id"},"rhs":{"value":"eight"}},{"instruction_type":"variable_declaration","variable_name":"base","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"base","lhs":{"value":"t8"},"rhs":{"value":"fifty"}},{"instruction_type":"array_write","base":"s","index":"base","value":"kind","scale":8},{"instruction_type":"variable_declaration","variable_name":"b1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"b1","lhs":{"value":"base"},"rhs":{"value":"one"}},{"instruction_type":"array_write","base":"s","index":"b1","value":"n","scale":8},{"instruction_type":"variable_declaration","variable_name":"b2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"b2","lhs":{"value":"base"},"rhs":{"value":"two"}},{"instruction_type":"array_write","base":"s","index":"b2","value":"zero","scale":8},{"instruction_type":"variable_declaration","variable_name":"b3","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"b3","lhs":{"value":"base"},"rhs":{"value":"three"}},{"instruction_type":"array_write","base":"s","index":"b3","value":"awaiter","scale":8},{"instruction_type":"variable_declaration","variable_name":"b4","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"b4","lhs":{"value":"base"},"