{"build_type":"executable","module_name":"launch-kernel-objects-following-bootconfig","package_name":"launch-kernel-objects-following-bootconfig","description":"Boot-mode kernel launcher built as a normal tool. Reads the fixed boot config at /home/vehir/.vehir-boot.json carrying libdir and kernel_entry, then loads and links the kernel object closure by name and jumps to it, the kernel return value becoming the exit code. Sibling of run-thin-binary-from-its-manifest but driven by the boot configuration rather than a per-tool manifest; transitional Phase A vehicle for the eventual unified bare-name loader boot mode.","function_definitions":{"launch-kernel-objects-following-bootconfig":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"function_invocation","invocation_name":"establish-bootstrap-thread-arena","invocation_arguments":[],"result_assignment_variable":"__boot_arena","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"reserve-error-ring-buffer-at-fixed-address","invocation_arguments":[],"result_assignment_variable":"_ring","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"k_config","variable_type":"str","assignment_operation":"string","source_target":"config"},{"instruction_type":"variable_declaration","variable_name":"k_libdir","variable_type":"str","assignment_operation":"string","source_target":"libdir"},{"instruction_type":"variable_declaration","variable_name":"k_entry","variable_type":"str","assignment_operation":"string","source_target":"kernel_entry"},{"instruction_type":"variable_declaration","variable_name":"k_arena","variable_type":"str","assignment_operation":"string","source_target":"arena_bytes"},{"instruc