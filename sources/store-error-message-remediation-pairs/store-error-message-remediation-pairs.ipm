{"build_type":"library","description":"Central error catalog: every compiler error name maps to a human-readable message plus a mandatory remediation instruction. Data only; parsed at first use by the error reporter.","module_name":"store-error-message-remediation-pairs","package_name":"store-error-message-remediation-pairs","function_definitions":{"error_catalog_json_text":{"return_type":"str","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"catalog","variable_type":"str","assignment_operation":"string","source_target":"{\"compile_step_budget_exceeded\":{\"message\":\"function lowering exceeded the per-function compile step budget\",\"remediation\":\"simplify or split the deeply-nested or oversized function, or raise g_lowering_step_budget if the function is legitimately large\"},\"job_output_path_missing\":{\"message\":\"job document lacks output path\",\"remediation\":\"add an output key to the job JSON specifying the target binary path\"},\"package_file_exceeds_size_limit\":{\"message\":\"package file exceeds 32768-byte limit\",\"remediation\":\"split the module into multiple packages to stay under the 32768-byte limit\"},\"output_rename_failed\":{\"message\":\"rename of compiler output failed\",\"remediation\":\"ensure the output directory is writable and the destination file is not locked\"},\"duplicate_json_key\":{\"message\":\"duplicate key detected in object\",\"remediation\":\"remove redundant keys so every key name is unique within the JSON object\"},\"undeclared_variable\":{\"message\":\"instruction names an undeclared variable\",\"remediation\":\"define the variable using variable_declaration before referencing it in an instruction\"},\"package_parse_failed\":{\"message\":\"package failed to parse as valid JSON\",\"remediation\":\"correct the syntax errors in the .ipm file to satisfy JSON standards\"},\"package_not_an_object\":{\"message\":\"package top level is not a JSON object\",\"remediation\":\"ensure the .ipm file starts and ends with curly braces forming one object\"},\"wrong_type_for_key\":{\"message\":\"value for key has an incorrect JSON type\",\"remediation\":\"change the value type to match the requirement specified in the schema catalog\"},\"missing_required_key\":{\"message\":\"required key is absent\",\"remediation\":\"add the missing mandatory key as defined in the package schema\"},\"bad_catalog_requirement\":{\"message\":\"internal schema catalog requirement code is unknown\",\"remediation\":\"update the internal schema catalog of the compiler to use supported requirement codes\"},\"unknown_key\":{\"message\":\"object carries a key not listed in schema\",\"remediation\":\"remove the unknown key or register it in the official schema catalog\"},\"instruction_not_an_object\":{\"message\":\"execution instruction entry is not a JSON object\",\"remediation\":\"ensure every entry in the execution_instructions array is a JSON object\"},\"conditional_branch_form_conflict\":{\"message\":\"conditional branch must have exactly one form\",\"remediation\":\"declare either numeric_compare or string_equals but never both or neither\"},\"unknown_instruction_type\":{\"message\":\"instruction type is not recognized\",\"remediation\":\"set instruction_type to a supported instruction type like function_invocation\"},\"function_not_an_object\":{\"message\":\"function definition entry is not a JSON object\",\"remediation\":\"ensure every value in the function_definitions object is a JSON object\"},\"too_many_parameters\":{\"message\":\"function declares more than 4 parameters\",\"remediation\":\"reduce the parameter_definitions length to 4 or fewer to satisfy ABI constraints\"},\"parameter_not_an_object\":{\"message\":\"parameter definition entry is not a JSON object\",\"remediation\":\"ensure every entry in the parameter_definitions array is a JSON object\"},\"entry_not_an_object\":{\"message\":\"module global or struct entry is malformed\",\"remediation\":\"verify that every entry in module_globals or struct_definitions is an object\"},\"field_not_an_object\":{\"message\":\"struct definition field is malformed\",\"remediation\":\"ensure every field entry within struct_definitions is a JSON object\"},\"too_many_invocation_arguments\":{\"message\":\"function invocation passes more than 4 arguments\",\"remediation\":\"reduce the invocation_arguments length to 4 or fewer to satisfy ABI constraints\"},\"argument_value_wrong_type\":{\"message\":\"argument value has wrong type\",\"remediation\":\"ensure the value type matches the kind field in the invocation argument\"},\"argument_not_an_object\":{\"message\":\"invocation argument entry is not a JSON object\",\"remediation\":\"ensure every entry in the invocation_arguments array is a JSON object\"},\"bad_argument_kind\":{\"message\":\"bad argument kind\",\"remediation\":\"set the kind field of the argument to either var or int\"},\"orphan_result_key\":{\"message\":\"orphan result key\",\"remediation\":\"provide both result_type and result_assignment_variable together or neither\"},\"source_target_must_be_number\":{\"message\":\"source_target must be a number\",\"remediation\":\"provide a numeric value for source_target when assignment_operation is literal\"},\"source_target_must_be_string\":{\"message\":\"source_target must be a string\",\"remediation\":\"provide a string value for source_target when assignment_operation is string\"},\"bad_assignment_operation\":{\"message\":\"bad assignment_operation\",\"remediation\":\"set assignment_operation to either literal or string\"},\"self_call_not_in_tail_position\":{\"message\":\"self-recursive call is not in tail position\",\"remediation\":\"place self-recursive function_invocation calls only in the final tail position\"},\"raw_stderr_write_outside_reporter\":{\"message\":\"direct stderr write outside the error reporter package\",\"remediation\":\"route the message through report_error_and_count or report_error_and_exit instead of writing to file descriptor 2\"},\"exit_syscall_outside_allowlist\":{\"message\":\"exit syscall outside the allowed packages\",\"remediation\":\"return an error to the caller or use report_error_and_exit; only the reporter and the compiler driver may invoke syscall 60\"},\"unknown_error_name_at_call_site\":{\"message\":\"error name not present in the catalog\",\"remediation\":\"add the entry to error-message-catalog or fix the name passed to the reporter\"},\"unresolvable_error_name_argument\":{\"message\":\"error name argument is not a resolvable string literal\",\"remediation\":\"pass the error name as a string variable declared in the calling function or forward a function parameter\"},\"error_catalog_entry_invalid\":{\"message\":\"catalog entry violates the error message law\",\"remediation\":\"give the entry exactly two non-empty fields named message and remediation\"},\"error_catalog_function_missing\":{\"message\":\"module reports errors but has no error catalog\",\"remediation\":\"add the error-message-catalog package with the error_catalog_json_text function to the job\"},\"error_catalog_parse_failed\":{\"message\":\"error catalog text failed to parse\",\"remediation\":\"fix the catalog JSON string in error_catalog_json_text so it parses as one object\"},\"enforcement_data_parse_failed\":{\"message\":\"internal enforcement data failed to parse\",\"remediation\":\"fix the allowlist JSON constants in validate-error-reporting-exclusivity\"},\"hardcoded_path\":{\"message\":\"string literal contains a hardcoded absolute path\",\"remediation\":\"resolve paths at runtime from the job file, config, or the executable location; never embed an absolute path in a package\"},\"duplicate_function_body\":{\"message\":\"two functions have byte-identical bodies\",\"remediation\":\"extract the shared logic into one function and call it from both; never duplicate a function body\"},\"duplicate_function_definition\":{\"message\":\"function name is defined in more than one package\",\"remediation\":\"ensure every function name is defined in exactly one package across the universe\"},\"unknown_target_package\":{\"message\":\"target package name not found in universe\",\"remediation\":\"verify that the target package exists in one of the provided root directories\"},\"unresolved_function\":{\"message\":\"called function is not defined in any known package\",\"remediation\":\"add the missing package to one of the root directories so that the function can be resolved\"},\"package_must_define_one_function\":{\"message\":\"package function_definitions must contain exactly one function\",\"remediation\":\"split the package so it defines exactly one function; one function equals one package\"},\"native_object_missing\":{\"message\":\"native object file for a required symbol was not found in the lib directory\",\"remediation\":\"ensure every relocation target has an object file named by its symbol in the loader lib directory\"},\"native_symbol_unresolved\":{\"message\":\"relocation target symbol is not present in the loaded closure\",\"remediation\":\"ensure the symbol is defined by some object reachable from the entry, or fix the relocation target name\"},\"view_input_missing_envelope\":{\"message\":\"view input lacks the output or source envelope\",\"remediation\":\"wrap the package as an object with an output path and a source full package before passing it to view\"},\"op_name_has_path_separator\":{\"message\":\"shell op name contains a path separator\",\"remediation\":\"pass a bare gen-pinned tool name as the op; the shell resolves it inside its own bin directory and never accepts a raw path\"},\"op_exec_failed\":{\"message\":\"shell could not execve the pinned tool for the op\",\"remediation\":\"ensure a gen-pinned binary named by the op exists in the bin directory of the shell\"},\"tool_self_description_did_not_derive\":{\"message\":\"a build artifact entry function was not found in its package so its self-description contract could not be derived\",\"remediation\":\"ensure the artifact entry names a function defined in the package named by its target so reconcile can derive the tool contract from the parsed package\"},\"raw_argv_access_outside_runtime_entry\":{\"message\":\"function reads the raw process argv outside the runtime seed\",\"remediation\":\"obtain the request via parse_argument_vector_json_request; only the shell and the loader may read raw argv\"},\"raw_stdin_read_outside_runtime_entry\":{\"message\":\"function calls read_all_of_stdin outside the runtime seed and the allowlisted compiler entries\",\"remediation\":\"take the request from argv via parse_argument_vector_json_request; a tool entry must not read stdin\"},\"name_policy_violation\":{\"message\":\"name violates the naming policy\",\"remediation\":\"rename so every hyphen or underscore separated word has at least five letters or is an allowlisted abbreviation and the name has at least five such words\"},\"linker_shelf_not_established\":{\"message\":\"the runtime name-to-address linker was invoked before the shared code region existed\",\"remediation\":\"ensure the loader has established the code region (g_ld_region) before calling link-name-returning-address; it must run inside already-loaded code, not from a cold start\"},\"linked_name_absent_from_map\":{\"message\":\"a package name was imported by the runtime linker but did not appear in the name-to-base map afterward\",\"remediation\":\"verify the named object exists in the loader libdir and that import-named-object-inside-closure-environment placed it; a truly missing object should surface as native_object_missing first\"},\"diagnostic_linker_region_null\":{\"message\":\"linker diagnostic: a required linker pointer was null\",\"remediation\":\"diagnostic guard; identifies which loader state (region/map/libdir/name) was null when link-name-returning-address ran\"},\"diagnostic_linker_map_null\":{\"message\":\"linker diagnostic: a required linker pointer was null\",\"remediation\":\"diagnostic guard; identifies which loader state (region/map/libdir/name) was null when link-name-returning-address ran\"},\"diagnostic_linker_libdir_null\":{\"message\":\"linker diagnostic: a required linker pointer was null\",\"remediation\":\"diagnostic guard; identifies which loader state (region/map/libdir/name) was null when link-name-returning-address ran\"},\"diagnostic_linker_name_null\":{\"message\":\"linker diagnostic: a required linker pointer was null\",\"remediation\":\"diagnostic guard; identifies which loader state (region/map/libdir/name) was null when link-name-returning-address ran\"},\"worklist_overflow\":{\"message\":\"lowering worklist stack exceeded its fixed capacity\",\"remediation\":\"increase the worklist buffer size in push-lowering-task-onto-worklist-stack or reduce the nesting depth of the function being lowered\"},\"cas_content_key_mismatch\":{\"message\":\"content-addressed store admit produced a file whose content sha256 does not equal its key name\",\"remediation\":\"the (key,data) pair passed to introduce-object-payload-towards-store is inconsistent; the key must be the sha256 of the exact data bytes -- fix the caller that derived the key, do not write content under a mismatched name\"},\"function-absent-about-package-target\":{\"message\":\"target function not found in package\",\"remediation\":\"verify the function name exists in the package function_definitions and is spelled correctly\"},\"request-bearer-fields-missing-about-editor\":{\"message\":\"tool request is missing required fields\",\"remediation\":\"provide the required fields as documented in the tool contract: path, function, and body or splice_at with splice_with\"},\"requested-operation-unavailable\":{\"message\":\"the requested tool was not found\",\"remediation\":\"call {help: null} to list all available tools, or {help: {tool: name}} for a specific tool's full contract (entry, calls, description)\"},\"package-source-file-not-found\":{\"message\":\"package source file could not be read\",\"remediation\":\"verify the path points to an existing .ipm file within the current sources directory\"},\"edit-file-old-not-found\":{\"message\":\"the old string was not found in the file\",\"remediation\":\"verify the old string exists in the file exactly as typed; use read-file to inspect the current content\"},\"edit-file-read-failed\":{\"message\":\"could not read the file\",\"remediation\":\"verify the path points to an existing readable file\"},\"edit-file-write-failed\":{\"message\":\"could not write the target file\",\"remediation\":\"verify the parent directory exists and is writable\"},\"edit-file-cas-blocked\":{\"message\":\"raw file tools cannot edit .ipm package sources\",\"remediation\":\"use the specialized package tools (edit, expand-package) or pass emergency flag if those tools are unavailable\"},\"write-file-cas-refused\":{\"message\":\"write target is outside the current generation directory\",\"remediation\":\"ensure the path is under the current generation root\"},\"write-file-open-failed\":{\"message\":\"could not open the target for writing\",\"remediation\":\"verify the parent directory exists; create it with make-directory first\"},\"read-file-bad-params\":{\"message\":\"read-file request is missing or has bad parameters\",\"remediation\":\"provide a valid request with a path field pointing to an existing file\"},\"read-file-open-failed\":{\"message\":\"could not open the file for reading\",\"remediation\":\"verify the path points to an existing readable file; use list-directory to check what exists\"},\"read-file-lseek-failed\":{\"message\":\"could not seek within the file\",\"remediation\":\"verify the cursor value is within the file bounds; this is usually a kernel issue\"},\"read-file-read-failed\":{\"message\":\"could not read bytes from the file\",\"remediation\":\"verify the file is readable and not corrupted\"},\"read-file-not-found\":{\"message\":\"the file does not exist\",\"remediation\":\"verify the path points to an existing file; use list-directory to see what files are available\"},\"package-source-requires-specialized-tool\":{\"message\":\"this path ends in .ipm so it is an IPM package source — use the specialized package tools (edit, expand-package, read-fn, read-map, view-full-package-as-concise) or pass the emergency flag if those tools are broken or unavailable\",\"remediation\":\"use a specialized package inspection tool, or set emergency to true only when those tools are broken or unavailable\"},\"rename-package-missing-fields\":{\"message\":\"rename-package request is missing required fields\",\"remediation\":\"provide old, new, roots where old is the current package name, new is the target name, and roots is an array of source directories\"},\"rename-package-not-found\":{\"message\":\"the package to rename was not found\",\"remediation\":\"verify the old package name exists in the sources directory\"},\"rename-package-cas-refused\":{\"message\":\"rename target is outside the current generation directory\",\"remediation\":\"ensure the rename target path is under the current generation root\"},\"rename-function-missing-fields\":{\"message\":\"rename-function request is missing required fields\",\"remediation\":\"provide from, to, roots where from is the current function name and to is the target name\"},\"list-directory-missing-fields\":{\"message\":\"directory listing request is missing required fields\",\"remediation\":\"provide a valid request with a path field pointing to an existing directory\"},\"expand-package-build-failed\":{\"message\":\"function body build failed\",\"remediation\":\"verify the concise function definitions are valid — check name, return type, and valid instruction objects\"},\"expand-package-already-exists\":{\"message\":\"a package already exists at this path\",\"remediation\":\"choose a different path or delete the existing package first\"},\"reconcile-disabled\":{\"message\":\"reconcile is not enabled in configuration\",\"remediation\":\"set enabled to 1 in etc/reconcile/reconcile.json\"},\"reconcile-manifest-not-found\":{\"message\":\"declared-build-state manifest file was not found\",\"remediation\":\"ensure active field in reconcile.json names an existing file\"},\"reconcile-manifest-invalid\":{\"message\":\"declared-build-state manifest could not be parsed\",\"remediation\":\"verify the manifest is valid JSON\"},\"reconcile-missing-field\":{\"message\":\"required field missing from manifest\",\"remediation\":\"ensure roots, root, compiler_target, artifacts are present\"},\"reconcile-policy-gate\":{\"message\":\"policy violations block the build\",\"remediation\":\"fix violations listed in the enforcement report\"},\"reconcile-analysis-failed\":{\"message\":\"analysis phase returned no result\",\"remediation\":\"check the error ring for compiler errors\"},\"list-directory-not-found\":{\"message\":\"the directory does not exist or is not accessible\",\"remediation\":\"verify the path points to an existing directory\"},\"make-directory-missing-fields\":{\"message\":\"make-directory request is missing required fields\",\"remediation\":\"provide a path to the directory to create\"},\"make-directory-failed\":{\"message\":\"mkdir syscall failed\",\"remediation\":\"verify the parent directory exists and is writable\"},\"render-package-concise-missing-fields\":{\"message\":\"render-package-concise request is missing required fields\",\"remediation\":\"provide a path to an .ipm package file\"},\"search-text-missing-fields\":{\"message\":\"search-text-in-package-sources request is missing required fields\",\"remediation\":\"provide a query string and either roots (array of source directories) or files (array of file paths)\"},\"export-generation-missing-fields\":{\"message\":\"export-generation request is missing required fields\",\"remediation\":\"provide gen_dir, dst_root, dst_gen_dir, and current_target as strings\"},\"find-symbol-callers-missing-fields\":{\"message\":\"find-symbol-callers request is missing required fields\",\"remediation\":\"provide symbol as a string and roots as an array of source directories\"},\"dependency-graph-missing-fields\":{\"message\":\"dependency-graph request is missing required fields\",\"remediation\":\"provide roots as an array of source directories; each root must end with /\"},\"dependency-graph-path-not-found\":{\"message\":\"the requested root directory was not found\",\"remediation\":\"verify the path exists and is a directory ending with /\"},\"rename-target-present-in-declared-build-state\":{\"message\":\"the rename target is present in the declared build state manifest\",\"remediation\":\"update the target name in the declared build state manifest before renaming the package, or re-run reconcile after the rename to regenerate\"},\"rename-batch-missing-fields\":{\"message\":\"rename-batch request is missing required fields\",\"remediation\":\"provide map, roots where map is old_name to new_name pairs and roots is source directories\"},\"unknown_tool\":{\"message\":\"the requested tool was not found\",\"remediation\":\"check the tool name spelling and call help to list all available tools\"},\"empty_request\":{\"message\":\"help was called with an empty request\",\"remediation\":\"provide a valid JSON request object with an optional tool member\"},\"bad_request\":{\"message\":\"help could not parse the request JSON\",\"remediation\":\"ensure the request is a valid JSON object\"},\"tool_policy_missing\":{\"message\":\"tool-policy.json could not be loaded or parsed\",\"remediation\":\"verify the current generation has a valid bin/tool-policy.json file; run reconcile to regenerate it\"},\"read-file-missing-path\":{\"message\":\"read-file request is missing the required path field\",\"remediation\":\"provide path as a non-empty string naming an existing readable file\"},\"read-file-unknown-field\":{\"message\":\"read-file request contains an unrecognized field\",\"remediation\":\"remove the field or use one of path, cursor, budget, line_base, encoding, raw, emergency\"},\"read-file-field-type-invalid\":{\"message\":\"read-file request field has an invalid JSON type\",\"remediation\":\"provide path and encoding as strings; cursor, budget, line_base, and raw as integers; and emergency as a boolean\"},\"read-file-field-range-invalid\":{\"message\":\"read-file request field value is outside its permitted range\",\"remediation\":\"use a non-negative cursor and line_base, budget from 1 through 1048576, and raw as 0 or 1\"},\"read-file-encoding-invalid\":{\"message\":\"read-file encoding is not supported\",\"remediation\":\"omit encoding for text output or set encoding to text or hex\"},\"tool-request-envelope-invalid\":{\"message\":\"tool request must be a valid mapping object\",\"remediation\":\"send one JSON object containing exactly one public tool entry\"},\"tool-request-root-count-invalid\":{\"message\":\"tool request must contain exactly one root entry\",\"remediation\":\"remove extra root entries or add the single missing tool entry\"},\"tool-request-entry-unavailable\":{\"message\":\"the requested entry is not a public tool in the running generation\",\"remediation\":\"call help to list the public tool entries and use one exact entry name\"},\"tool-request-arguments-not-object\":{\"message\":\"tool request arguments must be an object or null for an empty request\",\"remediation\":\"place the tool fields inside one JSON object under the tool entry\"},\"tool-request-contract-invalid\":{\"message\":\"the running generation does not provide a usable generated request contract\",\"remediation\":\"reconcile the declared build state and fix automatic contract generation before invoking the tool\"},\"tool-request-unknown-field\":{\"message\":\"tool request contains a field not present in its generated contract\",\"remediation\":\"remove the field or use help to inspect the automatically generated accepted fields\"},\"tool-request-required-field-missing\":{\"message\":\"tool request omits a field marked required by its generated contract\",\"remediation\":\"add the missing field shown in detail using the name reported by help\"},\"render-package-concise-invalid-source\":{\"message\":\"package cannot be rendered because its instruction graph violates the canonical IPM schema\",\"remediation\":\"correct the reported instruction types, required fields, field types, and value-wrapper shapes before requesting concise rendering\"},\"package-branch-depth-exceeded\":{\"message\":\"package conditional branch nesting exceeds the supported validation and compilation depth\",\"remediation\":\"split nested control flow into helper functions so no instruction block exceeds six conditional branch levels\"}}"},{"instruction_type":"return_statement","return_payload":{"value":"catalog"}}]}}}