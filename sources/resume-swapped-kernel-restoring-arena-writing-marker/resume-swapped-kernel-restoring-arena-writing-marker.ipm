{"build_type":"library","description":"Minimal swap-target entry, kernel-root-shaped (params env, config): reads the arena base from the boot envelope (slot 0), restores the kernel globals from the process table that lives at that base (the in-process-swap path -- the arena and table persist across the loader re-invocation, only the code-region globals are fresh-zero), then writes the RESTORED arena cursor into table slot 10 so the swapping caller can confirm both that this entry ran via a loader re-invocation AND that it saw the preserved arena and restored its state. Used by prove-second-loader-invocation-preserves-shared-arena.","module_name":"resume-swapped-kernel-restoring-arena-writing-marker","package_name":"resume-swapped-kernel-restoring-arena-writing-marker","function_definitions":{"resume-swapped-kernel-restoring-arena-writing-marker":{"return_type":"i64","parameter_definitions":[{"parameter_name":"env","parameter_type":"i64"},{"parameter_name":"cfg","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"ten","variable_type":"i64","assignment_operation":"literal","source_target":10},{"instruction_type":"array_read","dest":"base","base":"env","index":"zero","scale":8},{"instruction_type":"function_invocation","invocation_name":"restore-kernel-globals-using-process-table","invocation_arguments":[{"kind":"var","value":"base"}],"result_assignment_variable":"initpid","result_type":"i64"},{"instruction_type":"global_read","dest":"cur","name":"arena_cursor_address"},{"instruction_type":"array_write","base":"base","index":"ten","value":"cur","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}