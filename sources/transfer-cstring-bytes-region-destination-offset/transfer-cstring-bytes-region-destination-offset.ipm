{"build_type":"library","description":"Copies a null-terminated C string from a source pointer into the shared region at a chosen destination offset, reading the source from index zero while writing at destination offset plus the running index, including the terminating null. Unlike the older copy helper this decouples the source index from the region index, so two distinct strings can be staged at two different region offsets at the same time. Args are source pointer, region base, destination offset, and the running source index (caller passes zero).","module_name":"transfer-cstring-bytes-region-destination-offset","package_name":"transfer-cstring-bytes-region-destination-offset","function_definitions":{"transfer-cstring-bytes-region-destination-offset":{"return_type":"i64","parameter_definitions":[{"parameter_name":"src","parameter_type":"i64"},{"parameter_name":"region","parameter_type":"i64"},{"parameter_name":"dstoff","parameter_type":"i64"},{"parameter_name":"srcidx","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"array_read","dest":"b","base":"src","index":"srcidx","scale":1},{"instruction_type":"variable_declaration","variable_name":"wi","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"wi","lhs":{"value":"dstoff"},"rhs":{"value":"srcidx"}},{"instruction_type":"array_write","base":"region","index":"wi","value":"b","scale":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"b"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[{"instruction_type":"variable_declaration","variable_name":"ni","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"ni","lhs":{"value":"srcidx"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"transfer-cstring-bytes-region-destination-offset","invocation_arguments":[{"kind":"var","value":"src"},{"kind":"var","value":"region"},{"kind":"var","value":"dstoff"},{"kind":"var","value":"ni"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}