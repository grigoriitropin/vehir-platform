{"build_type":"library","description":"Hard gate for the law 'one function = one package': given a parsed package document and its source path, counts the entries of function_definitions and, when the count is not exactly one, reports package_must_define_one_function against the path and returns one violation; zero otherwise. Wired into the per-package validation pass so a multi-function package fails the build.","module_name":"check-single-function-across-package-policy","package_name":"check-single-function-across-package-policy","function_definitions":{"check-single-function-across-package-policy":{"return_type":"i64","parameter_definitions":[{"parameter_name":"pkg","parameter_type":"i64"},{"parameter_name":"path","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"k_fns","variable_type":"str","assignment_operation":"string","source_target":"function_definitions"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"pkg"},{"kind":"var","value":"k_fns"}],"result_assignment_variable":"fns","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"fns"}],"result_assignment_variable":"count","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"count"},"rhs":{"value":"one"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"name_multi","variable_type":"str","assignment_operation":"string","source_target":"package_must_define_one_function"},{"instruction_type":"function_invocation","invocation_name":"report-error-together-bearing-count","invocation_arguments":[{"kind":"var","value":"name_multi"},{"kind":"var","value":"path"}]},{"instruction_type":"return_statement","return_payload":{"value":"one"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}