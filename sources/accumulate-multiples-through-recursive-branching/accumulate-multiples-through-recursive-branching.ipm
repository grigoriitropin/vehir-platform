{"build_type":"library","description":"Test function exercising intra-function control flow for the object linker: recurses while n>0, adding 6 to acc each step, returning acc at the base case. Compiled in object-emit mode this produces BOTH local fixups (the conditional_branch jump targets, resolved inside the object) and a self-call (its own name, also local) plus is reached by an external call from the entry. It is the first object-emit test that drives the resolve_local_fixups_keep_external in-object patch path.","module_name":"accumulate-multiples-through-recursive-branching","package_name":"accumulate-multiples-through-recursive-branching","function_definitions":{"accumulate-multiples-through-recursive-branching":{"return_type":"i64","parameter_definitions":[{"parameter_name":"n","parameter_type":"i64"},{"parameter_name":"acc","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"six","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"n"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"n2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"-","target":"n2","lhs":{"value":"n"},"rhs":{"value":"one"}},{"instruction_type":"variable_declaration","variable_name":"acc2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"acc2","lhs":{"value":"acc"},"rhs":{"value":"six"}},{"instruction_type":"function_inv