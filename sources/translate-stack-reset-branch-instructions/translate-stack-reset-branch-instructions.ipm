{"build_type":"library","description":"Lowering handler for the jump_to_address_resetting_stack instruction: a no-return control transfer that sets the stack pointer to a runtime value and jumps to a runtime address. Emits a single jump_reset low-op carrying the address and stack variable names; the renderer turns it into mov rsp,<stack>; jmp <address>. Used by the loader to enter a freshly-linked program on the kernel-provided stack (PT_INTERP stage). No arguments, no result.","module_name":"translate-stack-reset-branch-instructions","package_name":"translate-stack-reset-branch-instructions","function_definitions":{"translate-stack-reset-branch-instructions":{"return_type":"void","parameter_definitions":[{"parameter_name":"inst","parameter_type":"i64"},{"parameter_name":"ops","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"k_address","variable_type":"str","assignment_operation":"string","source_target":"address"},{"instruction_type":"variable_declaration","variable_name":"k_stack","variable_type":"str","assignment_operation":"string","source_target":"stack"},{"instruction_type":"variable_declaration","variable_name":"k_jump_reset","variable_type":"str","assignment_operation":"string","source_target":"jump_reset"},{"instruction_type":"function_invocation","invocation_name":"extract-instruction-field-string-value","invocation_arguments":[{"kind":"var","value":"inst"},{"kind":"var","value":"k_address"}],"result_assignment_variable":"addr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"extract-instruction-field-string-value","invocation_arguments":[{"kind":"var","value":"inst"},{"kind":"var","value":"k_stack"}],"result_assignment_variable":"stk","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"initialize-native-primitive-operation-mapping","invocation_arguments":[{"kind":"var","value":"ops"},{"kind":"var","value":"k_jump_reset"}],"result_assignment_variable":"op","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-object","invocation_arguments":[{"kind":"var","value":"op"},{"kind":"var","value":"k_address"},{"kind":"var","value":"addr"}]},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-object","invocation_arguments":[{"kind":"var","value":"op"},{"kind":"var","value":"k_stack"},{"kind":"var","value":"stk"}]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}