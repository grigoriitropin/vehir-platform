{"build_type":"library","description":"Relocation primitive for a region-relative NUL-terminated string argument. Takes the channel base pointer and a region-relative offset. Fails closed returning zero when the offset is negative or when the offset exceeds the last valid region index. Otherwise returns the absolute pointer base plus offset. Only the start of the string is bounded, an unterminated string over-reads to the mapping edge where it faults and the path bytes are never returned to the tool, so the over-read is contained. Zero is an unambiguous deny sentinel.","module_name":"bounds-check-string-offset-returning-relocated-pointer","package_name":"bounds-check-string-offset-returning-relocated-pointer","function_definitions":{"bounds-check-string-offset-returning-relocated-pointer":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"},{"parameter_name":"off","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"sizem1","variable_type":"i64","assignment_operation":"literal","source_target":16383},{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"ptr","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"off"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":1}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"sizem1"},"rhs":{"value":"off"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"deny","variable_type":"i64","assignment_operation":"literal","source_target":1}],"branch_on_failure":[]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"deny"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"ptr","lhs":{"value":"base"},"rhs":{"value":"off"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"ptr"}}]}}}