{"build_type":"executable","description":"Child worker (a spawn entry, parameterless) for the real wait/wake floor proof. Reads its write-fd and input from globals g_channel_write_fd and g_channel_child_input (shared via CLONE_VM), computes result = input * 2, writes the 8-byte result to the pipe write-fd, and returns (its completion). The write is what wakes the parent that is blocked reading the pipe -- completion delivers the result through the channel, no futex and no eventfd.","module_name":"child-thread-computing-result-writing-toward-channel","package_name":"child-thread-computing-result-writing-toward-channel","function_definitions":{"child-thread-computing-result-writing-toward-channel":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"global_read","dest":"wfd","name":"g_channel_write_fd"},{"instruction_type":"global_read","dest":"n","name":"g_channel_child_input"},{"instruction_type":"variable_declaration","variable_name":"result","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"*","target":"result","lhs":{"value":"n"},"rhs":{"value":"two"}},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"eight"}],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"array_write","base":"buf","index":"zero","value":"result","scale":8},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"1","arg1":"wfd","arg2":"buf","arg3":"eight","arg4":"zero","arg5":"zero","arg6":"zero","result_variable":"wr"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}