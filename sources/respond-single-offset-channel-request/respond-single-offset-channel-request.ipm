{"build_type":"library","description":"Serve exactly one offset-gate request on a given channel. Block-read the request doorbell through the module read primitive, read the verb identifier from slot 256, scan the channel capability mask over verbs, place the deny sentinel minus 126 in result slot 260, and when the verb is inside the channel mask route it to the flat per-verb dispatcher. Finally ring the response doorbell through the module write primitive. Args are channel base pointer, request fd, response fd, and the count-prefixed mask pointer. The doorbell syscalls now go through the host module primitives, not raw sys.","module_name":"respond-single-offset-channel-request","package_name":"respond-single-offset-channel-request","function_definitions":{"respond-single-offset-channel-request":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"},{"parameter_name":"reqfd","parameter_type":"i64"},{"parameter_name":"respfd","parameter_type":"i64"},{"parameter_name":"maskptr","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"neg126","variable_type":"i64","assignment_operation":"literal","source_target":-126},{"instruction_type":"variable_declaration","variable_name":"i256","variable_type":"i64","assignment_operation":"literal","source_target":256},{"instruction_type":"variable_declaration","variable_name":"i260","variable_type":"i64","assignment_operation":"literal","source_target":260},{"instruction_type":"function_invocation","invocation_name":"allocate-