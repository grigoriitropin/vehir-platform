{"build_type":"library","description":"Event-driven byte relay loop for the stdio MCP transport adapter. Polls a two-entry pollfd buffer (slot 0 = standard input fd 0, slot 1 = the kernel socket fd) with an infinite timeout, and on readiness copies a chunk one direction: standard input bytes to the socket, socket bytes to standard output. End of either stream (a read returning zero or less) ends the relay. Pure byte transport with no MCP parsing; the pollfd buffer and the scratch buffer are set up once by the caller and reused every iteration. Tail-recurses for the next event.","module_name":"relay-polled-bytes-across-paired-descriptors-perpetually","package_name":"relay-polled-bytes-across-paired-descriptors-perpetually","function_definitions":{"relay-polled-bytes-across-paired-descriptors-perpetually":{"return_type":"i64","parameter_definitions":[{"parameter_name":"sockfd","parameter_type":"i64"},{"parameter_name":"buf","parameter_type":"i64"},{"parameter_name":"cap","parameter_type":"i64"},{"parameter_name":"pollbuf","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"neg1","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"variable_declaration","variable_name":"i3","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"i7","variable_type":"i64","assignment_operation":"literal","source_target":7},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_ty