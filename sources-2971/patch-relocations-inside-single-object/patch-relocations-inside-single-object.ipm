{"build_type":"library","description":"Apply every relocation of one loaded native object: for each {site,target}, look the target symbol up in the name->base map g_ld_map (an unresolved symbol is a fatal error, fail hard), compute the rel32 displacement (target_base - (object_base + site) - 4) and write it as four little-endian bytes into the call site within g_ld_region. Tail-recurses over the relocation index.","module_name":"patch-relocations-inside-single-object","package_name":"patch-relocations-inside-single-object","function_definitions":{"patch-relocations-inside-single-object":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"},{"parameter_name":"relocs","parameter_type":"i64"},{"parameter_name":"ri","parameter_type":"i64"},{"parameter_name":"nr","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"k_site","variable_type":"str","assignment_operation":"string","source_target":"site"},{"instruction_type":"variable_declaration","variable_name":"k_target","variable_type":"str","assignment_operation":"string","source_target":"target"},{"instruction_type":"variable_declaration","variable_name":"e_unresolved","variable_type":"str","assignment_operation":"string","source_target":"native_symbol_unresolved"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"ri"},"rhs":{"value":"nr"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"fetch-member-residing-within-sequence