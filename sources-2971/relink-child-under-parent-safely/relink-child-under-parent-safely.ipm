{"build_type":"library","description":"CC0. Ownership-safe re-link: detach child from its current parent (fixing the old siblings and the old parent first-child pointer using the parent back-pointer), then append it at the tail of parent. Safe to call on a fresh node (no old parent) or an already-attached one, so re-parenting never corrupts links (the footgun of unsafe re-parenting designed out).","module_name":"relink-child-under-parent-safely","package_name":"relink-child-under-parent-safely","function_definitions":{"relink-child-under-parent-safely":{"return_type":"i64","parameter_definitions":[{"parameter_name":"parent","parameter_type":"i64"},{"parameter_name":"child","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"field_read","struct":"json-tree-node","field":"parent","base":"child","dest":"oldp"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"oldp"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"field_read","struct":"json-tree-node","field":"prev","base":"child","dest":"p"},{"instruction_type":"field_read","struct":"json-tree-node","field":"next","base":"child","dest":"n"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"p"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"field_write","struct":"json-tree-node","field":"next","base":"p","value":"n"}],"branch_on_failure":[{"instruction_type":"field_write","struct":"json-tree-node","field":"child","base":"oldp","value":"n"}]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"n"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"field_write","struct":"json-tree-node","field":"prev","base":"n","value":"p"}],"branch_on_failure":[]