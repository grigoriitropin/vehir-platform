{"build_type":"executable","description":"Fail-closed syscall-monopoly enforcer. Walks every package under the roots, gathers all syscall sites, and reports every site whose package is outside the permitted allowlist (the host module plus the loader) as a forbidden package name. Emits the forbidden count first, a catalog error code when any violation exists, then the forbidden package list, and returns the forbidden count as the exit status so a build gate fails closed whenever any syscall lives outside the module. The allowlist is supplied in the request under the key allowed.","module_name":"report-foreign-syscall-sites-violating-library-monopoly","package_name":"report-foreign-syscall-sites-violating-library-monopoly","function_definitions":{"report-foreign-syscall-sites-violating-library-monopoly":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_roots","variable_type":"str","assignment_operation":"string","source_target":"roots"},{"instruction_type":"variable_declaration","variable_name":"s_allowed","variable_type":"str","assignment_operation":"string","source_target":"allowed"},{"instruction_type":"variable_declaration","variable_name":"s_fcount","variable_type":"str","assignment_operation":"string","source_target":"forbidden_count"},{"instruction_type":"variable_declaration","variable_name":"s_fpkgs","variable_type":"str","assignment_operation":"string","source_target":"forbidden_packages"},{"instruction_type":"variable_declaration","variable_name":"s_code","variable_type":"str","assignment_operation":"string","source_target":"code"},{"instruction_type":"variable_declaration","variable_name":"v_code","variable_type":"str","assignment_oper