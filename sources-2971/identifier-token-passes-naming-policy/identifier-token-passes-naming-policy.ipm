{"build_type":"library","description":"Return 1 if a single word token satisfies the naming policy: either it is a registered allowlisted abbreviation (member of allowlist, nallow = its length), or it is at least 5 bytes long and composed only of lowercase Latin letters. Else 0. This encodes the per-word half of the policy (the >=5-words count is checked by the caller). Reuses json_string_array_contains_value, compute_string_length_by_scanning, byte_run_is_lowercase_latin_letters.","module_name":"identifier-token-passes-naming-policy","package_name":"identifier-token-passes-naming-policy","function_definitions":{"identifier-token-passes-naming-policy":{"return_type":"i64","parameter_definitions":[{"parameter_name":"token","parameter_type":"i64"},{"parameter_name":"allowlist","parameter_type":"i64"},{"parameter_name":"nallow","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"function_invocation","invocation_name":"json-string-array-contains-value","invocation_arguments":[{"kind":"var","value":"allowlist"},{"kind":"var","value":"token"},{"kind":"var","value":"zero"},{"kind":"var","value":"nallow"}],"result_assignment_variable":"present","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"present"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"one"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"token"}],"result_assignment_variable":"len","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"len"},"rhs":{"value":"five"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"verify-character-sequence-members-constitute-lowercase-letters","invocation_arguments":[{"kind":"var","value":"token"},{"kind":"var","value":"zero"},{"kind":"var","value":"len"}],"result_assignment_variable":"lc","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"lc"}}]}}}