{"build_type":"library","description":"TLS slot-table null-name guard (SOUL Sec3 fail-hard). Before each thread-local name comparison the resolver routes through here: if the table entry name literal is NULL at runtime (a string-constant that failed to materialize), append a diagnostic record to the kernel error-ring (code 911, the entry slot offset in the task_id+rip fields, the looked-up global in the name field) THEN fall through to the byte compare which faults on the null - so the kernel/crash log names the exact broken slot offset before the crash. Non-null entries pass straight through to the normal byte compare. eoff = the unique TLS slot offset that 1:1 identifies the global.","module_name":"match-tls-name-or-fault-on-null","package_name":"match-tls-name-or-fault-on-null","function_definitions":{"match-tls-name-or-fault-on-null":{"return_type":"i64","parameter_definitions":[{"parameter_name":"lookup","parameter_type":"i64"},{"parameter_name":"ename","parameter_type":"i64"},{"parameter_name":"eoff","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"diag_code","variable_type":"i64","assignment_operation":"literal","source_target":911},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"ename"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"append-error-record-into-ring-buffer","invocation_arguments":[{"kind":"var","value":"diag_code"},{"kind":"var","value":"eoff"},{"kind":"var","value":"eoff"},{"kind":"var","value":"lookup"}],"result_assignment_variable":"logret","result_type":"i64"}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"compare-paired-strings-octet-through-octet","invocation_arguments":[{"kind":"var","value":"lookup"},{"kind":"var","value":"ename"}],"result_assignment_variable":"cres","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"cres"}}]}}}