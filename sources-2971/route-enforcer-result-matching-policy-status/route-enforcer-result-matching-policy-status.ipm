{"build_type":"library","description":"Route one enforcer result according to its configured severity. Given the violations sequence produced by a named check, do nothing when it is empty. Otherwise resolve the mode from the registry, defaulting to active when unlisted. Warning mode attaches the violators under the check name into the warning block and never blocks. Active mode attaches them into the blocking block and adds their count to the shared blocking counter so the build refuses to flip. Parameters are packed into ctx to respect the four-parameter cap: slot zero the policy registry, one the blocking-violations mapping, two the warning-violations mapping, three a single-word arena counter of accumulated blocking violations; the remaining parameters are the check name and its violations sequence.","module_name":"route-enforcer-result-matching-policy-status","package_name":"route-enforcer-result-matching-policy-status","function_definitions":{"route-enforcer-result-matching-policy-status":{"return_type":"i64","parameter_definitions":[{"parameter_name":"ctx","parameter_type":"i64"},{"parameter_name":"name","parameter_type":"i64"},{"parameter_name":"seq","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"array_read","dest":"registry","base":"ctx","index":"zero","scale":8},{"instruction_type":"array_read","dest":"active_block","base":"ctx","index":"one","scale":8},{"instruction_type":"array_read","dest":"warn_block","base":"ctx","index":"two","scale":8},{"instruction_type":"array_read","dest":"counter","base":"ctx","index":"three","scale":8},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"seq"}],"result_assignment_variable":"cnt","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"zero"},"rhs":{"value":"cnt"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"lookup-enforcement-policy-matching-named-check-standard","invocation_arguments":[{"kind":"var","value":"registry"},{"kind":"var","value":"name"}],"result_assignment_variable":"mode","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"s_warn","variable_type":"str","assignment_operation":"string","source_target":"warning"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"mode"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"compare-paired-strings-octet-through-octet","invocation_arguments":[{"kind":"var","value":"mode"},{"kind":"var","value":"s_warn"}],"result_assignment_variable":"isw","result_type":"i64"}],"branch_on_failure":[{"instruction_type":"variable_declaration","variable_name":"isw","variable_type":"i64","assignment_operation":"literal","source_target":1}]},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"isw"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_name":"fifty","variable_type":"i64","assignment_operation":"literal","source_target":50},{"instruction_type":"function_invocation","invocation_name":"truncate-violation-sequence-retaining-leading-members","invocation_arguments":[{"kind":"var","value":"seq"},{"kind":"var","value":"fifty"}],"result_assignment_variable":"tseq","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"warn_block"},{"kind":"var","value":"name"},{"kind":"var","value":"tseq"}]}],"branch_on_failure":[{"instruction_type":"function_invocation","invocation_name":"attach-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"active_block"},{"kind":"var","value":"name"},{"kind":"var","value":"seq"}]},{"instruction_type":"array_read","dest":"cur","base":"counter","index":"zero","scale":8},{"instruction_type":"variable_declaration","variable_name":"cur2","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"cur2","lhs":{"value":"cur"},"rhs":{"value":"cnt"}},{"instruction_type":"array_write","base":"counter","index":"zero","value":"cur2","scale":8}]}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}