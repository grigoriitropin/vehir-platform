{"build_type":"library","description":"As-completed result aggregation helper: walk the MPSC result pointer array from `index` until the first empty (zero) slot, wrap each worker result cstring as a string document node, and append it to `out_seq`. Tail-recursive over the array. The orchestrator calls this AFTER the collector loop drains, so it runs only for a bounded launch (a non-closing service launch never returns here, so nothing accumulates). Lets a fan-out return its workers' results as a JSON array instead of only a completion count.","module_name":"collect-result-pointer-array-into-document-sequence","package_name":"collect-result-pointer-array-into-document-sequence","function_definitions":{"collect-result-pointer-array-into-document-sequence":{"return_type":"i64","parameter_definitions":[{"parameter_name":"result_base","parameter_type":"i64"},{"parameter_name":"index","parameter_type":"i64"},{"parameter_name":"out_seq","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"array_read","dest":"r","base":"result_base","index":"index","scale":8},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"r"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"encode-textual-payload-document-value","invocation_arguments":[{"kind":"var","value":"r"}],"result_assignment_variable":"rnode","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-element-extending-document-sequence","invocation_arguments":[{"kind":"var","value":"out_seq"},{"kind":"var","value":"rnode"}]},{"instruction_type":"variable_declaration","variable_name":"next","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"next","lhs":{"value":"index"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"collect-result-pointer-array-into-document-sequence","invocation_arguments":[{"kind":"var","value":"result_base"},{"kind":"var","value":"next"},{"kind":"var","value":"out_seq"}],"result_assignment_variable":"rr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"rr"}}]}}}