{"build_type":"library","description":"Tail-chain worker result delivery: writes the worker's single result into the region's slot 0 (where the launching parent's poll-region reads it) and announces the doorbell at region+8 (where the parent is suspended), waking it. Implements the previously-stubbed cross-thread wake for a RETURNING tail-chain worker (the boot collector never returned, so this path was never exercised). The clone trampoline owns thread-exit after this returns.","module_name":"deliver-worker-result-waking-doorbell-terminating-thread","package_name":"deliver-worker-result-waking-doorbell-terminating-thread","function_definitions":{"deliver-worker-result-waking-doorbell-terminating-thread":{"return_type":"i64","parameter_definitions":[{"parameter_name":"context","parameter_type":"i64"},{"parameter_name":"result","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"array_write","base":"context","index":"zero","value":"result","scale":8},{"instruction_type":"variable_declaration","variable_name":"dbaddr","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"dbaddr","lhs":{"value":"context"},"rhs":{"value":"eight"}},{"instruction_type":"function_invocation","invocation_name":"announce-readiness-waking-doorbell-waiters","invocation_arguments":[{"kind":"var","value":"dbaddr"}],"result_assignment_variable":"_w","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}