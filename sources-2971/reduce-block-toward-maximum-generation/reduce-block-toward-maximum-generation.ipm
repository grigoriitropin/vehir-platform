{"build_type":"library","description":"Tail-recursively walks a getdents64 dirent block by d_reclen, parsing each entry name as a decimal integer and keeping the maximum seen, returning the highest numbered directory entry. Non-numeric names (dot and dotdot) parse to zero and do not affect the maximum, so scanning a generations directory yields the latest generation number. Dirent layout: d_reclen at offset+16 as two little-endian octets, d_name at offset+19.","module_name":"reduce-block-toward-maximum-generation","package_name":"reduce-block-toward-maximum-generation","function_definitions":{"reduce-block-toward-maximum-generation":{"return_type":"i64","parameter_definitions":[{"parameter_name":"region","parameter_type":"i64"},{"parameter_name":"offset","parameter_type":"i64"},{"parameter_name":"nbytes","parameter_type":"i64"},{"parameter_name":"maxsofar","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"sixteen","variable_type":"i64","assignment_operation":"literal","source_target":16},{"instruction_type":"variable_declaration","variable_name":"seventeen","variable_type":"i64","assignment_operation":"literal","source_target":17},{"instruction_type":"variable_declaration","variable_name":"nineteen","variable_type":"i64","assignment_operation":"literal","source_target":19},{"instruction_type":"variable_declaration","variable_name":"twofivesix","variable_type":"i64","assignment_operation":"literal","source_target":256},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"offset"},"rhs":{"value":"nbytes"},"branch_on_success":[{"instruction_type":"variable_declaration","variable_nam