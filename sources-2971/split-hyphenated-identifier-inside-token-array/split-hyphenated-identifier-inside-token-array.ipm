{"build_type":"library","description":"Split a hyphen-joined c-string name into a fresh document sequence of its word tokens. Resets the shared token-start cursor, then drives split_hyphenated_name_into_token_array_loop1 over the whole string. A name with no hyphen yields a single-element array (which then fails the >=5-words policy, as intended). Reuses compute_string_length_by_scanning, begin_empty_sequence_document_value, split_hyphenated_name_into_token_array_loop1.","module_name":"split-hyphenated-identifier-inside-token-array","package_name":"split-hyphenated-identifier-inside-token-array","module_globals":[{"global_name":"g_name_token_start","global_type":"i64","global_init":"0"}],"function_definitions":{"split-hyphenated-identifier-inside-token-array":{"return_type":"i64","parameter_definitions":[{"parameter_name":"name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"global_write","name":"g_name_token_start","value":"zero"},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"name"}],"result_assignment_variable":"len","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"arr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"split-hyphenated-identifier-inside-token-array-iteration","invocation_arguments":[{"kind":"var","value":"name"},{"kind":"var","value":"zero"},{"kind":"var","value":"len"},{"kind":"var","value":"arr"}],"result_assignment_variable":"rr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"arr"}}]}}}