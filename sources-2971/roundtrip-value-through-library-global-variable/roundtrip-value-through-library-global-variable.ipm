{"build_type":"executable","description":"Isolation test for global_read/global_write through the object linker: writes 42 into a module global, reads it back, and returns it. Object-emitted and run via the loader it must exit 42 — proving global variables (emitted as named data objects) are correctly written and read when linked by name. This path was never exercised by the earlier object tests (calls, data/lea, local branches, recursion).","module_name":"roundtrip-value-through-library-global-variable","package_name":"roundtrip-value-through-library-global-variable","module_globals":[{"global_name":"g_rt_slot","global_type":"i64","global_init":"0"}],"function_definitions":{"roundtrip-value-through-library-global-variable":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"v42","variable_type":"i64","assignment_operation":"literal","source_target":42},{"instruction_type":"global_write","name":"g_rt_slot","value":"v42"},{"instruction_type":"global_read","dest":"r","name":"g_rt_slot"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}