{"build_type":"library","description":"Driver for op.grep: walk the members of a package's function_definitions object (each child's .string is the function name), starting at 'member' and following .next. For each function, count instructions of the requested 'kind' anywhere in its subtree via count_matching_instructions_in_subtree (nested branches included); if the count is non-zero, append one located row {function, count} to the 'hits' array. Functions with zero matches are omitted (the rows are a density-by-function summary, not instruction-level locations). Reuses count_matching_instructions_in_subtree, add_str_field, add_number_to_object.","module_name":"gather-instruction-group-counts-across-functions","package_name":"gather-instruction-group-counts-across-functions","function_definitions":{"gather-instruction-group-counts-across-functions":{"return_type":"i64","parameter_definitions":[{"parameter_name":"member","parameter_type":"i64"},{"parameter_name":"kind","parameter_type":"i64"},{"parameter_name":"hits","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_function","variable_type":"str","assignment_operation":"string","source_target":"function"},{"instruction_type":"variable_declaration","variable_name":"s_count","variable_type":"str","assignment_operation":"string","source_target":"count"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"member"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"count-matching-instructions-inside-subtree-sequence","invocation_arguments":[{"kind":"var","value":"member"},{"kind":"var","value":"kind"}],"result_assignment_variable":"cnt","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"cnt"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"field_read","struct":"json-tree-node","field":"key","base":"member","dest":"name"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"row","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"row"},{"kind":"var","value":"s_function"},{"kind":"var","value":"name"}]},{"instruction_type":"function_invocation","invocation_name":"attach-numeric-value-towards-object","invocation_arguments":[{"kind":"var","value":"row"},{"kind":"var","value":"s_count"},{"kind":"var","value":"cnt"}]},{"instruction_type":"function_invocation","invocation_name":"append-element-extending-document-sequence","invocation_arguments":[{"kind":"var","value":"hits"},{"kind":"var","value":"row"}]}],"branch_on_failure":[]},{"instruction_type":"field_read","struct":"json-tree-node","field":"next","base":"member","dest":"nxt"},{"instruction_type":"function_invocation","invocation_name":"gather-instruction-group-counts-across-functions","invocation_arguments":[{"kind":"var","value":"nxt"},{"kind":"var","value":"kind"},{"kind":"var","value":"hits"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}