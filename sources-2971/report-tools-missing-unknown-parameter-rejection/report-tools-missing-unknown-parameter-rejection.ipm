{"build_type":"executable","description":"Fail-closed compile gate. Given roots and an array of tool entry function names under targets, enumerates the package universe, builds the function index, and for each target computes its call closure and checks whether the sanctioned package reject-unrecognized-request-parameters is reachable. Emits missing_count, the catalog code unvalidated_parameter_keys when any target does not route its request through the unknown-parameter rejection helper, then the missing target list, and returns the missing count as exit status so the build fails closed when any tool can silently ignore an unknown parameter.","module_name":"report-tools-missing-unknown-parameter-rejection","package_name":"report-tools-missing-unknown-parameter-rejection","function_definitions":{"report-tools-missing-unknown-parameter-rejection":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"c40","variable_type":"i64","assignment_operation":"literal","source_target":40},{"instruction_type":"variable_declaration","variable_name":"s_roots","variable_type":"str","assignment_operation":"string","sour