{"build_type":"library","description":"Minimal bare-metal kernel entry (no Linux processes): install the fixed world arena on the main thread, carve a private arena block into a spawn context, spawn the single ROOT worker via clone (render-clone endows its FS+arena), then PARK on the shutdown signal descriptor. Everything else (collector, VSM, services) hangs off the root worker as clone-thread launch workers -- no fork, no execve, no daemon supervisor process.","module_name":"enter-kernel-arena-spawning-root-worker-awaiting-shutdown","package_name":"enter-kernel-arena-spawning-root-worker-awaiting-shutdown","function_definitions":{"enter-kernel-arena-spawning-root-worker-awaiting-shutdown":{"return_type":"i64","parameter_definitions":[{"parameter_name":"env","parameter_type":"i64"},{"parameter_name":"config_path","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"negone","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"variable_declaration","variable_name":"rsz","variable_type":"i64","assignment_operation":"literal","source_target":4096},{"instruction_type":"variable_declaration","variable_name":"ssz","variable_type":"i64","assignment_operation":"literal","source_target":65536},{"instruction_type":"function_invocation","invocation_name":"install-fixed-arena-before-entering-kernel","invocation_arguments":[{"kind":"var","value":"env"},{"kind":"var","value":"zero"}],"result_assignment_variable":"ar","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"allocate-system-memory-chunk-region","invocation_arguments":[{"kind":"var","value":"rsz"}],"result_assignment_variable":"region","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"provision-worker-arena-block-into-regio