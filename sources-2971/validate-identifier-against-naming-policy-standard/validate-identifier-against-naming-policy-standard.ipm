{"build_type":"tool","description":"MCP launch-contract tool: validate a single identifier against the naming policy. Arg: {name: <string>}. Returns {name, ok} where ok=1 if the name satisfies the policy. Fully kernel-native — no argv/stdin/stdout.","module_name":"validate-identifier-against-naming-policy-standard","package_name":"validate-identifier-against-naming-policy-standard","module_globals":[],"function_definitions":{"validate-identifier-against-naming-policy-standard":{"return_type":"i64","parameter_definitions":[{"parameter_name":"input","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"c3","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"c5","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"c_hyphen","variable_type":"i64","assignment_operation":"literal","source_target":45},{"instruction_type":"variable_declaration","variable_name":"c_a","variable_type":"i64","assignment_operation":"literal","source_target":97},{"instruction_type":"variable_declaration","variable_name":"c_z","variable_type":"i64","assignment_operation":"literal","source_target":122},{"instruction_type":"variable_declaration","variable_name":"s_name","variable_type":"str","assignment_operation":"string","source_target":"name"},{"instruction_type":"variable_declaration","variable_name":"s_valid","variable_type":"str","assignment_operation":"string","source_target":"valid"},{"instruction_type":"variable_declaration","variable_name":"s_wc","variable_type":"str","assignment_operation":"string",