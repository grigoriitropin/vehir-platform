{"build_type":"library","description":"Scan a {name,type} entry list (linked list nodes via .next) and return the entry whose name is the smallest one STRICTLY GREATER than prev_name, carrying the running best in the 3rd argument (pass 0 to start). Byte-comparison via compare_two_strings_byte_by_byte (>0 = name after prev; <0 vs best = new minimum). Directory entry names are unique within a directory, so 'smallest name > prev' yields a total order with no ties — the selection step of an in-place-free sort. Tail-recursive over .next. Reuses locate_named_member_inside_mapping, compare_two_strings_byte_by_byte.","module_name":"identify-lexicographically-smallest-remaining-directory-entry","package_name":"identify-lexicographically-smallest-remaining-directory-entry","function_definitions":{"identify-lexicographically-smallest-remaining-directory-entry":{"return_type":"i64","parameter_definitions":[{"parameter_name":"node","parameter_type":"i64"},{"parameter_name":"prev_name","parameter_type":"i64"},{"parameter_name":"best","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_name","variable_type":"str","assignment_operation":"string","source_target":"name"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"node"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"node"},{"kind":"var","value":"s_name"}],"result_assignment_variable":"nn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"nn"}],"result_assignment_variable":"name","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"compare-paired-strings-octet-through-octet","invocation_arguments":[{"kind":"var","value":"name"},{"kind":"var","value":"prev_name"}],"result_assignment_variable":"cmp_prev","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"cmp_prev"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"best"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"best","lhs":{"value":"node"},"rhs":{"value":"zero"}}],"branch_on_failure":[{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"best"},{"kind":"var","value":"s_name"}],"result_assignment_variable":"bnn","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-string-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"bnn"}],"result_assignment_variable":"best_name","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"compare-paired-strings-octet-through-octet","invocation_arguments":[{"kind":"var","value":"name"},{"kind":"var","value":"best_name"}],"result_assignment_variable":"cmp_best","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"cmp_best"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"best","lhs":{"value":"node"},"rhs":{"value":"zero"}}],"branch_on_failure":[]}]}],"branch_on_failure":[]},{"instruction_type":"field_read","struct":"json-tree-node","field":"next","base":"node","dest":"nxt"},{"instruction_type":"function_invocation","invocation_name":"identify-lexicographically-smallest-remaining-directory-entry","invocation_arguments":[{"kind":"var","v