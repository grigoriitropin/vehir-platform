{"build_type":"library","description":"Sanctioned unknown-parameter gate for tool entries. reqch is the first member of the parsed request mapping (field_read child of req); allowed_seq_root is a JSON sequence whose members text-name every permitted parameter key. Returns 0 when every request key is permitted; emits a JSON error {status:error, code:unknown_param, got:<key>} and returns 1 on the first unrecognized key. Every tool entry must route its request through this before doing work, so an unknown parameter is a loud JSON error, never a silent no-op.","module_name":"reject-unrecognized-request-parameters-sequence","package_name":"reject-unrecognized-request-parameters-sequence","function_definitions":{"reject-unrecognized-request-parameters-sequence":{"return_type":"i64","parameter_definitions":[{"parameter_name":"reqch","parameter_type":"i64"},{"parameter_name":"allowed_seq_root","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"function_invocation","invocation_name":"fetch-child-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"allowed_seq_root"}],"result_assignment_variable":"allowed_head","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-child-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"reqch"}],"result_assignment_variable":"params_head","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"inspect-sequence-members-rejecting-unrecognized-parameters","invocation_arguments":[{"kind":"var","value":"params_head"},{"kind":"var","value":"allowed_head"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}]}}}