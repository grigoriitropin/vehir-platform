{"build_type":"library","description":"Walk every universe entry and feed each package function definition into the shared clone buckets. For each entry it reads the doc then the function_definitions object and, when present, hands the first function node to the per-package bucketer. Parameters are packed into ctx (slot zero the universe array, slot one the buckets object) to respect the parameter cap; the second parameter is the running index the caller passes as zero. Recurses by index.","module_name":"traverse-universe-entries-gathering-function-clone-buckets","package_name":"traverse-universe-entries-gathering-function-clone-buckets","function_definitions":{"traverse-universe-entries-gathering-function-clone-buckets":{"return_type":"i64","parameter_definitions":[{"parameter_name":"ctx","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"k_doc","variable_type":"str","assignment_operation":"string","source_target":"doc"},{"instruction_type":"variable_declaration","variable_name":"k_fn","variable_type":"str","assignment_operation":"string","source_target":"function_definitions"},{"instruction_type":"array_read","dest":"universe","base":"ctx","index":"zero","scale":8},{"instruction_type":"array_read","dest":"buckets","base":"ctx","index":"one","scale":8},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"universe"}],"result_assignment_variable":"n","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"i"},"rhs":{"value":"n"