{"build_type":"library","description":"Manual thread-local arena setup for the ONE firmware-seed entry that is NOT launched (the boot kernel launcher): mmaps a private 16MiB block, writes its size into block[6] (the header slot endow reads), and endows this thread with that block as its private FS-relative arena. Must be the FIRST thing the launcher does, before any allocation -- after the FLIP a firmware seed starts with FS=0 and any allocation would fault. install-fixed-arena later re-points FS at the real kernel arena from the boot envelope.","module_name":"establish-bootstrap-thread-arena","package_name":"establish-bootstrap-thread-arena","function_definitions":{"establish-bootstrap-thread-arena":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"six","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"variable_declaration","variable_name":"prot","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"flags","variable_type":"i64","assignment_operation":"literal","source_target":34},{"instruction_type":"variable_declaration","variable_name":"nfd","variable_type":"i64","assignment_operation":"literal","source_target":-1},{"instruction_type":"variable_declaration","variable_name":"size","variable_type":"i64","assignment_operation":"literal","source_target":16777216},{"instruction_type":"variable_declaration","variable_name":"__t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"invoke_kernel_syscall","syscall_number":"9","arg1":"zero","arg2":"size","arg3":"prot","arg4":"flags","arg5":"nfd","arg6":"zero","result_variable":"block"},{"instruction_type":"array_write","base":"block","index":"six","value":"size","scale":8},{"instruction_type":"function_invocation","invocation_name":"endow-calling-thread-with-private-arena","invocation_arguments":[{"kind":"var","value":"block"}],"result_assignment_variable":"e","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}