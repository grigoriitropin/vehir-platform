{"build_type":"library","description":"Append the substring of c-string name in the half-open range [start,end) as a new string element of arr. An empty range yields an empty-string token (so consecutive separators surface as a too-short token that fails the policy, rather than silently vanishing). Reuses create_empty_string_buffer, append_byte_range_into_buffer, encode_textual_payload_document_value, append_element_extending_document_sequence.","module_name":"append-substring-token-inside-token-array","package_name":"append-substring-token-inside-token-array","function_definitions":{"append-substring-token-inside-token-array":{"return_type":"i64","parameter_definitions":[{"parameter_name":"arr","parameter_type":"i64"},{"parameter_name":"name","parameter_type":"i64"},{"parameter_name":"start","parameter_type":"i64"},{"parameter_name":"end","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"empty","variable_type":"str","assignment_operation":"string","source_target":""},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">","lhs":{"value":"end"},"rhs":{"value":"start"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-octet-range-inside-buffer","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"name"},{"kind":"var","value":"start"},{"kind":"var","value":"end"}],"result_assignment_variable":"abr","result_type":"i64"},{"instruction_type":"field_read","struct":"string_buffer","field":"data","base":"buf","dest":"data"},{"instruction_type":"function_invocation","invocation_name":"encode-textual-payloa