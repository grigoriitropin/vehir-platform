{"build_type":"library","module_name":"adjust-buffer-window-completing-character","package_name":"adjust-buffer-window-completing-character","description":"Given a byte-cut window end, scan back to the last UTF-8 lead byte, read its declared length from the high bits, and return a reduced end that never splits a multibyte codepoint (or the original end if the last codepoint is whole). Used by read-file on the no-newline giant-line cut path. Params: buf, i (scan start = end minus one), m (window length).","function_definitions":{"adjust-buffer-window-completing-character":{"return_type":"i64","parameter_definitions":[{"parameter_name":"buf","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"},{"parameter_name":"m","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"c80","variable_type":"i64","assignment_operation":"literal","source_target":128},{"instruction_type":"variable_declaration","variable_name":"cC0","variable_type":"i64","assignment_operation":"literal","source_target":192},{"instruction_type":"variable_declaration","variable_name":"cE0","variable_type":"i64","assignment_operation":"literal","source_target":224},{"instruction_type":"variable_declaration","variable_name":"cF0","variable_type":"i64","assignment_operation":"literal","source_target":240},{"instruction_type":"variable_declaration","variable_name":"cF8","variable_type":"i64","assignment_operation":"literal","source_target":248},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"i"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"m"}}