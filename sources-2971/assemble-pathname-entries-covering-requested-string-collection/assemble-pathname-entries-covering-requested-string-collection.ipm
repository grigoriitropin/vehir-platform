{"build_type":"library","description":"Given an array of pathname strings, append one mapping {path: <string>} per element into the output sequence, producing entries in exactly the shape grep_text_scan consumes (it reads the path member off each node and reads that file). Lets the text-search tool grep an explicit list of arbitrary files (the manifest, markdown drafts, json, tool-results) instead of only enumerated .ipm package sources. Recurses by index; parameters are the string array, the output sequence, and the running index the caller passes as zero.","module_name":"assemble-pathname-entries-covering-requested-string-collection","package_name":"assemble-pathname-entries-covering-requested-string-collection","function_definitions":{"assemble-pathname-entries-covering-requested-string-collection":{"return_type":"i64","parameter_definitions":[{"parameter_name":"files","parameter_type":"i64"},{"parameter_name":"out","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"s_path","variable_type":"str","assignment_operation":"string","source_target":"path"},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"files"}],"result_assignment_variable":"n","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"i"},"rhs":{"value":"n"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"fetch-member-residing-within-sequence","invocation_arguments":[{"kind":"var","value":"files"},{"kind":"var","value":"i"}],"