{"build_type":"library","description":"Run the whole-program analysis phase that needs every parsed package resident, and emit its light results to a file so the caller can drop the resident universe. Builds the universe from the manifest roots, grafts attached repositories, builds the function index, runs the whole-program policy enforcers, derives the compiler toolchain identity, and records the source content commit. Then writes the function index, the package-name to path index, the toolchain identity, and the enforcer violation count into an analysis results file under the generation directory, and returns the active-mode violation count. Intended to run inside a forked child whose exit returns the resident documents to the operating system.","module_name":"perform-universe-analysis-writing-results","package_name":"perform-universe-analysis-writing-results","function_definitions":{"perform-universe-analysis-writing-results":{"return_type":"i64","parameter_definitions":[{"parameter_name":"manifest","parameter_type":"i64"},{"parameter_name":"gen_dir","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"k_roots","variable_type":"str","assignment_operation":"string","source_target":"roots"},{"instruction_type":"variable_declaration","variable_name":"k_root","variable_type":"str","assignment_operation":"string","source_target":"root"},{"instruction_type":"variable_declaration","variable_name":"k_comp","variable_type":"str","assignment_operation":"string","source_target":"compiler_target"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"manifest"},{"kind":"var","value":"k_roots"}],"result_assignment_variable":"roots","result_type":"i64"},{"instruction_type":"function_invocation"