{"build_type":"library","description":"Emit a structured stdout error when an op did not resolve to a runnable tool (the execve in execute_pinned_tool_by_operation_name returned, which only happens on failure = no such pinned binary). Replaces a stderr-only report on that path so a consumer routed through the shell actually sees why nothing ran, plus the live available_tools name list to recover. {status:error, code:unknown_op, message, requested:<op>, available_tools:[names]}. Reuses read_tool_policy_tools, count_members_inside_container_value, begin_empty_mapping_document_value, add_str_field, begin_empty_sequence_document_value, project_contract_names_into_array, attach_named_member_inside_mapping, emit_result_object_onto_standard_output.","module_name":"write-unknown-operation-diagnostics-report","package_name":"write-unknown-operation-diagnostics-report","function_definitions":{"write-unknown-operation-diagnostics-report":{"return_type":"i64","parameter_definitions":[{"parameter_name":"argv0","parameter_type":"i64"},{"parameter_name":"op_name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_status","variable_type":"str","assignment_operation":"string","source_target":"status"},{"instruction_type":"variable_declaration","variable_name":"v_error","variable_type":"str","assignment_operation":"string","source_target":"error"},{"instruction_type":"variable_declaration","variable_name":"s_code","variable_type":"str","assignment_operation":"string","source_target":"code"},{"instruction_type":"variable_declaration","variable_name":"v_unknown","variable_type":"str","assignment_operation":"string","source_target":"unknown_op"},{"instruction_type":"variable_declaration","variable_name":"s_message","variable_type":"str","assignment_operation":"string","source_target":"message"},{"instruction_type":"variable_declaration","variable_name":"m_unknown","variable_type":"str","assignment_operation":"string","source_target":"the request's key did not resolve to a tool; use a single-key request {\"<tool>\": <arg>} with a name from available_tools, or send {\"help\": null} for usage"},{"instruction_type":"variable_declaration","variable_name":"s_requested","variable_type":"str","assignment_operation":"string","source_target":"requested"},{"instruction_type":"variable_declaration","variable_name":"s_avail","variable_type":"str","assignment_operation":"string","source_target":"available_tools"},{"instruction_type":"function_invocation","invocation_name":"retrieve-helper-policy-rules-helpers","invocation_arguments":[{"kind":"var","value":"argv0"}],"result_assignment_variable":"tools","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"tools"}],"result_assignment_variable":"n","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-mapping-document-value","invocation_arguments":[],"result_assignment_variable":"res","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"res"},{"kind":"var","value":"s_status"},{"kind":"var","value":"v_error"}]},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"res"},{"kind":"var","value":"s_code"},{"kind":"var","value":"v_unknown"}]},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"res"},{"kind":"var","value":"s_message"},{"kind":"var","value":"m_unknown"}]},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-mapping","invocation_arguments":[{"kind":"var","value":"res"},{"kind":"var","value":"s_requested"},{"kind":"var","value":"op_name"}]},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"names","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"project-contract-names-inside-array","invocation_arguments":[{"kind":"var","value":"tools"},{"kind":"var","value":"names"},{"kind":"var","value":"zero"},{"kind":"var","value":"n"}],"result_assignment_variable":"pr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"res"},{"kind":"var","value":"s_avail"},{"kind":"var","value":"names"}]},{"instruction_type":"function_invocation","invocation_name":"write-result-object-toward-standard-output","invocation_arguments":[{"kind":"var","value":"res"}],"result_assignment_variable":"w","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}