{"build_type":"library","description":"Reads from descriptor fd repeatedly into buffer starting at byte off, advancing off by each read count, until a read returns zero or less (end of stream or error) or the cap is reached. Returns the total bytes accumulated. Needed because procfs files short-read one page per call, so a single read does not return the whole file.","module_name":"accumulate-descriptor-octets-until-exhausted","package_name":"accumulate-descriptor-octets-until-exhausted","function_definitions":{"accumulate-descriptor-octets-until-exhausted":{"return_type":"i64","parameter_definitions":[{"parameter_name":"fd","parameter_type":"i64"},{"parameter_name":"buffer","parameter_type":"i64"},{"parameter_name":"off","parameter_type":"i64"},{"parameter_name":"cap","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":">=","lhs":{"value":"off"},"rhs":{"value":"cap"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"off"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"ptr","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"ptr","lhs":{"value":"buffer"},"rhs":{"value":"off"}},{"instruction_type":"variable_declaration","variable_name":"remaining","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"-","target":"remaining","lhs":{"value":"cap"},"rhs":{"value":"off"}},{"instruction_type":"function_invocation","invocation_name":"acquire-octets-starting-filesystem-document","invocation_ar