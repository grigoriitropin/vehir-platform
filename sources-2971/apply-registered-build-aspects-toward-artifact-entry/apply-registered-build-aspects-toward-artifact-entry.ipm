{"build_type":"library","description":"The build-aspect registry, expressed as code (mirrors detect-whole-program-universe-policy-violations being the enforcer registry-as-code). Runs every registered build aspect against one artifact entry at build time, returning the count of aspects that injected. Registering a new aspect is one call line here plus its package; no compiler-core change. Today the only registered aspect is the describe contract prologue.","module_name":"apply-registered-build-aspects-toward-artifact-entry","package_name":"apply-registered-build-aspects-toward-artifact-entry","function_definitions":{"apply-registered-build-aspects-toward-artifact-entry":{"return_type":"i64","parameter_definitions":[{"parameter_name":"doc","parameter_type":"i64"},{"parameter_name":"art","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation","invocation_name":"inject-describe-contract-build-aspect-toward-entry","invocation_arguments":[{"kind":"var","value":"doc"},{"kind":"var","value":"art"}],"result_assignment_variable":"r_describe","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"total","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"total","lhs":{"value":"zero"},"rhs":{"value":"r_describe"}},{"instruction_type":"return_statement","return_payload":{"value":"total"}}]}}}