{"build_type":"library","description":"Return the 64-hex sha256 of a NUL-terminated byte string (the package/graph text a reader op read from stdin). Wraps the length-scan + 32-byte digest buffer + compute_sha256_digest_into_buffer + 65-byte hex buffer + format_digest_hex dance into one call so every reader op computes its content hash identically (the dedup/last-seen cache key). Byte-exact: the hash covers the input verbatim, trailing newline included. Reuses compute_string_length_by_scanning, allocate_bytes_from_mmap_arena, compute_sha256_digest_into_buffer, format_digest_hex.","module_name":"compute-content-digest-within-cstring","package_name":"compute-content-digest-within-cstring","function_definitions":{"compute-content-digest-within-cstring":{"return_type":"str","parameter_definitions":[{"parameter_name":"raw","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"c32","variable_type":"i64","assignment_operation":"literal","source_target":32},{"instruction_type":"variable_declaration","variable_name":"c65","variable_type":"i64","assignment_operation":"literal","source_target":65},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"raw"}],"result_assignment_variable":"rawlen","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c32"}],"result_assignment_variable":"dig","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"compute-sha-digest-inside-buffer","invocation_arguments":[{"kind":"var","value":"raw"},{"kind":"var","value":"rawlen"},{"kind":"var","value":"dig"}],"result_assignment_variable":"hr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c65"}],"result_assignment_variable":"hex","result_type":"str"},{"instruction_type":"function_invocation","invocation_name":"convert-digest-bytes-towards-hexadecimal","invocation_arguments":[{"kind":"var","value":"dig"},{"kind":"var","value":"hex"}],"result_assignment_variable":"fr","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"hex"}}]}}}