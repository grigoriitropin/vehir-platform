{"build_type":"library","description":"Opens the file at path read-only and reads up to maxbytes leading octets into a fresh NUL-terminated arena buffer by LOOPING read until end of stream (procfs files short-read one page per call), returning the buffer; empty string on open failure. Reads independent of reported size, so it works on procfs files like proc cpuinfo whose stat size is zero.","module_name":"retrieve-leading-filepath-octet-window","package_name":"retrieve-leading-filepath-octet-window","function_definitions":{"retrieve-leading-filepath-octet-window":{"return_type":"str","parameter_definitions":[{"parameter_name":"path","parameter_type":"i64"},{"parameter_name":"maxbytes","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"empty","variable_type":"str","assignment_operation":"string","source_target":""},{"instruction_type":"variable_declaration","variable_name":"allocsize","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"allocsize","lhs":{"value":"maxbytes"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"acquire-filepath-towards-reading-operations","invocation_arguments":[{"kind":"var","value":"path"}],"result_assignment_variable":"fd","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"fd"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"empty"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"allocsize"}],"result_assignment_variable":"buffer","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"accumulate-descriptor-octets-until-exhausted","invocation_arguments":[{"kind":"var","value":"fd"},{"kind":"var","value":"buffer"},{"kind":"var","value":"zero"},{"kind":"var","value":"maxbytes"}],"result_assignment_variable":"got","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"release-allocated-system-descriptor-resource","invocation_arguments":[{"kind":"var","value":"fd"}],"result_assignment_variable":"dc","result_type":"i64"},{"instruction_type":"array_write","base":"buffer","index":"got","value":"zero","scale":1},{"instruction_type":"return_statement","return_payload":{"value":"buffer"}}]}}}