{"build_type":"executable","description":"Boot-policy decision for automatic rollback. Reads three raw-int boot-state files (counter, current generation, fallback generation) named in the request. If the failure counter has reached zero it selects the fallback generation (auto-rollback after N failed boots); otherwise it selects the current generation and decrements the counter back to its file. Emits the chosen generation, the remaining counter and whether it rolled back. The decrement is the boot-attempt charge that a successful userspace boot later resets.","module_name":"select-generation-honoring-failure-counter","package_name":"select-generation-honoring-failure-counter","function_definitions":{"select-generation-honoring-failure-counter":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"sixtyfour","variable_type":"i64","assignment_operation":"literal","source_target":64},{"instruction_type":"variable_declaration","variable_name":"k_counter","variable_type":"str","assignment_operation":"string","source_target":"counter"},{"instruction_type":"variable_declaration","variable_name":"k_current","variable_type":"str","assignment_operation":"string","source_target":"current"},{"instruction_type":"variable_declaration","variable_name":"k_fallback","variable_type":"str","assignment_operation":"string","source_target":"fallback"},{"instruction_type":"variable_declaration","va