{"build_type":"library","description":"Generic AST counter: return how many nodes in the subtree rooted at 'node' carry an instruction_type field whose string value equals 'kind' (byte-for-byte). Counts this node (if it matches) plus all descendants, descending via .child and across siblings via count_matching_instructions_across_siblings — so matches nested inside branch_on_success/branch_on_failure ARE counted. Safe on leaf nodes (locate_named_member_inside_mapping / .child return 0). Reuses compare_two_strings_byte_by_byte (0 = equal).","module_name":"count-matching-instructions-inside-subtree-sequence","package_name":"count-matching-instructions-inside-subtree-sequence","function_definitions":{"count-matching-instructions-inside-subtree-sequence":{"return_type":"i64","parameter_definitions":[{"parameter_name":"node","parameter_type":"i64"},{"parameter_name":"kind","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"m","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_it","variable_type":"str","assignment_operation":"string","source_target":"instruction_type"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"node"},{"kind":"var","value":"s_it"}],"result_assignment_variable":"it","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"it"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"field_read","struct":"json-tree-node","field":"text","base":"it","dest":"itstr"},{"instruction_type":"function_invocation","invocation_name":"compare-paired-strings-octet-through-octet","invocation_arguments":[{"kind":"var","value":"kind"},{"kind":"var","value":"itstr"}],"result_assignment_variable":"cmp","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"cmp"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"alu_operation","operator":"+","target":"m","lhs":{"value":"one"},"rhs":{"value":"zero"}}],"branch_on_failure":[]}],"branch_on_failure":[]},{"instruction_type":"field_read","struct":"json-tree-node","field":"child","base":"node","dest":"child"},{"instruction_type":"function_invocation","invocation_name":"count-matching-instructions-across-siblings","invocation_arguments":[{"kind":"var","value":"child"},{"kind":"var","value":"kind"},{"kind":"var","value":"zero"}],"result_assignment_variable":"cs","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"total","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"total","lhs":{"value":"m"},"rhs":{"value":"cs"}},{"instruction_type":"return_statement","return_payload":{"value":"total"}}]}}}