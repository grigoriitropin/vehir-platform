{"build_type":"library","description":"Runtime-layer input boundary seed: parse the single JSON request a tool receives in its argument vector (argv[1]). Returns the parsed JSON document root node, or 0 when no argument was given (argc<2) or the bytes do not parse. A tool calls this once instead of touching argv/stdin directly, so the tool body stays pure json-in. Reuses decode_entire_source_building_document.","module_name":"parse-argument-vector-json-request","package_name":"parse-argument-vector-json-request","function_definitions":{"parse-argument-vector-json-request":{"return_type":"i64","parameter_definitions":[{"parameter_name":"argc","parameter_type":"i64"},{"parameter_name":"argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"argc"},"rhs":{"value":"two"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"array_read","dest":"raw","base":"argv","index":"one","scale":8},{"instruction_type":"function_invocation","invocation_name":"decode-entire-source-building-document","invocation_arguments":[{"kind":"var","value":"raw"}],"result_assignment_variable":"req","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"req"}}]}}}