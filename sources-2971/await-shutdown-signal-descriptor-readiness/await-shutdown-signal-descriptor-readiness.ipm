{"build_type":"library","description":"Park on a signalfd via poll until the shutdown signal arrives as a readable event, then read the siginfo record and return its byte count. Event-driven, no sleep, no busy-wait. The timeout argument is passed straight to poll: negative means park indefinitely (the living kernel), a finite value bounds a test.","module_name":"await-shutdown-signal-descriptor-readiness","package_name":"await-shutdown-signal-descriptor-readiness","function_definitions":{"await-shutdown-signal-descriptor-readiness":{"return_type":"i64","parameter_definitions":[{"parameter_name":"sfd","parameter_type":"i64"},{"parameter_name":"timeout_ms","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"c128","variable_type":"i64","assignment_operation":"literal","source_target":128},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"eight"}],"result_assignment_variable":"pollbuf","result_type":"i64"},{"instruction_type":"array_write","base":"pollbuf","index":"zero","value":"sfd","scale":1},{"instruction_type":"array_write","base":"pollbuf","index":"four","value":"one","scale":1},{"instruction_type":"variable_declaration","variable_name":"t0","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"function_invocation