{"build_type":"executable","description":"Isolated proof (3c-i) that a PT_INTERP interpreter can locate AT_EXECFN through the kernel-provided stack. From its entry args (argc, &argv) it computes envp_base = argv + (argc+1)*8, steps past the envp NULL to the auxiliary vector, finds AT_EXECFN (key 31) = the path of the program being run, and returns that path's first byte. Run as the interpreter of a thin binary invoked by an absolute path, the first byte is '/' (47), so the process exits 47 — proving auxv traversal works in interpreter mode.","module_name":"report-execfn-first-octet-through-auxiliary","package_name":"report-execfn-first-octet-through-auxiliary","function_definitions":{"report-execfn-first-octet-through-auxiliary":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"at_execfn","variable_type":"i64","assignment_operation":"literal","source_target":31},{"instruction_type":"variable_declaration","variable_name":"argc_plus","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"argc_plus","lhs":{"value":"__argc"},"rhs":{"value":"one"}},{"instruction_type":"variable_declaration","variable_name":"envp_off","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"*","target":"envp_off","lhs":{"value":"argc_plus"},"rhs":{"value":"eight"}},{"instruction_type":"variable_declaration","variable_name":"envp_base","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"envp_base","lhs":{"value":"__argv"},"rhs":{"value":"envp_off"}},{"instruction_type":"function_invocation","invocation_name":"calculate-address-following-terminated-pointer-sequence","invocation_arguments":[{"kind":"var","value":"envp_base"},{"kind":"var","value":"zero"}],"result_assignment_variable":"auxv_base","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"locate-auxiliary-vector-value-using-identifier","invocation_arguments":[{"kind":"var","value":"auxv_base"},{"kind":"var","value":"at_execfn"},{"kind":"var","value":"zero"}],"result_assignment_variable":"execfn","result_type":"i64"},{"instruction_type":"array_read","dest":"byte0","base":"execfn","index":"zero","scale":1},{"instruction_type":"return_statement","return_payload":{"value":"byte0"}}]}}}