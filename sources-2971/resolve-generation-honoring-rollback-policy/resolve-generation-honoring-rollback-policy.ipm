{"build_type":"executable","description":"Integrated boot policy: resolves the final generation to boot from the raw-int boot-state files, chaining the three proven rules sequentially. Starts at current; if the failure counter is exhausted it rolls back to fallback (else decrements the counter); a pending one-shot override (if its file exists) wins and is consumed (unlinked) so it fires once; finally the chosen generation is validity-checked (its kernel-entry object must exist) and falls back if missing. Emits the chosen generation and which rules fired. Feed the chosen generation to the kernel launcher.","module_name":"resolve-generation-honoring-rollback-policy","package_name":"resolve-generation-honoring-rollback-policy","function_definitions":{"resolve-generation-honoring-rollback-policy":{"return_type":"i64","parameter_definitions":[{"parameter_name":"__argc","parameter_type":"i64"},{"parameter_name":"__argv","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"eight","variable_type":"i64","assignment_operation":"literal","source_target":8},{"instruction_type":"variable_declaration","variable_name":"sixtyfour","variable_type":"i64","assignment_operation":"literal","source_target":64},{"instruction_type":"variable_declaration","variable_name":"k_oneshot","variable_type":"str","assignment_operation":"string","source_target":"oneshot"},{"instruction_type":"variable_declaration","variable_name":"k_counter","variable_type":"str","assignment_operation":"string","source_target":"counter"},{"instruction_type":"variable_declaration","variable_name":"k_current","variable_type":"str","assignment_operation":"string","source_target":"current"}