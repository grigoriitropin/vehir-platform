{"build_type":"library","description":"Worker doorbell wake: rings the doorbell by waking one futex waiter through the futex driver (FUTEX_WAKE), then returns. The thread itself is terminated by the clone-trampoline epilogue (it emits the thread-exit), not here -- zero inline syscalls in this runtime body.","module_name":"wake-doorbell-waiter-terminating-calling-thread","package_name":"wake-doorbell-waiter-terminating-calling-thread","function_definitions":{"wake-doorbell-waiter-terminating-calling-thread":{"return_type":"i64","parameter_definitions":[{"parameter_name":"futex_word","parameter_type":"i64"},{"parameter_name":"wake_count","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"function_invocation","invocation_name":"operate-futex-value-across-userspace-address","invocation_arguments":[{"kind":"var","value":"futex_word"},{"kind":"var","value":"one"},{"kind":"var","value":"wake_count"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}