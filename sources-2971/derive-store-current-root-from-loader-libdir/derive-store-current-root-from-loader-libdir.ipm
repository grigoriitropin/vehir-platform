{"build_type":"library","module_name":"derive-store-current-root-from-loader-libdir","package_name":"derive-store-current-root-from-loader-libdir","description":"Return the store's current-generation root path (<store>/current) from the propagated loader library directory global (g_ld_libdir = <store>/current/bin/objlib), stripping the trailing '/bin/objlib' (11 octets). Anchors runtime store paths to the boot-provided libdir instead of a hardcoded absolute path -> relocatable store. Appends a NUL terminator so the returned buffer is a valid C string.","function_definitions":{"derive-store-current-root-from-loader-libdir":{"return_type":"i64","parameter_definitions":[],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"strip","variable_type":"i64","assignment_operation":"literal","source_target":11},{"instruction_type":"global_read","dest":"libdir","name":"g_ld_libdir"},{"instruction_type":"function_invocation","invocation_name":"measure-cstring-octet-length-value","invocation_arguments":[{"kind":"var","value":"libdir"},{"kind":"var","value":"zero"}],"result_assignment_variable":"len","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"n","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"-","target":"n","lhs":{"value":"len"},"rhs":{"value":"strip"}},{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"buf","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"copy-cstring-prefix-octets-into-string-buffer","invocation_arguments":[{"kind":"var","value":"libdir"},{"kind":"var","value":"n"},{"kind":"var","value":"buf"},{"kind":"var","value":"zero"}],"result_assignment_variable":"_c","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"append-single-octet-inside-expandable-buffer","invocation_arguments":[{"kind":"var","value":"buf"},{"kind":"var","value":"zero"}]},{"instruction_type":"field_read","struct":"string_buffer","field":"data","base":"buf","dest":"data"},{"instruction_type":"return_statement","return_payload":{"value":"data"}}]}}}