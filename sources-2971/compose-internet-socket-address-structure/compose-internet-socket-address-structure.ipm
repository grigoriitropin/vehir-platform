{"build_type":"library","description":"Fills a 16-byte buffer with an IPv4 stream socket address for binding/connecting: address family AF_INET in host order at offset 0, the listening port in network byte order at offset 2 from the caller-supplied port_hi and port_lo bytes, the loopback address 127.0.0.1 at offset 4, and zero padding through offset 15. Returns the address length 16. The port bytes are parameters (config-driven by the caller), no fixed port.","module_name":"compose-internet-socket-address-structure","package_name":"compose-internet-socket-address-structure","function_definitions":{"compose-internet-socket-address-structure":{"return_type":"i64","parameter_definitions":[{"parameter_name":"addr","parameter_type":"i64"},{"parameter_name":"port_hi","parameter_type":"i64"},{"parameter_name":"port_lo","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"two","variable_type":"i64","assignment_operation":"literal","source_target":2},{"instruction_type":"variable_declaration","variable_name":"three","variable_type":"i64","assignment_operation":"literal","source_target":3},{"instruction_type":"variable_declaration","variable_name":"i1","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"four","variable_type":"i64","assignment_operation":"literal","source_target":4},{"instruction_type":"variable_declaration","variable_name":"five","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"six","variable_type":"i64","assignment_operation":"literal","source_target":6},{"instruction_type":"variable_declaration","variable_name":"seven","variable_type":"i64","assignment_operation":"literal","source_target":7},{"instruction_type":"variable_declaration","variable_name":"loopback_first_octet","variable_type":"i64","assignment_operation":"literal","source_target":127},{"instruction_type":"variable_declaration","variable_name":"sixteen","variable_type":"i64","assignment_operation":"literal","source_target":16},{"instruction_type":"array_write","base":"addr","index":"zero","value":"two","scale":1},{"instruction_type":"array_write","base":"addr","index":"i1","value":"zero","scale":1},{"instruction_type":"array_write","base":"addr","index":"two","value":"port_hi","scale":1},{"instruction_type":"array_write","base":"addr","index":"three","value":"port_lo","scale":1},{"instruction_type":"array_write","base":"addr","index":"four","value":"loopback_first_octet","scale":1},{"instruction_type":"array_write","base":"addr","index":"five","value":"zero","scale":1},{"instruction_type":"array_write","base":"addr","index":"six","value":"zero","scale":1},{"instruction_type":"array_write","base":"addr","index":"seven","value":"i1","scale":1},{"instruction_type":"array_write","base":"addr","index":"i1","value":"zero","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"sixteen"}}]}}}