{"build_type":"library","description":"Walk a linked list of function definition nodes (the children of a package function_definitions object, threaded by next) and bucket each by the byte-for-byte serialization of its definition value. The serialized body is used directly as the bucket key in the buckets object, so two functions with identical definitions land in the same bucket regardless of their names; each function name is appended to its bucket array. Recurses along next; a null node ends the walk. Arguments are the first function node and the shared buckets object.","module_name":"place-package-functions-within-matching-clone-buckets","package_name":"place-package-functions-within-matching-clone-buckets","function_definitions":{"place-package-functions-within-matching-clone-buckets":{"return_type":"i64","parameter_definitions":[{"parameter_name":"fn_node","parameter_type":"i64"},{"parameter_name":"buckets","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"fn_node"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"variable_declaration","variable_name":"threshold","variable_type":"i64","assignment_operation":"literal","source_target":5},{"instruction_type":"variable_declaration","variable_name":"s_body","variable_type":"str","assignment_operation":"string","source_target":"body"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"fn_node"},{"kind":"var","value":"s_body"}],"result_assignment_variable":"body_node","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","oper