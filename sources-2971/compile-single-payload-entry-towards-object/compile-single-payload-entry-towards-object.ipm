{"build_type":"library","description":"Render one low-IR data item (a named string or zero-fill) into a relocation-free native object as JSON text. Reuses the whole-module data emitters (loop1 for zero-fill count, loop2 + trailing NUL for text) so the emitted bytes are byte-identical to the monolithic data section, then serializes via the shared object serializer. Data items become their own named objects so a function's string reference is an external relocation the loader resolves by name to the shared data object (one string, one object, zero duplication).","module_name":"compile-single-payload-entry-towards-object","package_name":"compile-single-payload-entry-towards-object","function_definitions":{"compile-single-payload-entry-towards-object":{"return_type":"i64","parameter_definitions":[{"parameter_name":"dent","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"k_name","variable_type":"str","assignment_operation":"string","source_target":"name"},{"instruction_type":"variable_declaration","variable_name":"k_zeros","variable_type":"str","assignment_operation":"string","source_target":"zeros"},{"instruction_type":"variable_declaration","variable_name":"k_text","variable_type":"str","assignment_operation":"string","source_target":"text"},{"instruction_type":"function_invocation","invocation_name":"create-empty-string-buffer-sequence","invocation_arguments":[],"result_assignment_variable":"code","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"dent"},{"kind":"var","value":"k_zeros"}],"result_assignment_variable":"zeros