{"build_type":"library","description":"Linear search over the reconcile universe array (each element is {path, doc} where doc is the parsed package AST) for the package whose doc.package_name equals the target c-string, byte-for-byte. Returns that doc document node, or 0 if no package matches. Tail-recurses by index across [i,n). Used at build time to map a declared-build-state artifact (target == package_name) back to its parsed AST so per-tool contract facts can be derived. Reuses fetch_member_residing_within_sequence, locate_named_member_inside_mapping, compare_two_strings_byte_by_byte.","module_name":"locate-package-document-matching-package-identifier","package_name":"locate-package-document-matching-package-identifier","function_definitions":{"locate-package-document-matching-package-identifier":{"return_type":"i64","parameter_definitions":[{"parameter_name":"universe","parameter_type":"i64"},{"parameter_name":"target","parameter_type":"i64"},{"parameter_name":"i","parameter_type":"i64"},{"parameter_name":"n","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"s_pkgname","variable_type":"str","assignment_operation":"string","source_target":"package_name"},{"instruction_type":"global_read","dest":"nidx","name":"g_universe_name_index"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"nidx"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"nidx"},{"kind":"var","value":"target"}],"result_assignment_variable":"hit","result_type":"i64"},{"i