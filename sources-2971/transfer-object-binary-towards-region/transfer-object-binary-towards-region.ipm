{"build_type":"library","description":"Copy one native object's code bytes (a sequence of integer bytes) into the loader's mmap region (global g_ld_region) starting at the given base offset, one byte per element, by tail recursion over the index. Used while placing each object in the contiguous link region.","module_name":"transfer-object-binary-towards-region","package_name":"transfer-object-binary-towards-region","function_definitions":{"transfer-object-binary-towards-region":{"return_type":"i64","parameter_definitions":[{"parameter_name":"base","parameter_type":"i64"},{"parameter_name":"code","parameter_type":"i64"},{"parameter_name":"idx","parameter_type":"i64"},{"parameter_name":"count","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"<","lhs":{"value":"idx"},"rhs":{"value":"count"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"fetch-member-residing-within-sequence","invocation_arguments":[{"kind":"var","value":"code"},{"kind":"var","value":"idx"}],"result_assignment_variable":"item","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"fetch-number-field-tolerating-absence","invocation_arguments":[{"kind":"var","value":"item"}],"result_assignment_variable":"byte","result_type":"i64"},{"instruction_type":"global_read","dest":"region","name":"g_ld_region"},{"instruction_type":"variable_declaration","variable_name":"pos","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"pos","lhs":{"value":"base"},"rhs":{"value":"idx"}},{"instruction_type":"array_write","