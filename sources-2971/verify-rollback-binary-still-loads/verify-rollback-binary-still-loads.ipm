{"build_type":"library","description":"Fork-exec a named binary from a generation bin directory and return its wait-status word, used as a pre-flip load check. A zero status means the binary loaded and ran cleanly; a non-zero means it failed to load (a missing relocation object) or crashed. The reconcile uses this both to smoke-test the build probe and, critically, to confirm the new generation rollback binary still loads before the current generation is flipped, so a generation can never become current unless it is self-rollback-able.","module_name":"verify-rollback-binary-still-loads","package_name":"verify-rollback-binary-still-loads","function_definitions":{"verify-rollback-binary-still-loads":{"return_type":"i64","parameter_definitions":[{"parameter_name":"gen_bin_dir","parameter_type":"i64"},{"parameter_name":"binary_name","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"i1","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"variable_declaration","variable_name":"c16","variable_type":"i64","assignment_operation":"literal","source_target":16},{"instruction_type":"function_invocation","invocation_name":"construct-content-addressed-storage-location","invocation_arguments":[{"kind":"var","value":"gen_bin_dir"},{"kind":"var","value":"binary_name"}],"result_assignment_variable":"rprobe","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c16"}],"result_assignment_variable":"rargv","result_type":"i64"},{"instruction_type":"array_write","base":"rargv","index":"zero","value":"rprobe","scale":8},{"instruction_type":"array_write","base":"rargv","index":"i1","value":"zero","scale":8},{"instruction_type":"function_invocation","invocation_name":"duplicate-current-process-returning-child-identifier","invocation_arguments":[],"result_assignment_variable":"rpid","result_type":"i64"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"==","lhs":{"value":"rpid"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"function_invocation","invocation_name":"replace-running-process-image-executing-program","invocation_arguments":[{"kind":"var","value":"rprobe"},{"kind":"var","value":"rargv"},{"kind":"var","value":"zero"}],"result_assignment_variable":"_rex","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}],"branch_on_failure":[]},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"c16"}],"result_assignment_variable":"rstatbuf","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"await-child-process-termination-returning-status","invocation_arguments":[{"kind":"var","value":"rpid"},{"kind":"var","value":"rstatbuf"}],"result_assignment_variable":"rstatus","result_type":"i64"},{"instruction_type":"array_read","dest":"rstatword","base":"rstatbuf","index":"zero","scale":8},{"instruction_type":"return_statement","return_payload":{"value":"rstatword"}}]}},"module_globals":[]}