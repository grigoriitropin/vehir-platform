{"build_type":"library","description":"MCP per-connection handler worker (SM.1): decode {conn}, read+dispatch+reply on that ONE connection via answer-protocol-request-framing-internet-reply (which reads the request, renders the response in-process, writes the framed HTTP reply, shuts down and closes the conn), then exit-and-notify. One connection per worker: a slow or faulting handler costs one connection, not the service.","module_name":"handle-protocol-connection-item-writing-reply","package_name":"handle-protocol-connection-item-writing-reply","function_definitions":{"handle-protocol-connection-item-writing-reply":{"return_type":"i64","parameter_definitions":[{"parameter_name":"item","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"k_conn","variable_type":"str","assignment_operation":"string","source_target":"conn"},{"instruction_type":"variable_declaration","variable_name":"capbig","variable_type":"i64","assignment_operation":"literal","source_target":1048576},{"instruction_type":"function_invocation","invocation_name":"decode-entire-source-building-document","invocation_arguments":[{"kind":"var","value":"item"}],"result_assignment_variable":"doc","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"doc"},{"kind":"var","value":"k_conn"}],"result_assignment_variable":"cnode","result_type":"i64"},{"instruction_type":"field_read","struct":"json-tree-node","field":"number","base":"cnode","dest":"conn"},{"instruction_type":"function_invocation","invocation_name":"allocate-character-buffer-inside-memory-arena","invocation_arguments":[{"kind":"var","value":"capbig"}],"result_assignment_variable":"scratch","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"answer-protocol-request-framing-internet-reply","invocation_arguments":[{"kind":"var","value":"conn"},{"kind":"var