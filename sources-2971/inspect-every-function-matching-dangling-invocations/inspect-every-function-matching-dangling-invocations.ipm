{"build_type":"library","description":"Walk a function_definitions object's members as a json-tree-node linked list (node = first child, follow .next). For each function: record its name into the module global g_dangling_fn_name, collect its invocation names via gx_collect_instr_calls (recursively, including nested branches), then check each against the index via check_function_calls_against_index, appending dangling records to out. Tail-recurses over .next. Reuses locate_named_member_inside_mapping, count_members_inside_container_value, begin_empty_sequence_document_value, gx_collect_instr_calls, check_function_calls_against_index.","module_name":"inspect-every-function-matching-dangling-invocations","package_name":"inspect-every-function-matching-dangling-invocations","module_globals":[{"global_name":"g_dangling_fn_name","global_type":"i64","global_init":"0"}],"function_definitions":{"inspect-every-function-matching-dangling-invocations":{"return_type":"i64","parameter_definitions":[{"parameter_name":"member","parameter_type":"i64"},{"parameter_name":"index","parameter_type":"i64"},{"parameter_name":"out","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"s_ei","variable_type":"str","assignment_operation":"string","source_target":"execution_instructions"},{"instruction_type":"conditional_branch","condition_type":"numeric_compare","operator":"!=","lhs":{"value":"member"},"rhs":{"value":"zero"},"branch_on_success":[{"instruction_type":"field_read","struct":"json-tree-node","field":"key","base":"member","dest":"fname"},{"instruction_type":"global_write","name":"g_dangling_fn_name","value":"fname"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"member"},{"kind":"var","value":"s_ei"}],"result_assignment_variable":"ei","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"count-members-inside-container-value","invocation_arguments":[{"kind":"var","value":"ei"}],"result_assignment_variable":"ninstr","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"begin-empty-sequence-document-value","invocation_arguments":[],"result_assignment_variable":"calls","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"extract-graph-collect-instruction-calls","invocation_arguments":[{"kind":"var","value":"ei"},{"kind":"var","value":"calls"},{"kind":"var","value":"zero"},{"kind":"var","value":"ninstr"}],"result_assignment_variable":"rc","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"check-function-calls-against-index","invocation_arguments":[{"kind":"var","value":"calls"},{"kind":"var","value":"index"},{"kind":"var","value":"out"},{"kind":"var","value":"zero"}],"result_assignment_variable":"rch","result_type":"i64"},{"instruction_type":"field_read","struct":"json-tree-node","field":"next","base":"member","dest":"nxt"},{"instruction_type":"function_invocation","invocation_name":"inspect-every-function-matching-dangling-invocations","invocation_arguments":[{"kind":"var","value":"nxt"},{"kind":"var","value":"index"},{"kind":"var","value":"out"}],"result_assignment_variable":"r","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"r"}}],"branch_on_failure":[]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}