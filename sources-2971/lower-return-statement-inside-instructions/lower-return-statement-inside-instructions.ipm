{"build_type":"library","description":"Native (pure-IPM, Variant-A) lowering handler for the high instruction_type return_statement (#33 VARIANT A). Native replacement for the monolith's return_statement branch. Emits one low-op {instruction_type:ret, value:<payload value text>}. The payload value comes from inst.return_payload.value, read via locate_named_member_inside_mapping(inst, \"return_payload\") then inst_field_string(payload, \"value\") -- the native decomposition of the verbatim-C extract_json_field_string_value(locate_named_member_inside_mapping(inst, \"return_payload\"), \"value\"). Op object is created/appended via begin_native_low_op_object and its single field set via add_string_to_object. This is the brief template for the remaining per-type handlers handed to Gemini. Depends on native-lowering-emit-helpers and the native json-tree-node DOM.","module_name":"lower-return-statement-inside-instructions","package_name":"lower-return-statement-inside-instructions","function_definitions":{"lower-return-statement-inside-instructions":{"return_type":"void","parameter_definitions":[{"parameter_name":"inst","parameter_type":"i64"},{"parameter_name":"ops","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"key_return_payload","variable_type":"str","assignment_operation":"string","source_target":"return_payload"},{"instruction_type":"variable_declaration","variable_name":"key_value","variable_type":"str","assignment_operation":"string","source_target":"value"},{"instruction_type":"variable_declaration","variable_name":"type_ret","variable_type":"str","assignment_operation":"string","source_target":"ret"},{"instruction_type":"function_invocation","invocation_name":"locate-named-member-inside-mapping","invocation_arguments":[{"kind":"var","value":"inst"},{"kind":"var","value":"key_return_payload"}],"result_assignment_variable":"payload","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"extract-instruction-field-string-value","invocation_arguments":[{"kind":"var","value":"payload"},{"kind":"var","value":"key_value"}],"result_assignment_variable":"value_text","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"initialize-native-primitive-operation-mapping","invocation_arguments":[{"kind":"var","value":"ops"},{"kind":"var","value":"type_ret"}],"result_assignment_variable":"op","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"attach-string-member-towards-object","invocation_arguments":[{"kind":"var","value":"op"},{"kind":"var","value":"key_value"},{"kind":"var","value":"value_text"}]},{"instruction_type":"return_statement","return_payload":{"value":"zero"}}]}}}