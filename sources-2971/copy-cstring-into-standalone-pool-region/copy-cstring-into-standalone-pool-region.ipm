{"build_type":"library","module_name":"copy-cstring-into-standalone-pool-region","package_name":"copy-cstring-into-standalone-pool-region","description":"Copy a NUL-terminated cstring into a freshly granted standalone pool region (allocate-system-memory-chunk-region, len+1 bytes) and return the region base. The copy outlives the caller's per-thread arena, so an as-completed worker result survives its own arena being reaped (design section 4.4 flat-bytes lifetime fix). Copy-only: the caller renders any DOM to a cstring first.","function_definitions":{"copy-cstring-into-standalone-pool-region":{"return_type":"i64","parameter_definitions":[{"parameter_name":"cstr","parameter_type":"i64"}],"execution_instructions":[{"instruction_type":"variable_declaration","variable_name":"zero","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"variable_declaration","variable_name":"one","variable_type":"i64","assignment_operation":"literal","source_target":1},{"instruction_type":"function_invocation","invocation_name":"determine-string-character-sequence-length","invocation_arguments":[{"kind":"var","value":"cstr"}],"result_assignment_variable":"len","result_type":"i64"},{"instruction_type":"variable_declaration","variable_name":"len1","variable_type":"i64","assignment_operation":"literal","source_target":0},{"instruction_type":"alu_operation","operator":"+","target":"len1","lhs":{"value":"len"},"rhs":{"value":"one"}},{"instruction_type":"function_invocation","invocation_name":"allocate-system-memory-chunk-region","invocation_arguments":[{"kind":"var","value":"len1"}],"result_assignment_variable":"region","result_type":"i64"},{"instruction_type":"function_invocation","invocation_name":"transfer-cstring-octets-inside-region","invocation_arguments":[{"kind":"var","value":"cstr"},{"kind":"var","value":"region"},{"kind":"var","value":"zero"}],"result_assignment_variable":"_cp","result_type":"i64"},{"instruction_type":"return_statement","return_payload":{"value":"region"}}]}}}